@model SpaN5.Models.Customer
@{
    ViewData["Title"] = "Hồ sơ Chuyên sâu: " + Model.FullName;
    Layout = "~/Areas/Staff/Views/Shared/_StaffLayout.cshtml";
    var historyNotes = ViewBag.HistoryNotes as List<SpaN5.Models.CustomerNote> ?? new List<SpaN5.Models.CustomerNote>();
    var totalServices = Model.Bookings.SelectMany(b => b.BookingDetails).Count();
    
    // Tổng hợp các ghi chú lâm sàng quan trọng (AI Alert)
    var clinicalAlerts = historyNotes.Where(n => n.Note.ToLower().Contains("da nhạy cảm") || 
                                               n.Note.ToLower().Contains("dị ứng") || 
                                               n.Note.ToLower().Contains("lưu ý") ||
                                               n.Note.ToLower().Contains("áp lực")).ToList();
}

<style>
    .dossier-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        border-radius: 32px;
        padding: 40px;
        color: white;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
    }
    .dossier-header::after {
        content: ''; position: absolute; top: -50px; right: -50px;
        width: 200px; height: 200px; background: rgba(99, 102, 241, 0.1);
        filter: blur(50px); border-radius: 50%;
    }
    .tier-badge {
        background: linear-gradient(90deg, #f59e0b, #d97706);
        padding: 6px 16px; border-radius: 50px; font-weight: 800; font-size: 0.7rem;
        text-transform: uppercase; color: white; letter-spacing: 1px;
    }
    .stat-pill {
        background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px; padding: 15px; text-align: center;
    }
    .clinic-alert-card {
        background: #fff1f2; border-left: 6px solid #e11d48;
        border-radius: 16px; padding: 20px; margin-bottom: 25px;
    }
    .timeline-vertical { position: relative; padding-left: 30px; }
    .timeline-vertical::before {
        content: ''; position: absolute; left: 8px; top: 0; bottom: 0;
        width: 2px; background: #e2e8f0;
    }
    .timeline-point {
        position: relative; margin-bottom: 30px;
    }
    .timeline-dot {
        position: absolute; left: -26px; top: 5px;
        width: 12px; height: 12px; border-radius: 50%;
        background: #94a3b8; border: 2px solid white;
    }
    .timeline-point.latest .timeline-dot { background: #6366f1; box-shadow: 0 0 0 4px rgba(99,102,241,0.1); }
    
    .treatment-card {
        background: white; border: 1px solid #e2e8f0; border-radius: 16px;
        padding: 20px; transition: all 0.3s;
    }
    .treatment-card:hover { transform: translateX(5px); border-color: #6366f1; }
</style>

<div class="container-fluid py-4" style="max-width: 1000px;">
    <!-- Nút Quay lại -->
    <a href="javascript:history.back()" class="btn btn-link text-decoration-none text-muted mb-3 px-0">
        <i class="bi bi-arrow-left me-2"></i>Quay lại lịch trình
    </a>

    <!-- Header Dossier -->
    <div class="dossier-header shadow-lg">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-4">
                    <div class="rounded-4 bg-primary text-white d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem; font-weight: 800;">
                        @Model.FullName.FirstOrDefault()
                    </div>
                    <div>
                        <div class="tier-badge mb-2">Hạng Diamond</div>
                        <h1 class="fw-bold mb-1" style="font-size: 2rem;">@Model.FullName.ToUpper()</h1>
                        <div class="d-flex gap-3 opacity-75 small">
                            <span><i class="bi bi-phone me-1"></i> @Model.Phone</span>
                            <span><i class="bi bi-geo-alt me-1"></i> @(Model.Address ?? "Chưa có địa chỉ")</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="row g-2 mt-3 mt-md-0">
                    <div class="col-6">
                        <div class="stat-pill">
                            <div class="small opacity-50 mb-1">Tổng chi tiêu</div>
                            <div class="fw-bold">@Model.TotalSpent.ToString("N0") đ</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-pill">
                            <div class="small opacity-50 mb-1">Điểm tích lũy</div>
                            <div class="fw-bold">@Model.LoyaltyPoints.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Cột Trái: Cảnh báo & Ghi chú -->
        <div class="col-lg-4">
            <h5 class="fw-bold text-dark mb-4"><i class="bi bi-shield-exclamation me-2 text-danger"></i>Lưu ý Chuyên môn</h5>
            
            @if (clinicalAlerts.Any())
            {
                <div class="clinic-alert-card shadow-sm">
                    <div class="fw-bold text-danger mb-2 small text-uppercase letter-spacing-1">Cảnh báo Quan trọng</div>
                    <ul class="list-unstyled mb-0 small">
                        @foreach(var alert in clinicalAlerts)
                        {
                            <li class="mb-2"><i class="bi bi-dot me-1"></i>"@alert.Note"</li>
                        }
                    </ul>
                </div>
            }
            else
            {
                <div class="p-4 rounded-4 bg-light text-muted text-center italic small mb-4">
                    Chưa có cảnh báo đặc biệt cho khách hàng này.
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-dark mb-3">Thông tin bổ sung</h6>
                    <div class="small text-muted mb-3">Ngày bắt đầu đồng hành cùng Spa: <span class="fw-bold text-dark">@Model.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                    <div class="small text-muted mb-0">Dịch vụ thực hiện nhiều nhất: <br/><span class="fw-bold text-primary">Massage Thụy Điển (12 lần)</span></div>
                </div>
            </div>
        </div>

        <!-- Cột Phải: Lịch trình & Phản hồi -->
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold text-dark mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Lịch sử Điều trị (@totalServices lần)</h5>
                <div class="badge bg-soft-primary text-primary rounded-pill px-3 py-2">Dữ liệu từ @Model.Bookings.Count lần ghé thăm</div>
            </div>

            <div class="timeline-vertical">
                @{
                    var sortedTimeline = Model.Bookings
                        .SelectMany(b => b.BookingDetails)
                        .OrderByDescending(bd => bd.Booking.BookingDate)
                        .ThenByDescending(bd => bd.Booking.StartTime)
                        .ToList();
                }

                @foreach(var item in sortedTimeline)
                {
                    <div class="timeline-point @(item == sortedTimeline.First() ? "latest" : "")">
                        <div class="timeline-dot"></div>
                        <div class="treatment-card shadow-sm">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="small text-muted fw-bold">@item.Booking.BookingDate.ToString("dd/MM/yyyy") • @item.Booking.StartTime.ToString("HH:mm")</div>
                                    <h6 class="fw-bold text-dark mb-1">@item.Service.ServiceName</h6>
                                </div>
                                <div class="text-end">
                                    <div class="small text-primary fw-bold">KTV: @(item.Staff?.FullName ?? "N/A")</div>
                                    @if (item.Status == SpaN5.Models.DetailStatus.Completed)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill" style="font-size: 0.6rem;">ĐÃ XONG</span>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(item.TechnicianNote))
                            {
                                <div class="p-3 rounded-3 bg-light smaller italic text-muted mt-2">
                                    <i class="bi bi-chat-quote me-2 fs-6"></i>"@item.TechnicianNote"
                                </div>
                            }
                            
                            <!-- Hiển thị phản hồi của khách cho loại dịch vụ này nếu có -->
                            @{
                                var review = Model.Reviews.OrderByDescending(r => r.CreatedAt).FirstOrDefault(r => r.ServiceId == item.ServiceId);
                            }
                            @if (review != null)
                            {
                                <div class="mt-3 pt-3 border-top border-light d-flex align-items-center gap-3">
                                    <div class="text-warning">
                                        @for(int i=1; i<=5; i++) { <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i> }
                                    </div>
                                    <div class="small fw-bold text-dark italic">" @review.Comment "</div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
