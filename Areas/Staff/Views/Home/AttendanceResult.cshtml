@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Kết quả chấm công";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow-sm rounded-4 p-5">
                <div class="mb-4">
                    <i class="bi bi-patch-check-fill text-success" style="font-size: 5rem;"></i>
                </div>
                <h2 class="fw-bold text-dark mb-3">@ViewBag.Message</h2>
                <p class="text-muted mb-4">Hệ thống đã ghi nhận thời gian làm việc của bạn vào cơ sở dữ liệu.</p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary rounded-pill px-5 py-2 fw-bold">
                    Quay lại Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
