<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The Serene Spa Therapist</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
         :root {
            --serene-navy: #1e293b;
            --serene-blue: #0ea5e9;
            --serene-blue-strong: #0284c7;
            --serene-blue-light: #f0f9ff;
            --serene-bg: #f8fafc;
            --serene-text: #64748b;
            --serene-text-dark: #0f172a;
            --serene-border: #e2e8f0;
            --serene-white: #ffffff;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--serene-bg);
            color: var(--serene-text-dark);
            overflow-x: hidden;
            margin: 0;
        }

        /* Sidebar Styling */
        #sidebar-wrapper {
            width: 250px;
            background-color: var(--serene-white);
            border-right: 1px solid var(--serene-border);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 1.5rem 1.5rem 1rem 1.5rem;
            display: flex;
            flex-direction: column;
            text-decoration: none;
            border-bottom: 1px solid transparent;
        }

        .brand-text-wrapper {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .brand-icon {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #0ea5e9, #3b82f6);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.85rem;
        }

        .brand-text {
            color: var(--serene-navy);
            font-size: 1.1rem;
            font-weight: 700;
            line-height: 1.2;
        }

        .brand-subtext {
            color: #94a3b8;
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            padding-left: 36px;
            margin-top: 4px;
        }

        /* User Profile in Sidebar */
        .user-profile {
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 1rem;
        }
        
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .user-info .name {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--serene-navy);
            margin-bottom: 0px;
            line-height: 1.2;
        }
        
        .user-info .role {
            font-size: 0.7rem;
            color: #94a3b8;
            font-weight: 500;
        }

        .sidebar-menu {
            padding: 0;
            list-style: none;
            margin: 0;
            flex-grow: 1;
        }

        .sidebar-menu .nav-item {
            margin-bottom: 0.2rem;
            padding: 0 1rem;
        }

        .sidebar-menu .nav-link {
            color: var(--serene-text);
            padding: 0.75rem 1.2rem;
            border-radius: 8px;
            display: flex;
            align-items: center;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .sidebar-menu .nav-link > i {
            margin-right: 14px;
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
        }

        .sidebar-menu .nav-link:hover {
            color: var(--serene-navy);
            background-color: var(--serene-bg);
        }

        .sidebar-menu .nav-link.active {
            color: var(--serene-blue-strong);
            background-color: transparent;
            position: relative;
        }
        
        .sidebar-menu .nav-link.active::before {
            content: '';
            position: absolute;
            left: -1rem;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 28px;
            background-color: var(--serene-blue-strong);
            border-radius: 0 4px 4px 0;
        }

        /* Main Content wrapper */
        #page-content-wrapper {
            margin-left: 250px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Header */
        .staff-header {
            background-color: var(--serene-white);
            padding: 0.75rem 2.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--serene-border);
            height: 70px;
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .page-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--serene-navy);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .shift-badge {
            background: var(--serene-blue-light);
            color: var(--serene-blue-strong);
            font-size: 0.75rem;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .shift-badge i { font-size: 0.6rem; }

        .header-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .btn-fast-complete {
            background-color: var(--serene-blue-strong);
            color: white;
            border: none;
            border-radius: 20px;
            padding: 0.4rem 1.25rem;
            font-size: 0.85rem;
            font-weight: 600;
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.2);
            transition: all 0.2s;
        }
        .btn-fast-complete:hover { background-color: #0369a1; }

        .btn-icon {
            background: none;
            border: none;
            color: #94a3b8;
            font-size: 1.1rem;
            position: relative;
            padding: 8px;
            border-radius: 50%;
            transition: all 0.2s;
        }
        .btn-icon:hover { color: var(--serene-navy); background: var(--serene-bg); }

        .main-content {
            padding: 2.5rem;
            flex-grow: 1;
        }

        /* Generic Card Styling */
        .card {
            border: 1px solid var(--serene-border);
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02), 0 2px 4px -1px rgba(0,0,0,0.02);
            border-radius: 16px;
            background: #fff;
            margin-bottom: 1.5rem;
            overflow: hidden;
        }

        @@media (max-width: 991.98px) {
            #sidebar-wrapper { transform: translateX(-100%); transition: transform 0.3s; }
            #sidebar-wrapper.show { transform: translateX(0); }
            #page-content-wrapper { margin-left: 0; }
        }
    </style>
</head>
<body>

    <!-- Left Sidebar -->
    <div id="sidebar-wrapper">
        <a href="/Staff/Home/Index" class="sidebar-brand">
            <div class="brand-text-wrapper">
                <div class="brand-icon"><i class="bi bi-flower1"></i></div>
                <span class="brand-text">The Serene Spa</span>
            </div>
            <div class="brand-subtext">Kỹ thuật viên</div>
        </a>

        <div class="user-profile">
            <img src="https://ui-avatars.com/api/?name=@User.Identity?.Name&background=0ea5e9&color=fff" alt="User Avatar" class="user-avatar" />
            <div class="user-info">
                <div class="name">@User.Identity?.Name</div>
                <div class="role">Kỹ thuật viên</div>
            </div>
        </div>

        <ul class="sidebar-menu">
            @{ string action = ViewContext.RouteData.Values["action"]?.ToString() ?? ""; }
            <li class="nav-item">
                <a href="/Staff/Home/Index" class="nav-link @(action == "Index" ? "active" : "")">
                    <i class="bi bi-calendar4-week"></i> Lịch làm việc
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="bi bi-briefcase"></i> Quy trình trị liệu
                </a>
            </li>
            <li class="nav-item">
                <a href="/Staff/Home/History" class="nav-link @(action == "History" ? "active" : "")">
                    <i class="bi bi-person-lines-fill"></i> Hồ sơ khách hàng
                </a>
            </li>
            <li class="nav-item">
                <a href="/Staff/Home/Commission" class="nav-link @(action == "Commission" ? "active" : "")">
                    <i class="bi bi-wallet2"></i> Thu nhập & Hoa hồng
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="bi bi-question-circle"></i> Hỗ trợ
                </a>
            </li>

            <!-- Dòng Đăng xuất ẩn ở cuối -->
            <li class="nav-item mt-auto mb-4 px-4 pt-5">
                 <a href="/Admin/Auth/Logout" class="nav-link text-danger" style="margin-left: -1rem;">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </a>
            </li>
        </ul>
    </div>

    <!-- Main Content -->
    <div id="page-content-wrapper">
        <!-- Header -->
        <header class="staff-header">
            <div class="header-left">
                <button class="btn btn-icon d-lg-none me-2" id="menu-toggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="page-title">The Serene Architect</div>
                <div class="shift-badge">
                    <i class="bi bi-circle-fill"></i> Ca sáng: 08:00 - 14:00
                </div>
            </div>

            <div class="header-right">
                <button class="btn-fast-complete">Hoàn tất nhanh</button>
                <button class="btn-icon">
                    <i class="bi bi-bell"></i>
                </button>
                <button class="btn-icon">
                    <i class="bi bi-gear"></i>
                </button>
            </div>
        </header>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <!-- Floating Action Button: Gọi Hỗ Trợ Khẩn Cấp -->
    <button class="btn btn-danger rounded-circle shadow-lg position-fixed" id="btnEmergencySupport" style="bottom: 30px; right: 30px; width: 60px; height: 60px; z-index: 9999; animation: pulse-red 2s infinite;">
        <i class="fa-solid fa-bell text-white fs-4"></i>
    </button>
    <style>
        @@keyframes pulse-red {
            0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7); }
            70% { box-shadow: 0 0 0 15px rgba(220, 53, 69, 0); }
            100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
        }
    </style>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('menu-toggle')?.addEventListener('click', function() {
            document.getElementById('sidebar-wrapper').classList.toggle('show');
        });

        // Xử lý Gọi hỗ trợ khẩn cấp
        document.getElementById('btnEmergencySupport').addEventListener('click', function() {
            Swal.fire({
                title: '🚨 GỌI LỄ TÂN HỖ TRỢ',
                html: `
                    <p class="text-muted mb-3">Bạn đang cần mang gấp món đồ nào vào phòng?</p>
                    <div class="d-flex flex-wrap gap-2 justify-content-center mb-3" id="quickOptions">
                        <button class="btn btn-outline-danger btn-sm rounded-pill" onclick="$('#emergencyMessage').val('Khăn tắm / Khăn đắp')">Khăn tắm</button>
                        <button class="btn btn-outline-danger btn-sm rounded-pill" onclick="$('#emergencyMessage').val('Tinh dầu massage')">Tinh dầu</button>
                        <button class="btn btn-outline-danger btn-sm rounded-pill" onclick="$('#emergencyMessage').val('Nước suối / Trà')">Nước uống</button>
                        <button class="btn btn-outline-danger btn-sm rounded-pill" onclick="$('#emergencyMessage').val('Hỗ trợ làm sạch phòng')">Dọn phòng</button>
                    </div>
                    <input type="text" id="emergencyMessage" class="form-control text-center" placeholder="Hoặc nhập yêu cầu khác...">
                `,
                showCancelButton: true,
                confirmButtonText: '<i class="fa-solid fa-paper-plane me-1"></i> Gửi Yêu Cầu',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#dc3545',
                focusConfirm: false,
                preConfirm: () => {
                    const msg = document.getElementById('emergencyMessage').value.trim();
                    if (!msg) {
                        Swal.showValidationMessage('Vui lòng nhập hoặc chọn đồ cần hỗ trợ!');
                        return false;
                    }
                    return msg;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    // Gọi AJAX
                    $.post('/Staff/Home/RequestEmergencySupport', { message: result.value }, function(res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Đã gửi yêu cầu!',
                                text: 'Lễ tân đã nhận được thông báo và sẽ mang vào ngay.',
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } else {
                            Swal.fire('Lỗi', res.message || 'Không thể gửi yêu cầu', 'error');
                        }
                    }).fail(function() {
                        Swal.fire('Lỗi', 'Có lỗi kết nối mạng.', 'error');
                    });
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
