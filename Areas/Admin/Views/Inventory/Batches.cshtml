@model SpaN5.Models.Material
@{
    ViewData["Title"] = "Quản lý Lô hàng - " + Model.MaterialName;
    Layout = "_AdminLayout";
    var now = DateTime.Now;
}

<style>
    .batch-item {
        border-radius: 16px;
        border: 2px solid var(--accent-blue);
        padding: 1.5rem;
        margin-bottom: 1rem;
        background: var(--white);
        transition: all 0.2s;
    }
    .batch-item.expired { border-color: #EE5D50; background: #FFF5F5; }
    .batch-item.warning { border-color: #FFB800; background: #FFF9E6; }
    
    .progress-custom {
        height: 10px;
        background: var(--admin-bg);
        border-radius: 10px;
        margin: 10px 0;
    }
    .progress-bar-custom {
        border-radius: 10px;
        background: var(--primary-blue);
    }
</style>

<div class="mb-4">
    <a href="/Admin/Inventory" class="btn btn-light rounded-pill px-3 fw-bold border-0" style="background: var(--accent-blue); color: var(--primary-blue);">
        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại kho
    </a>
</div>

<div class="glass-card p-4 mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="fw-bold mb-1">#MS-@Model.MaterialId - @Model.MaterialName</h2>
            <div class="text-muted fw-600">Tổng tồn hệ thống: <span class="text-main">@Model.CurrentStock.ToString("N0") @Model.Unit</span></div>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-primary rounded-pill px-4 fw-bold shadow-sm" onclick="alert('Tính năng nhập kho theo Lô (PO Flow) đang được thực hiện ở Phase 5')">
                <i class="fa-solid fa-file-import me-1"></i> Nhập lô mới
            </button>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <h4 class="fw-bold mb-4">Danh sách Lô hàng (Ưu tiên xuất theo HSD - FEFO)</h4>
        
        @if (!Model.Batches.Any())
        {
            <div class="glass-card text-center py-5">
                <i class="fa-solid fa-boxes-packing fa-3x text-muted mb-3 opacity-20"></i>
                <h5 class="text-muted">Chưa có thông tin lô hàng. Vui lòng nhập kho lô đầu tiên.</h5>
            </div>
        }
        else
        {
            foreach (var b in Model.Batches)
            {
                var isExpired = b.ExpiryDate < now;
                var isNearExpiry = !isExpired && b.ExpiryDate < now.AddDays(30);
                var statusClass = isExpired ? "expired" : (isNearExpiry ? "warning" : "");
                var usagePercent = (double)b.CurrentQuantity / b.OriginalQuantity * 100;

                <div class="batch-item @statusClass">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <span class="badge bg-dark rounded-pill mb-2">Lô: @b.BatchCode</span>
                            <h5 class="fw-bold mb-0">Hết hạn: @b.ExpiryDate.ToString("dd/MM/yyyy")</h5>
                        </div>
                        <div class="text-end">
                            @if (isExpired) { <span class="badge bg-danger rounded-pill mb-2">ĐÃ HẾT HẠN</span> }
                            else if (isNearExpiry) { <span class="badge bg-warning text-dark rounded-pill mb-2">SẮP HẾT HẠN</span> }
                            <div class="fw-bold text-main">Còn lại: @b.CurrentQuantity.ToString("N0") / @b.OriginalQuantity.ToString("N0") @Model.Unit</div>
                        </div>
                    </div>

                    <div class="progress progress-custom">
                        <div class="progress-bar progress-bar-custom" style="width: @usagePercent%"></div>
                    </div>

                    <div class="d-flex justify-content-between small text-muted fw-bold">
                        <span>Nhập ngày: @b.ReceivedDate.ToString("dd/MM/yyyy")</span>
                        <span>Giá nhập: @b.UnitCost.ToString("N0")đ/@Model.Unit</span>
                    </div>
                </div>
            }
        }
    </div>
    
    <div class="col-lg-4">
        <div class="glass-card p-4">
            <h5 class="fw-bold mb-3"><i class="fa-solid fa-info-circle me-2 text-primary"></i>Quy tắc FEFO</h5>
            <p class="small text-muted">
                Hệ thống tự động trừ vào lô hàng có <strong>Ngày hết hạn gần nhất</strong> trước. 
                Điều này đảm bảo quay vòng vốn và giảm thiểu hàng hỏng/hết hạn.
            </p>
            <hr class="opacity-10">
            <div class="d-flex justify-content-between mb-2">
                <span class="small fw-600 text-muted">Đang sử dụng lô</span>
                <span class="small fw-bold">@(Model.Batches.FirstOrDefault(b => b.CurrentQuantity > 0 && b.ExpiryDate > now)?.BatchCode ?? "N/A")</span>
            </div>
        </div>
    </div>
</div>
