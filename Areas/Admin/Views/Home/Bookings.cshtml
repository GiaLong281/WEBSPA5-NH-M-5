@model IEnumerable<SpaN5.Models.Booking>
@{
    ViewData["Title"] = "Quản lý lịch hẹn";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .filter-card {
        background: var(--white);
        border-radius: 24px;
        padding: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid var(--accent-blue);
        margin-bottom: 2rem;
    }
    
    .booking-card {
        background: transparent;
        border: none;
        padding: 0;
        box-shadow: none;
    }

    .booking-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 12px;
        margin-top: -12px;
    }
    .booking-table th {
        padding: 20px 24px;
        color: var(--secondary-blue);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .booking-row {
        background: var(--white);
        border-radius: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .booking-row:hover {
        transform: translateY(-3px) scale(1.005);
        box-shadow: 0 12px 30px rgba(67, 24, 255, 0.08);
        background: #FDFDFF;
    }
    .booking-row td {
        padding: 24px;
        vertical-align: middle;
        border: none;
    }
    .booking-row td:first-child { border-radius: 20px 0 0 20px; }
    .booking-row td:last-child { border-radius: 0 20px 20px 0; }

    /* Custom Status Badges */
    .status-pill {
        padding: 8px 16px;
        border-radius: 14px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .status-confirmed { background: #E9EDF7; color: #4318FF; }
    .status-accepted { background: #E0E7FF; color: #4338CA; }
    .status-pending { background: #FFF8E6; color: #FFB800; }
    .status-inprogress { background: #FEEEEE; color: #FF5B5B; }
    .status-completed { background: #E6F6ED; color: #00B050; }
    .status-cancelled { background: #F4F7FE; color: #A3AED0; }

    .customer-avatar {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--primary-blue) 0%, #707EFE 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
        box-shadow: 0 8px 16px rgba(67, 21, 255, 0.15);
    }

    .btn-circle-action {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: var(--admin-bg);
        border: none;
        color: var(--primary-blue);
        transition: all 0.2s;
    }
    .btn-circle-action:hover { background: var(--primary-blue); color: white; }

    /* Premium Dropdown Styling */
    .dropdown-menu {
        min-width: 220px;
        padding: 8px;
        border: 1px solid rgba(0,0,0,0.05) !important;
    }
    .dropdown-item {
        padding: 10px 16px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text-main);
        font-size: 0.9rem;
    }
    .dropdown-item i {
        font-size: 1.1rem;
        width: 20px;
        text-align: center;
    }
    .dropdown-item-info:hover { background-color: #f0f7ff !important; color: #007bff !important; }
    .dropdown-item-success:hover { background-color: #f0fff4 !important; color: #28a745 !important; }
    .dropdown-item-danger:hover { background-color: #fff5f5 !important; color: #dc3545 !important; }
    .dropdown-item-warning:hover { background-color: #fffcf0 !important; color: #ffc107 !important; }
    .dropdown-item-primary:hover { background-color: var(--accent-blue) !important; color: var(--primary-blue) !important; }

    .search-input {
        background: var(--admin-bg) !important;
        border: 2px solid transparent !important;
        border-radius: 16px !important;
        padding: 12px 15px 12px 45px !important;
        transition: all 0.2s !important;
    }
    .search-input:focus { border-color: var(--primary-blue) !important; background: white !important; box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; }

    .btn-action {
        background: linear-gradient(135deg, var(--primary-blue) 0%, #707EFE 100%);
        color: white;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 8px 15px rgba(67, 24, 255, 0.2);
    }
    .btn-action:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 20px rgba(67, 24, 255, 0.3);
        color: white;
    }

    /* Timeline Scheduler Specific */
    #calendar-timeline {
        background: white;
        padding: 20px;
        border-radius: 24px;
        box-shadow: var(--card-shadow);
        border: 1px solid var(--accent-blue);
        min-height: 600px;
    }
    .fc-header-toolbar {
        margin-bottom: 2rem !important;
    }
    .fc-resource-group {
        background: #f8faff !important;
        font-weight: 800 !important;
        color: var(--primary-blue) !important;
    }

    /* Waiting List Sidebar */
    #external-events {
        background: #f8faff;
        border-radius: 20px;
        padding: 20px;
        border: 1px dashed var(--luxury-gold);
        height: 100%;
        max-height: 600px;
        overflow-y: auto;
    }
    .fc-event-external {
        cursor: grab;
        padding: 12px;
        margin-bottom: 10px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        border-left: 4px solid var(--luxury-gold);
        transition: all 0.2s;
    }
    /* LUXURY TIMELINE ENHANCEMENTS */
    #calendar-timeline {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(15px);
        border-radius: 24px;
        padding: 15px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    }

    #calendar-timeline .fc-toolbar-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        color: #1a1a1a;
        letter-spacing: -1px;
    }

    /* Column Headers & Slots */
    .fc .fc-timeline-header-cell-cushion {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: #64748b;
        padding: 12px 0;
    }

    .fc .fc-resource-timeline-divider { background: rgba(0,0,0,0.03); }
    
    .fc-timeline-slot-label {
        font-weight: 600;
        color: #475569;
    }

    /* Resource Area (Left Side) */
    .fc .fc-datagrid-cell-cushion {
        padding: 12px 15px;
        font-weight: 700;
        color: #334155;
    }

    .fc .fc-datagrid-header-cell-cushion {
        font-weight: 900;
        color: #1e293b;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    /* Event Styling (The Booking Blocks) */
    .fc-timeline-event {
        border-radius: 12px !important;
        border: none !important;
        padding: 4px 8px !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    .fc-timeline-event:hover {
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
        z-index: 100 !important;
    }

    .fc-event-main-frame { padding: 4px; }
    
    .status-event-inprogress {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%) !important;
    }
    
    .status-event-completed {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
    }

    .status-event-accepted {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
    }

    /* Waiting List Sidebar Refinement */
    #external-events {
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 20px;
        padding: 20px;
        height: 100%;
        min-height: 400px;
    }

    .waiting-list-title {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 20px;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .fc-event-external {
        background: white;
        border: 1px solid rgba(0,0,0,0.05);
        border-left: 4px solid #f59e0b;
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 12px;
        cursor: grab;
        transition: all 0.2s;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

    .fc-event-external:active { cursor: grabbing; }

    .empty-waiting-state {
        text-align: center;
        padding: 40px 10px;
        color: #94a3b8;
    }

    .empty-waiting-state i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 15px;
        opacity: 0.3;
    }

    /* Tab Switcher Upgrade */
    .view-switcher-pill {
        background: rgba(255, 255, 255, 0.8);
        padding: 6px;
        border-radius: 16px;
        display: inline-flex;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }
    
    .view-switcher-pill .btn {
        border-radius: 12px;
        padding: 8px 16px;
        font-weight: 700;
        font-size: 0.85rem;
        border: none;
        transition: all 0.3s;
    }

    .view-switcher-pill .btn.active {
        background: #1a1a1a;
        color: white;
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    }

    .view-switcher-pill .btn:not(.active):hover {
        background: rgba(0,0,0,0.05);
    }
</style>

<!-- FullCalendar Scheduler Library -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler@5.11.3/main.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar-scheduler@5.11.3/main.min.js"></script>

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="fw-bold mb-1" style="letter-spacing: -1px;">Danh sách Lịch hẹn</h2>
        <p class="text-muted small">Quản lý, điều phối và xử lý lịch đặt của khách hàng</p>
    </div>
    <div class="col-auto">
        <div class="view-switcher-pill">
            <button class="btn active view-toggle-btn" id="btn-table-view">
                <i class="fa-solid fa-list-ul me-2"></i>Dọc (Bảng)
            </button>
            <button class="btn view-toggle-btn" id="btn-timeline-view">
                <i class="fa-solid fa-chart-gantt me-2"></i>Ngang (Timeline)
            </button>
        </div>
    </div>
</div>

<!-- Advanced Filters -->
<div class="filter-card">
    <form method="get" action="/Admin/Home/Bookings" class="row g-3">
        <div class="col-md-4">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute" style="left: 15px; top: 18px; color: var(--secondary-blue);"></i>
                <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control search-input" placeholder="Tìm tên khách, mã đơn hoặc SĐT...">
            </div>
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select border-0 bg-light rounded-3 py-2 px-3 fw-600">
                <option value="">Tất cả trạng thái</option>
                @foreach (var s in Enum.GetValues(typeof(SpaN5.Models.BookingStatus)))
                {
                    <option value="@s" selected="@(Context.Request.Query["status"] == s.ToString())">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <input type="text" name="date" value="@Context.Request.Query["date"]" class="form-control border-0 bg-light rounded-3 py-2 px-3 fw-600" placeholder="Ngày hẹn (dd/mm/yyyy)">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-action w-100 py-2">Áp dụng lọc</button>
        </div>
    </form>
</div>

<!-- Bookings List (Table View) -->
<div class="booking-card" id="table-view-container">
    <div class="table-responsive">
        <table class="booking-table">
            <thead>
                <tr>
                    <th style="width: 200px;">Thông tin đơn</th>
                    <th>Khách hàng</th>
                    <th>Dịch vụ & Kỹ thuật viên</th>
                    <th style="width: 160px;">Trạng thái</th>
                    <th style="width: 140px;">Thanh toán</th>
                    <th class="text-end" style="width: 100px;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if(!Model.Any()) {
                    <tr class="booking-row">
                        <td colspan="6" class="text-center py-5 text-muted">Không tìm thấy dữ liệu lịch hẹn phù hợp</td>
                    </tr>
                }
                @foreach (var bk in Model)
                {
                    <tr class="booking-row">
                        <td>
                            <div class="fw-800 text-primary mb-1">@bk.BookingCode</div>
                            <div class="text-muted smaller d-flex align-items-center gap-2">
                                <span><i class="fa-regular fa-calendar-days text-primary opacity-50"></i> @bk.BookingDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="text-muted smaller mt-1 d-flex align-items-center gap-2">
                                <span><i class="fa-regular fa-clock text-primary opacity-50"></i> @bk.StartTime.ToString("HH:mm") - @bk.EndTime.ToString("HH:mm")</span>
                            </div>
                            @if(bk.Status == SpaN5.Models.BookingStatus.InProgress) {
                                var totalDuration = bk.BookingDetails?.Sum(d => d.Service?.Duration ?? 0) ?? 0;
                                <div class="mt-2 p-1 rounded timer-container" 
                                     data-end-time="@bk.EndTime.ToString("O")" 
                                     data-duration="@totalDuration"
                                     style="background: rgba(255,91,91,0.1); border: 1px solid rgba(255,91,91,0.3); font-size: 0.75rem; max-width: 130px; text-align: center;">
                                    <i class="fa-solid fa-stopwatch text-danger me-1"></i><span class="fw-bold text-danger timer-text">Đang tính giờ...</span>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="customer-avatar me-3">@(bk.Customer?.FullName?[0].ToString().ToUpper() ?? "?")</div>
                                <div>
                                    <div class="fw-800 text-main" style="font-size: 1.05rem;">@bk.Customer?.FullName</div>
                                    <div class="text-muted smaller"><i class="fa-solid fa-phone-volume me-1 text-primary opacity-50"></i> @bk.Customer?.Phone</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-2">
                                @{ var currentServiceTime = bk.StartTime; }
                                @foreach(var detail in bk.BookingDetails) {
                                    var detailDuration = detail.Service?.Duration ?? 0;
                                    var detailEndTime = currentServiceTime.AddMinutes(detailDuration);
                                    
                                    <div class="p-2 bg-light rounded-3 border-start border-3 border-primary position-relative" style="background: #F8F9FD !important;">
                                        @if(bk.Status != SpaN5.Models.BookingStatus.Completed && detail.Status == SpaN5.Models.DetailStatus.InProgress) {
                                            <span class="position-absolute top-0 end-0 mt-1 me-1 badge bg-primary" style="font-size: 0.6rem;">Đang phục vụ</span>
                                        }
                                        
                                        <div class="fw-800 text-main small">
                                            @detail.Service?.ServiceName
                                        </div>
                                        <div class="text-muted smaller fw-600 mb-1" style="font-size: 0.75rem;">
                                            <i class="fa-regular fa-clock me-1 text-primary opacity-50"></i>
                                            @currentServiceTime.ToString("HH:mm") - @detailEndTime.ToString("HH:mm")
                                        </div>
                                        <div class="text-muted smaller" style="font-size: 0.75rem;">
                                            <i class="fa-solid fa-user-sparkles me-1 text-primary opacity-50"></i> 
                                            KTV: @(detail.Staff?.FullName ?? "Đang chờ điều phối")
                                        </div>
                                    </div>
                                    currentServiceTime = detailEndTime;
                                }
                            </div>
                        </td>
                        <td>
                            @{
                                var isPaid = bk.Payments != null && bk.Payments.Any(p => p.Status == SpaN5.Models.PaymentStatus.Paid);
                                
                                var statusName = bk.Status switch {
                                    SpaN5.Models.BookingStatus.Pending => "Đợi duyệt",
                                    SpaN5.Models.BookingStatus.Confirmed => "Đã xác nhận",
                                    SpaN5.Models.BookingStatus.Accepted => "KTV Đã nhận",
                                    SpaN5.Models.BookingStatus.InProgress => "Đang bận",
                                    SpaN5.Models.BookingStatus.Completed => isPaid ? "Hoàn thành" : "Chờ thanh toán",
                                    SpaN5.Models.BookingStatus.Cancelled => "Đã hủy",
                                    _ => bk.Status.ToString()
                                };

                                var statusClass = bk.Status == SpaN5.Models.BookingStatus.Completed && !isPaid 
                                                ? "status-unpaid" 
                                                : "status-" + bk.Status.ToString().ToLower();

                                var statusIcon = bk.Status switch {
                                    SpaN5.Models.BookingStatus.Pending => "fa-clock-rotate-left",
                                    SpaN5.Models.BookingStatus.Confirmed => "fa-circle-check",
                                    SpaN5.Models.BookingStatus.Accepted => "fa-user-check",
                                    SpaN5.Models.BookingStatus.InProgress => "fa-spinner fa-spin",
                                    SpaN5.Models.BookingStatus.Completed => isPaid ? "fa-circle-check" : "fa-file-invoice-dollar",
                                    SpaN5.Models.BookingStatus.Cancelled => "fa-circle-xmark",
                                    _ => "fa-info-circle"
                                };
                            }
                            <span class="status-pill @statusClass">
                                <i class="fa-solid @statusIcon"></i>
                                @statusName
                            </span>
                        </td>
                        <td>
                            <div class="fw-900 text-main fs-5">@bk.TotalAmount.ToString("N0")</div>
                            <div class="text-muted smaller fw-700">VND</div>
                        </td>
                        <td class="text-end">
                            <div class="dropdown">
                                <button class="btn-circle-action" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-2 rounded-4">
                                    <li><a class="dropdown-item dropdown-item-info rounded-3 fw-bold" href="/Booking/Details?bookingCode=@bk.BookingCode"><i class="fa-regular fa-eye"></i> Chi tiết</a></li>
                                    
                                    @if(bk.Status == SpaN5.Models.BookingStatus.Pending) {
                                        <li><button class="dropdown-item dropdown-item-success rounded-3 fw-bold" onclick="updateStatus(@bk.BookingId, 'ConfirmBooking')"><i class="fa-regular fa-circle-check"></i> Xác nhận</button></li>
                                    }

                                    @if(bk.Status == SpaN5.Models.BookingStatus.Pending || bk.Status == SpaN5.Models.BookingStatus.Confirmed) {
                                        <li><button class="dropdown-item dropdown-item-warning rounded-3 fw-bold" onclick="showRescheduleModal(@bk.BookingId, '@bk.BookingDate.ToString("yyyy-MM-dd")', '@bk.StartTime.ToString("HH:mm")')"><i class="fa-regular fa-clock"></i> Dời lịch hẹn</button></li>
                                    }

                                    @if(bk.Status == SpaN5.Models.BookingStatus.Confirmed) {
                                        <li><button class="dropdown-item dropdown-item-primary rounded-3 fw-bold" onclick="updateStatus(@bk.BookingId, 'CheckIn')"><i class="fa-solid fa-user-check"></i> Check-in khách</button></li>
                                    }
                                    
                                    @if(bk.Status == SpaN5.Models.BookingStatus.InProgress) {
                                        @if(bk.BookingDetails.Any(bd => bd.Status == SpaN5.Models.DetailStatus.Pending)) {
                                            <li><button class="dropdown-item dropdown-item-info rounded-3 fw-bold" onclick="showCheckInModal(@bk.BookingId, true)"><i class="fa-solid fa-arrow-right"></i> Chuyển dịch vụ tiếp theo</button></li>
                                        } else {
                                            <li><button class="dropdown-item dropdown-item-success rounded-3 fw-bold" onclick="showCompleteModal(@bk.BookingId, @bk.TotalAmount)"><i class="fa-solid fa-file-invoice-dollar"></i> Thanh toán</button></li>
                                        }
                                    }
                                    
                                    @if(bk.Status == SpaN5.Models.BookingStatus.Completed && !isPaid) {
                                        <li><button class="dropdown-item dropdown-item-success rounded-3 fw-bold" onclick="showCompleteModal(@bk.BookingId, @bk.TotalAmount)"><i class="fa-solid fa-file-invoice-dollar"></i> Thanh toán ngay</button></li>
                                    }
                                    
                                    @if(bk.Status != SpaN5.Models.BookingStatus.Completed && bk.Status != SpaN5.Models.BookingStatus.Cancelled) {
                                        <li><hr class="dropdown-divider opacity-50 mx-2"></li>
                                        <li><button class="dropdown-item dropdown-item-danger rounded-3 fw-bold" onclick="updateStatus(@bk.BookingId, 'RejectBooking')"><i class="fa-regular fa-trash-can"></i> Hủy lịch</button></li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Timeline View Container (Hidden) -->
<div id="timeline-view-container" style="display: none;">
    <div class="row g-4">
        <div class="col-md-3 col-lg-2">
            <div id="external-events">
                <div class="waiting-list-title">
                    <i class="fa-solid fa-user-clock text-warning"></i>
                    <span>Khách Đang Chờ</span>
                </div>
                <div id="external-events-list">
                    <!-- Danh sách chờ được load bằng AJAX -->
                    <div class="empty-waiting-state">
                        <i class="fa-solid fa-hourglass-empty"></i>
                        <p class="small">Hiện không có khách chờ điều phối</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-9 col-lg-10">
            <div id="calendar-timeline"></div>
        </div>
    </div>
</div>

<!-- Assignment & Payment Modals -->
<div class="modal fade" id="checkInModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-main">Điều phối dịch vụ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="checkInBookingId">
                <input type="hidden" id="isNextServiceMode" value="false">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Kỹ thuật viên thực hiện</label>
                    <select id="selectStaff" class="form-select border-0 bg-light rounded-3 py-2 px-3">
                        <option value="">-- Đang tải nhân viên... --</option>
                    </select>
                </div>
                <div class="mb-4">
                    <div class="p-3 rounded-3 bg-light border border-info" style="font-size: 0.85rem;">
                        <i class="fa-solid fa-robot text-info me-2"></i>
                        Hệ thống sẽ <strong>tự động gán phòng trống</strong> tối ưu nhất cho dịch vụ này.
                    </div>
                </div>
                <button class="btn btn-action w-100 py-2" onclick="confirmCheckIn()">
                    Xác nhận Bắt đầu
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="completeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0 justify-content-center position-relative">
                <h5 class="modal-title fw-bold text-main mt-2">Thanh toán dịch vụ</h5>
                <button type="button" class="btn-close position-absolute" data-bs-dismiss="modal" style="right: 15px; top: 15px;"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <!-- Bước 1: Chọn phương thức -->
                <div id="stepSelectMethod">
                    <div class="mb-3 text-muted fw-bold small">TỔNG CỘNG THANH TOÁN</div>
                    <div class="h2 fw-800 text-primary mb-4" id="modalAmount">0đ</div>
                    
                    <div class="row g-2">
                        <div class="col-6">
                            <button class="btn btn-outline-primary w-100 py-3 rounded-4 fw-bold" onclick="selectPaymentMethod('Cash')">
                                <i class="fa-solid fa-money-bill-wave d-block mb-1 fs-4"></i> Tiền mặt
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-outline-primary w-100 py-3 rounded-4 fw-bold" onclick="selectPaymentMethod('BankTransfer')">
                                <i class="fa-solid fa-building-columns d-block mb-1 fs-4"></i> Chuyển khoản
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Bước 2: Tiền mặt -->
                <div id="stepCash" style="display: none;">
                    <div class="mb-3 text-muted fw-bold small">SỐ TIỀN CẦN THU</div>
                    <div class="h2 fw-800 text-primary mb-4" id="cashAmount">0đ</div>
                    <p class="text-muted small mb-4">Vui lòng nhận tiền mặt từ khách hàng trước khi xác nhận.</p>
                    
                    <div class="row g-2">
                        <div class="col-6">
                            <button class="btn btn-light w-100 py-2 rounded-3 fw-bold" onclick="backToMethods()">
                                Hủy
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-success w-100 py-2 rounded-3 fw-bold" onclick="confirmComplete('Cash')">
                                <i class="fa-solid fa-check me-1"></i> Đã thanh toán
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Bước 2: Chuyển khoản -->
                <div id="stepBank" style="display: none;">
                    <div class="mb-1 text-muted fw-bold small">QUÉT MÃ QR ĐỂ THANH TOÁN</div>
                    
                    <div class="bg-light p-2 rounded-4 mb-4 d-inline-block shadow-sm">
                        <img id="qrCodeImg" src="" alt="Mã QR" style="width: 220px; height: 220px; object-fit: contain; border-radius: 8px;">
                    </div>
                    
                    <div class="row g-2">
                        <div class="col-6">
                            <button class="btn btn-light w-100 py-2 rounded-3 fw-bold" onclick="backToMethods()">
                                Hủy
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-success w-100 py-2 rounded-3 fw-bold" onclick="confirmComplete('BankTransfer')">
                                <i class="fa-solid fa-check me-1"></i> Đã thanh toán
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="rescheduleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-main">Dời lịch hẹn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="rescheduleBookingId">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Ngày hẹn mới</label>
                    <input type="date" id="rescheduleDate" class="form-control border-0 bg-light rounded-3 py-2 px-3">
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">Giờ hẹn mới</label>
                    <input type="time" id="rescheduleTime" class="form-control border-0 bg-light rounded-3 py-2 px-3">
                </div>
                <button class="btn btn-action w-100 py-2" onclick="confirmReschedule()">
                    Xác nhận thay đổi
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const checkInModal = new bootstrap.Modal(document.getElementById('checkInModal'));
        const completeModal = new bootstrap.Modal(document.getElementById('completeModal'));
        const rescheduleModal = new bootstrap.Modal(document.getElementById('rescheduleModal'));
        let selectedBookingId = 0;
        let calendar = null;

        // View Toggling
        $('#btn-table-view').click(function() {
            $('.view-toggle-btn').removeClass('active');
            $(this).addClass('active');
            $('#table-view-container').fadeIn();
            $('#timeline-view-container').hide();
        });

        $('#btn-timeline-view').click(function() {
            $('.view-toggle-btn').removeClass('active');
            $(this).addClass('active');
            $('#table-view-container').hide();
            $('#timeline-view-container').fadeIn();
            
            initTimeline();
        });

        function initTimeline() {
            const calendarEl = document.getElementById('calendar-timeline');
            const containerEl = document.getElementById('external-events-list');

            if (calendar) {
                calendar.render();
                return;
            }

            // Initialize External Draggable
            new FullCalendar.Draggable(containerEl, {
                itemSelector: '.fc-event-external',
                eventData: function(eventEl) {
                    return {
                        id: eventEl.getAttribute('data-id'),
                        title: eventEl.getAttribute('data-title'),
                        duration: eventEl.getAttribute('data-duration'),
                        create: true
                    };
                }
            });

            const targetDate = '@(string.IsNullOrEmpty(Context.Request.Query["date"]) ? DateTime.Today.ToString("yyyy-MM-dd") : DateTime.ParseExact(Context.Request.Query["date"], "dd/MM/yyyy", null).ToString("yyyy-MM-dd"))';

            calendar = new FullCalendar.Calendar(calendarEl, {
                schedulerLicenseKey: 'CC-Attribution-NonCommercial-NoDerivatives',
                initialView: 'resourceTimelineDay',
                initialDate: targetDate,
                locale: 'vi',
                slotMinTime: '08:00:00',
                slotMaxTime: '22:00:00',
                resourceOrder: 'id',
                resourceAreaWidth: '25%',
                resourceAreaHeaderContent: 'Dịch vụ & Phòng',
                slotMinWidth: 100,
                height: 'auto',
                contentHeight: 650,
                nowIndicator: true,
                allDaySlot: false,
                editable: true,
                droppable: true,
                eventClassNames: function(arg) {
                    const status = arg.event.extendedProps.status?.toLowerCase() || 'accepted';
                    return ['status-event-' + status];
                },
                buttonText: {
                    today: 'Hôm nay'
                },
                resources: function(info, successCallback, failureCallback) {
                    fetch(`/Admin/Home/GetTimelineData?date=${targetDate}`)
                        .then(r => r.json())
                        .then(data => {
                            renderWaitingList(data.unassigned);
                            successCallback(data.resources);
                        });
                },
                events: function(info, successCallback, failureCallback) {
                    fetch(`/Admin/Home/GetTimelineData?date=${targetDate}`)
                        .then(r => r.json())
                        .then(data => successCallback(data.events));
                },
                eventReceive: function(info) {
                    // Xử lý khi kéo từ Waiting List vào
                    const detailId = info.event.id;
                    const resourceId = info.event.getResources()[0].id;
                    const start = info.event.startStr;
                    const end = info.event.endStr;

                    saveAssignment(detailId, resourceId, start, end);
                },
                eventDrop: function(info) {
                    // Xử lý khi di chuyển lịch đã gán
                    const detailId = info.event.id;
                    const resourceId = info.event.getResources()[0].id;
                    const start = info.event.startStr;
                    const end = info.event.endStr;

                    saveAssignment(detailId, resourceId, start, end);
                },
                eventContent: function(arg) {
                    const props = arg.event.extendedProps;
                    return {
                        html: `
                            <div class="p-1" style="overflow: hidden; white-space: nowrap; text-overflow: ellipsis;">
                                <div class="fw-bold" style="font-size: 0.8rem; color: #fff;">${arg.event.title}</div>
                                <div style="font-size: 0.7rem; color: rgba(255,255,255,0.9);">${props.service || ""}</div>
                                <div style="font-size: 0.65rem; margin-top: 2px; color: rgba(255,255,255,0.8);">KTV: ${props.staff || "Chờ gán"}</div>
                            </div>
                        `
                    };
                },
                eventClick: function(info) {
                    const props = info.event.extendedProps;
                    Swal.fire({
                        title: 'Chi tiết điều phối',
                        html: `
                            <div class="text-start">
                                <p><strong>Khách hàng:</strong> ${props.customer || info.event.title}</p>
                                <p><strong>Dịch vụ:</strong> ${props.service || "Massage"}</p>
                                <p><strong>Nhân viên:</strong> ${props.staff || "Chờ gán"}</p>
                                <p><strong>Trạng thái:</strong> ${props.status || "Accepted"}</p>
                            </div>
                        `,
                        icon: 'info',
                        showCancelButton: true,
                        confirmButtonText: 'Xem lịch chi tiết',
                        cancelButtonText: 'Đóng'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = `/Booking/Details?bookingCode=${props.code}`;
                        }
                    });
                }
            });

            calendar.render();
        }

        function renderWaitingList(unassigned) {
            const listEl = document.getElementById('external-events-list');
            if (!unassigned || unassigned.length === 0) {
                listEl.innerHTML = `
                    <div class="empty-waiting-state">
                        <i class="fa-solid fa-hourglass-empty"></i>
                        <p class="small">Hiện không có khách chờ điều phối</p>
                    </div>
                `;
                return;
            }

            let html = '';
            unassigned.forEach(ev => {
                // Định dạng duration từ số phút (ví dụ 60) thành HH:mm (01:00)
                const hrs = Math.floor(ev.duration / 60);
                const mins = ev.duration % 60;
                const durationFormatted = `${hrs.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}`;

                html += `
                    <div class="fc-event-external" 
                         data-id="${ev.id}" 
                         data-title="${ev.title}" 
                         data-duration="${durationFormatted}">
                        <div class="fw-bold small">${ev.title}</div>
                        <div class="smaller text-muted">${ev.serviceName}</div>
                        <div class="smaller fw-bold text-primary mt-1">${ev.startTime}</div>
                    </div>
                `;
            });
            listEl.innerHTML = html;
        }

        function saveAssignment(detailId, resourceId, start, end) {
            $.post('/Admin/Home/AssignRoomFromTimeline', {
                detailId: detailId,
                resourceId: resourceId,
                start: start,
                end: end
            }, function(res) {
                if (res.success) {
                    Toast.fire({ icon: 'success', title: 'Đã điều phối thành công' });
                    calendar.refetchResources();
                    calendar.refetchEvents();
                } else {
                    Swal.fire('Lỗi', res.message, 'error');
                }
            });
        }

        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true
        });

        function updateStatus(id, action) {
            if(action === 'CheckIn') {
                showCheckInModal(id);
                return;
            }

            if(confirm('Bạn có chắc chắn muốn thực hiện thao tác này?')) {
                fetch('/Admin/Home/' + action, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'bookingId=' + id
                }).then(r => r.json()).then(data => {
                    if(data.success) location.reload();
                    else alert(data.message);
                });
            }
        }

        function showCheckInModal(id, isNextService = false) {
            document.getElementById('checkInBookingId').value = id;
            document.getElementById('isNextServiceMode').value = isNextService.toString();
            
            const modalTitle = document.querySelector('#checkInModal .modal-title');
            if(modalTitle) modalTitle.innerText = isNextService ? "Chuyển dịch vụ tiếp theo" : "Điều phối dịch vụ (Check-in)";

            fetch('/Admin/Home/GetAvailableResources?bookingId=' + id)
                .then(r => r.json())
                .then(data => {
                    if(data.success) {
                        const sSelect = document.getElementById('selectStaff');
                        sSelect.innerHTML = '<option value="">-- Chọn nhân viên --</option>';
                        data.staff.forEach(s => {
                            const disabled = s.isBusy ? 'disabled' : '';
                            const busyStatus = s.isBusy ? ' (Đang bận)' : ' (Rảnh)';
                            const specText = s.specialization ? ` [${s.specialization}]` : '';
                            const genderText = s.gender ? ` - ${s.gender}` : '';
                            sSelect.innerHTML += `<option value="${s.staffId}" ${disabled}>${s.fullName}${genderText}${specText}${busyStatus}</option>`;
                        });
                        checkInModal.show();
                    }
                });
        }

        let currentRawAmount = 0;

        function showCompleteModal(id, amount) {
            selectedBookingId = id;
            currentRawAmount = amount;
            const formattedAmount = amount.toLocaleString('vi-VN') + 'đ';
            document.getElementById('modalAmount').innerText = formattedAmount;
            document.getElementById('cashAmount').innerText = formattedAmount;
            
            // Đặt lại trang thái ban đầu
            if (typeof backToMethods === 'function') backToMethods();
            
            completeModal.show();
        }

        function selectPaymentMethod(method) {
            document.getElementById('stepSelectMethod').style.display = 'none';
            if (method === 'Cash') {
                document.getElementById('stepCash').style.display = 'block';
            } else if (method === 'BankTransfer') {
                document.getElementById('stepBank').style.display = 'block';
                // Tạo link mã VietQR với thông tin cứng theo hình ảnh
                const bankBin = 'vcb';      // Ngân hàng Vietcombank
                const bankAcc = '9783473024'; // Số TK trong hình ảnh
                const accName = 'NGUYEN GIA LONG'; 
                const addInfo = 'Thanh toan dich vu ' + selectedBookingId;
                
                const qrUrl = `https://img.vietqr.io/image/${bankBin}-${bankAcc}-compact2.png?amount=${currentRawAmount}&addInfo=${encodeURIComponent(addInfo)}&accountName=${encodeURIComponent(accName)}`;
                document.getElementById('qrCodeImg').src = qrUrl;
            }
        }

        function backToMethods() {
            const stepSelect = document.getElementById('stepSelectMethod');
            const stepCash = document.getElementById('stepCash');
            const stepBank = document.getElementById('stepBank');
            if(stepSelect) stepSelect.style.display = 'block';
            if(stepCash) stepCash.style.display = 'none';
            if(stepBank) stepBank.style.display = 'none';
        }

        function confirmComplete(method) {
            fetch('/Admin/Home/CompleteBooking', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `bookingId=${selectedBookingId}&method=${method}`
            }).then(r => r.json()).then(data => {
                if(data.success) {
                    alert('Thanh toán thành công!');
                    location.reload();
                }
                else {
                    alert(data.message);
                }
            });
        }

        function confirmCheckIn() {
            const id = document.getElementById('checkInBookingId').value;
            const isNext = document.getElementById('isNextServiceMode').value === 'true';
            const sId = document.getElementById('selectStaff').value;

            if(!sId) {
                alert('Vui lòng chọn nhân viên thực hiện.');
                return;
            }
            const apiUrl = isNext ? '/Admin/Home/NextService' : '/Admin/Home/CheckIn';
            fetch(apiUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `bookingId=${id}&staffId=${sId}`
            }).then(r => r.json()).then(data => {
                if(data.success) location.reload();
                else {
                    Swal.fire('Hết phòng', data.message, 'error');
                }
            });
        }

        function showRescheduleModal(id, date, time) {
            document.getElementById('rescheduleBookingId').value = id;
            document.getElementById('rescheduleDate').value = date;
            document.getElementById('rescheduleTime').value = time;
            rescheduleModal.show();
        }

        function confirmReschedule() {
            const id = document.getElementById('rescheduleBookingId').value;
            const date = document.getElementById('rescheduleDate').value;
            const time = document.getElementById('rescheduleTime').value;

            if(!date || !time) {
                alert('Vui lòng chọn ngày và giờ mới.');
                return;
            }

            fetch('/Admin/Home/RescheduleBooking', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `bookingId=${id}&newDate=${date}&newTime=${time}`
            }).then(r => r.json()).then(data => {
                if(data.success) location.reload();
                else alert(data.message);
            });
        }

        // Live timer cho các dịch vụ đang chạy
        setInterval(() => {
            document.querySelectorAll('.timer-container').forEach(container => {
                const endTimeStr = container.getAttribute('data-end-time');
                const durationMins = parseInt(container.getAttribute('data-duration') || "0");
                if (!endTimeStr) return;
                
                const endTime = new Date(endTimeStr);
                const now = new Date();
                let diffMs = endTime - now;
                const textSpan = container.querySelector('.timer-text');
                const icon = container.querySelector('i');
                
                if (diffMs <= 0) {
                    textSpan.innerText = 'Hoàn thành';
                    container.style.background = '#e6f6ed'; 
                    container.style.borderColor = '#00B050';
                    textSpan.classList.add('text-success');
                    textSpan.classList.remove('text-danger', 'text-white');
                    icon.className = 'fa-solid fa-check-circle text-success me-1';
                } else {
                    // Xử lý trường hợp test: Nếu thời gian còn lại lớn hơn thời lượng dịch vụ (do lệch ngày)
                    const durationMs = durationMins * 60000;
                    if (durationMs > 0 && diffMs > durationMs) {
                        diffMs = durationMs;
                    }

                    const diffHrs = Math.floor(diffMs / 3600000);
                    const diffMins = Math.floor((diffMs % 3600000) / 60000);
                    const diffSecs = Math.floor((diffMs % 60000) / 1000);
                    
                    if (diffHrs > 0) {
                        textSpan.innerText = `Còn ${diffHrs}h ${diffMins}p ${diffSecs}s`;
                    } else {
                        textSpan.innerText = `Còn ${diffMins}p ${diffSecs}s`;
                    }
                }
            });
        }, 1000);
    </script>
}
