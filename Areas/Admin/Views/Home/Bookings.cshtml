@model IEnumerable<SpaN5.Models.Booking>
@{
    ViewData["Title"] = "Quản lý lịch hẹn";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .filter-card {
        background: var(--white);
        border-radius: 24px;
        padding: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid var(--accent-blue);
        margin-bottom: 2rem;
    }
    
    .booking-card {
        background: transparent;
        border: none;
        padding: 0;
        box-shadow: none;
    }

    .booking-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 12px;
        margin-top: -12px;
    }
    .booking-table th {
        padding: 20px 24px;
        color: var(--secondary-blue);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .booking-row {
        background: var(--white);
        border-radius: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .booking-row:hover {
        transform: translateY(-3px) scale(1.005);
        box-shadow: 0 12px 30px rgba(67, 24, 255, 0.08);
        background: #FDFDFF;
    }
    .booking-row td {
        padding: 24px;
        vertical-align: middle;
        border: none;
    }
    .booking-row td:first-child { border-radius: 20px 0 0 20px; }
    .booking-row td:last-child { border-radius: 0 20px 20px 0; }

    /* Custom Status Badges */
    .status-pill {
        padding: 8px 16px;
        border-radius: 14px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .status-confirmed { background: #E9EDF7; color: #4318FF; }
    .status-pending { background: #FFF8E6; color: #FFB800; }
    .status-inprogress { background: #FEEEEE; color: #FF5B5B; }
    .status-completed { background: #E6F6ED; color: #00B050; }
    .status-cancelled { background: #F4F7FE; color: #A3AED0; }

    .customer-avatar {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--primary-blue) 0%, #707EFE 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
        box-shadow: 0 8px 16px rgba(67, 21, 255, 0.15);
    }

    .btn-circle-action {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: var(--admin-bg);
        border: none;
        color: var(--primary-blue);
        transition: all 0.2s;
    }
    .btn-circle-action:hover { background: var(--primary-blue); color: white; }

    .search-input {
        background: var(--admin-bg) !important;
        border: 2px solid transparent !important;
        border-radius: 16px !important;
        padding: 12px 15px 12px 45px !important;
        transition: all 0.2s !important;
    }
    .search-input:focus { border-color: var(--primary-blue) !important; background: white !important; box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; }
</style>

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="fw-bold mb-1" style="letter-spacing: -1px;">Danh sách Lịch hẹn</h2>
        <p class="text-muted small">Quản lý, điều phối và xử lý lịch đặt của khách hàng</p>
    </div>
    <div class="col-auto">
        <div class="btn-group p-1 bg-white rounded-pill shadow-sm">
            <button class="btn btn-sm rounded-pill px-3 fw-bold btn-primary">Bảng biểu</button>
            <button class="btn btn-sm rounded-pill px-3 fw-bold text-muted border-0">Timeline</button>
        </div>
    </div>
</div>

<!-- Advanced Filters -->
<div class="filter-card">
    <form method="get" action="/Admin/Home/Bookings" class="row g-3">
        <div class="col-md-4">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute" style="left: 15px; top: 18px; color: var(--secondary-blue);"></i>
                <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control search-input" placeholder="Tìm tên khách, mã đơn hoặc SĐT...">
            </div>
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select border-0 bg-light rounded-3 py-2 px-3 fw-600">
                <option value="">Tất cả trạng thái</option>
                @foreach (var s in Enum.GetValues(typeof(SpaN5.Models.BookingStatus)))
                {
                    <option value="@s" selected="@(Context.Request.Query["status"] == s.ToString())">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <input type="text" name="date" value="@Context.Request.Query["date"]" class="form-control border-0 bg-light rounded-3 py-2 px-3 fw-600" placeholder="Ngày hẹn (dd/mm/yyyy)">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-action w-100 py-2">Áp dụng lọc</button>
        </div>
    </form>
</div>

<!-- Bookings List -->
<div class="booking-card">
    <div class="table-responsive">
        <table class="booking-table">
            <thead>
                <tr>
                    <th style="width: 200px;">Thông tin đơn</th>
                    <th>Khách hàng</th>
                    <th>Dịch vụ & Kỹ thuật viên</th>
                    <th style="width: 160px;">Trạng thái</th>
                    <th style="width: 140px;">Thanh toán</th>
                    <th class="text-end" style="width: 100px;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if(!Model.Any()) {
                    <tr class="booking-row">
                        <td colspan="6" class="text-center py-5 text-muted">Không tìm thấy dữ liệu lịch hẹn phù hợp</td>
                    </tr>
                }
                @foreach (var bk in Model)
                {
                    <tr class="booking-row">
                        <td>
                            <div class="fw-800 text-primary mb-1">@bk.BookingCode</div>
                            <div class="text-muted smaller d-flex align-items-center gap-2">
                                <span><i class="fa-regular fa-calendar-days text-primary opacity-50"></i> @bk.BookingDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="text-muted smaller mt-1 d-flex align-items-center gap-2">
                                <span><i class="fa-regular fa-clock text-primary opacity-50"></i> @bk.StartTime.ToString("HH:mm")</span>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="customer-avatar me-3">@(bk.Customer?.FullName?[0].ToString().ToUpper() ?? "?")</div>
                                <div>
                                    <div class="fw-800 text-main" style="font-size: 1.05rem;">@bk.Customer?.FullName</div>
                                    <div class="text-muted smaller"><i class="fa-solid fa-phone-volume me-1 text-primary opacity-50"></i> @bk.Customer?.Phone</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-2">
                                @foreach(var detail in bk.BookingDetails) {
                                    <div class="p-2 bg-light rounded-3 border-start border-3 border-primary" style="background: #F8F9FD !important;">
                                        <div class="fw-800 text-main small">@detail.Service?.ServiceName</div>
                                        <div class="text-muted smaller" style="font-size: 0.75rem;">
                                            <i class="fa-solid fa-user-sparkles me-1 text-primary opacity-50"></i> 
                                            KTV: @(detail.Staff?.FullName ?? "Đang chờ điều phối")
                                        </div>
                                    </div>
                                }
                            </div>
                        </td>
                        <td>
                            @{
                                var statusClass = "status-" + bk.Status.ToString().ToLower();
                                var statusIcon = bk.Status switch {
                                    SpaN5.Models.BookingStatus.Pending => "fa-clock-rotate-left",
                                    SpaN5.Models.BookingStatus.Confirmed => "fa-circle-check",
                                    SpaN5.Models.BookingStatus.InProgress => "fa-spinner fa-spin",
                                    SpaN5.Models.BookingStatus.Completed => "fa-check-double",
                                    SpaN5.Models.BookingStatus.Cancelled => "fa-circle-xmark",
                                    _ => "fa-info-circle"
                                };
                                var statusName = bk.Status switch {
                                    SpaN5.Models.BookingStatus.Pending => "Đợi duyệt",
                                    SpaN5.Models.BookingStatus.Confirmed => "Đã xác nhận",
                                    SpaN5.Models.BookingStatus.InProgress => "Đang bận",
                                    SpaN5.Models.BookingStatus.Completed => "Hoàn thành",
                                    SpaN5.Models.BookingStatus.Cancelled => "Đã hủy",
                                    _ => bk.Status.ToString()
                                };
                            }
                            <span class="status-pill @statusClass">
                                <i class="fa-solid @statusIcon"></i>
                                @statusName
                            </span>
                        </td>
                        <td>
                            <div class="fw-900 text-main fs-5">@bk.TotalAmount.ToString("N0")</div>
                            <div class="text-muted smaller fw-700">VND</div>
                        </td>
                        <td class="text-end">
                            <div class="dropdown">
                                <button class="btn-circle-action" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-2 rounded-4">
                                    <li><a class="dropdown-item py-2 px-3 rounded-3 fw-bold" href="/Booking/Details?bookingCode=@bk.BookingCode"><i class="fa-regular fa-eye me-2"></i> Chi tiết</a></li>
                                    @if(bk.Status == SpaN5.Models.BookingStatus.Pending) {
                                        <li><button class="dropdown-item py-2 px-3 rounded-3 text-success fw-bold" onclick="updateStatus(@bk.BookingId, 'ConfirmBooking')"><i class="fa-regular fa-circle-check me-2"></i> Xác nhận</button></li>
                                        <li><button class="dropdown-item py-2 px-3 rounded-3 text-danger fw-bold" onclick="updateStatus(@bk.BookingId, 'RejectBooking')"><i class="fa-regular fa-circle-xmark me-2"></i> Từ chối</button></li>
                                    }
                                    @if(bk.Status == SpaN5.Models.BookingStatus.Confirmed) {
                                        <li><button class="dropdown-item py-2 px-3 rounded-3 text-primary fw-bold" onclick="updateStatus(@bk.BookingId, 'CheckIn')"><i class="fa-solid fa-user-check me-2"></i> Check-in khách</button></li>
                                    }
                                    @if(bk.Status == SpaN5.Models.BookingStatus.InProgress) {
                                        <li><button class="dropdown-item py-2 px-3 rounded-3 text-success fw-bold" onclick="showCompleteModal(@bk.BookingId, @bk.TotalAmount)"><i class="fa-solid fa-file-invoice-dollar me-2"></i> Thanh toán</button></li>
                                    }
                                    @if(bk.Status != SpaN5.Models.BookingStatus.Completed && bk.Status != SpaN5.Models.BookingStatus.Cancelled) {
                                        <li><hr class="dropdown-divider opacity-50"></li>
                                        <li><button class="dropdown-item py-2 px-3 rounded-3 text-danger fw-bold" onclick="updateStatus(@bk.BookingId, 'RejectBooking')"><i class="fa-regular fa-trash-can me-2"></i> Hủy lịch</button></li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Assignment & Payment Modals -->
<div class="modal fade" id="checkInModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-main">Điều phối dịch vụ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="checkInBookingId">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Kỹ thuật viên thực hiện</label>
                    <select id="selectStaff" class="form-select border-0 bg-light rounded-3 py-2 px-3">
                        <option value="">-- Đang tải nhân viên... --</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">Phòng phục vụ</label>
                    <select id="selectRoom" class="form-select border-0 bg-light rounded-3 py-2 px-3">
                        <option value="">-- Đang tải phòng... --</option>
                    </select>
                </div>
                <button class="btn btn-action w-100 py-2" onclick="confirmCheckIn()">
                    Xác nhận Bắt đầu
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="completeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <div class="mb-3 text-muted fw-bold small">TỔNG CỘNG THANH TOÁN</div>
                <div class="h2 fw-800 text-primary mb-4" id="modalAmount">0đ</div>
                
                <div class="row g-2">
                    <div class="col-6">
                        <button class="btn btn-outline-primary w-100 py-3 rounded-4 fw-bold" onclick="confirmComplete('Cash')">
                            <i class="fa-solid fa-money-bill-wave d-block mb-1 fs-4"></i> Tiền mặt
                        </button>
                    </div>
                    <div class="col-6">
                        <button class="btn btn-outline-primary w-100 py-3 rounded-4 fw-bold" onclick="confirmComplete('BankTransfer')">
                            <i class="fa-solid fa-building-columns d-block mb-1 fs-4"></i> Chuyển khoản
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const checkInModal = new bootstrap.Modal(document.getElementById('checkInModal'));
        const completeModal = new bootstrap.Modal(document.getElementById('completeModal'));
        let selectedBookingId = 0;

        function updateStatus(id, action) {
            if(action === 'CheckIn') {
                showCheckInModal(id);
                return;
            }

            if(confirm('Bạn có chắc chắn muốn thực hiện thao tác này?')) {
                fetch('/Admin/Home/' + action, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'bookingId=' + id
                }).then(r => r.json()).then(data => {
                    if(data.success) location.reload();
                    else alert(data.message);
                });
            }
        }

        function showCheckInModal(id) {
            document.getElementById('checkInBookingId').value = id;
            fetch('/Admin/Home/GetAvailableResources?bookingId=' + id)
                .then(r => r.json())
                .then(data => {
                    if(data.success) {
                        const sSelect = document.getElementById('selectStaff');
                        const rSelect = document.getElementById('selectRoom');
                        sSelect.innerHTML = `<option value="">-- Chọn KTV (${data.serviceName}) --</option>`;
                        data.staff.forEach(s => {
                            sSelect.innerHTML += `<option value="${s.staffId}">${s.fullName}</option>`;
                        });
                        rSelect.innerHTML = '<option value="">-- Chọn phòng --</option>';
                        data.rooms.forEach(r => {
                            rSelect.innerHTML += `<option value="${r}">Phòng ${r.toString().padStart(2, '0')}</option>`;
                        });
                        checkInModal.show();
                    }
                });
        }

        function showCompleteModal(id, amount) {
            selectedBookingId = id;
            document.getElementById('modalAmount').innerText = amount.toLocaleString('vi-VN') + 'đ';
            completeModal.show();
        }

        function confirmComplete(method) {
            fetch('/Admin/Home/CompleteBooking', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `bookingId=${selectedBookingId}&method=${method}`
            }).then(r => r.json()).then(data => {
                if(data.success) location.reload();
                else alert(data.message);
            });
        }

        function confirmCheckIn() {
            const id = document.getElementById('checkInBookingId').value;
            const sId = document.getElementById('selectStaff').value;
            const rNum = document.getElementById('selectRoom').value;
            if(!sId || !rNum) {
                alert('Vui lòng chọn đầy đủ nhân viên và phòng.');
                return;
            }
            fetch('/Admin/Home/CheckIn', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `bookingId=${id}&staffId=${sId}&roomNumber=${rNum}`
            }).then(r => r.json()).then(data => {
                if(data.success) location.reload();
                else alert(data.message);
            });
        }
    </script>
}
