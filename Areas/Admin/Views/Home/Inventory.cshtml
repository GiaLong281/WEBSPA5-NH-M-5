@model IEnumerable<SpaN5.Models.Material>
@{
    ViewData["Title"] = "Quản lý Kho nguyên liệu";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var transactions = ViewBag.RecentTransactions as List<SpaN5.Models.StockTransaction> ?? new List<SpaN5.Models.StockTransaction>();
}

<style>
    .inventory-card {
        background: var(--white);
        border-radius: 20px;
        padding: 1.5rem;
        box-shadow: var(--card-shadow);
        border: 1px solid var(--accent-blue);
        height: 100%;
    }
    
    .status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }
    .status-ok { background: #00B050; box-shadow: 0 0 0 4px rgba(0, 176, 80, 0.1); }
    .status-warning { background: #FFB800; box-shadow: 0 0 0 4px rgba(255, 184, 0, 0.1); }
    .status-danger { background: #FF5B5B; box-shadow: 0 0 0 4px rgba(255, 91, 91, 0.1); }

    .stock-badge {
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--text-main);
    }
    
    .transaction-item {
        padding: 12px;
        border-radius: 12px;
        background: var(--admin-bg);
        margin-bottom: 10px;
        border-left: 4px solid var(--primary-blue);
    }
    .transaction-item.export { border-left-color: #FF5B5B; }
    
    .unit-text { font-size: 0.75rem; color: var(--secondary-blue); font-weight: 600; text-transform: uppercase; }
</style>

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="fw-bold mb-1" style="letter-spacing: -1px;">Quản lý Kho Vật Tư</h2>
        <p class="text-muted small">Theo dõi tồn kho, định mức và lịch sử nhập xuất</p>
    </div>
    <div class="col-auto d-flex gap-2">
        <button class="btn btn-light btn-sm rounded-pill px-3 fw-bold border-0 shadow-sm"><i class="fa-solid fa-file-export me-2"></i> Xuất báo cáo</button>
        <button class="btn btn-action"><i class="fa-solid fa-plus me-2"></i> Nhập kho mới</button>
    </div>
</div>

<div class="row g-4 mb-4">
    @foreach(var item in Model) {
        var statusClass = item.CurrentStock <= item.MinStock ? "status-danger" : (item.CurrentStock <= item.MinStock * 1.5 ? "status-warning" : "status-ok");
        <div class="col-md-4">
            <div class="inventory-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div class="fw-bold text-main">@item.MaterialName</div>
                        <div class="unit-text">Đơn vị: @item.Unit</div>
                    </div>
                    <div class="status-indicator @statusClass"></div>
                </div>
                
                <div class="d-flex align-items-end justify-content-between">
                    <div>
                        <div class="small text-muted mb-1">Tồn kho hiện tại</div>
                        <div class="stock-badge">@item.CurrentStock.ToString("N0") <span style="font-size: 0.8rem; font-weight: 600;">@item.Unit</span></div>
                    </div>
                    <div class="text-end">
                        <div class="small text-muted mb-1">Định mức tối thiểu</div>
                        <div class="fw-bold" style="color: var(--secondary-blue);">@item.MinStock.ToString("N0")</div>
                    </div>
                </div>
                
                <div class="progress mt-3" style="height: 6px; border-radius: 10px;">
                    @{
                        var percent = (double)item.CurrentStock / (item.MinStock * 3) * 100;
                        if(percent > 100) percent = 100;
                    }
                    <div class="progress-bar @(item.CurrentStock <= item.MinStock ? "bg-danger" : "bg-success")" style="width: @percent%"></div>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="inventory-card">
            <div class="section-header">
                <h3>Danh sách vật tư chi tiết</h3>
                <div class="header-search" style="width: 250px;">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Tìm kiếm vật tư...">
                </div>
            </div>
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Tên vật tư</th>
                            <th>Đơn vị</th>
                            <th>Giá nhập gần nhất</th>
                            <th>Tồn kho</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model) {
                            <tr>
                                <td class="fw-bold">@item.MaterialName</td>
                                <td class="unit-text">@item.Unit</td>
                                <td>@item.PurchasePrice.ToString("N0")đ</td>
                                <td class="fw-bold">@item.CurrentStock.ToString("N0")</td>
                                <td>
                                    <span class="status-pill @(item.CurrentStock <= item.MinStock ? "danger" : (item.CurrentStock <= item.MinStock * 1.5 ? "warning" : "success"))">
                                        @(item.CurrentStock <= item.MinStock ? "SẮP HẾT" : (item.CurrentStock <= item.MinStock * 1.5 ? "CẦN NHẬP" : "ỔN ĐỊNH"))
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-light btn-sm rounded-pill fw-bold border-0 px-3">Chi tiết</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="inventory-card">
            <div class="section-header">
                <h3>Lịch sử giao dịch</h3>
            </div>
            <div class="transaction-list">
                @if(!transactions.Any()) {
                    <div class="text-center py-5 text-muted">Chưa có giao dịch nào</div>
                }
                @foreach(var t in transactions) {
                    <div class="transaction-item @(t.Type == "Export" ? "export" : "")">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <div class="fw-bold small">@t.Material?.MaterialName</div>
                            <div class="fw-bold @(t.Type == "Export" ? "text-danger" : "text-success")">
                                @(t.Type == "Export" ? "-" : "+")@t.Quantity.ToString("N0")
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="text-muted smaller" style="font-size: 0.7rem;">@t.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</div>
                            <div class="unit-text" style="font-size: 0.6rem;">@t.Material?.Unit</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
