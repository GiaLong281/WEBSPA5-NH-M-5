@{
    ViewData["Title"] = "Cấu hình hệ thống";
    Layout = "_AdminLayout";
}

<style>
    .config-card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid rgba(0,0,0,0.03);
    }
    
    .setting-group {
        padding: 20px 0;
        border-bottom: 1px solid #f1f5f9;
    }
    
    .setting-group:last-child { border-bottom: none; }
    
    .ai-brain-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        color: white;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
    }
</style>

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="fw-bold mb-1" style="letter-spacing: -1px;">Cấu hình & Thiết lập AI</h2>
        <p class="text-muted small">Tùy chỉnh "bộ não" hệ thống và các tham số vận hành</p>
    </div>
    <div class="col-auto">
        <button class="btn btn-action shadow-sm px-4" onclick="saveConfig()">
            <i class="fa-solid fa-floppy-disk me-2"></i> Lưu thiết lập
        </button>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="config-card mb-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="ai-brain-icon">
                    <i class="fa-solid fa-microchip"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-0">Thiết lập Azure Smart Advisor</h5>
                    <p class="text-muted smaller mb-0">Cấu hình các ngưỡng để AI đưa ra lời khuyên chính xác</p>
                </div>
            </div>

            <div class="setting-group">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <h6 class="fw-bold mb-1">Ngưỡng cảnh báo hao hụt vật tư</h6>
                        <p class="text-muted smaller">AI sẽ báo động nếu tỷ lệ hao hụt của nhân viên vượt quá mức này.</p>
                    </div>
                    <div class="col-md-5">
                        <div class="input-group">
                            <input type="number" class="form-control border-0 bg-light rounded-start-3" value="15">
                            <span class="input-group-text border-0 bg-light rounded-end-3 fw-bold">%</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="setting-group">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <h6 class="fw-bold mb-1">Cảnh báo tồn kho tối thiểu (Dự báo)</h6>
                        <p class="text-muted smaller">Báo cho tôi khi số lượng vật tư chỉ đủ dùng trong vòng (ngày):</p>
                    </div>
                    <div class="col-md-5">
                        <div class="input-group">
                            <input type="number" class="form-control border-0 bg-light rounded-start-3" value="3">
                            <span class="input-group-text border-0 bg-light rounded-end-3 fw-bold">Ngày</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="setting-group">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <h6 class="fw-bold mb-1">Phong cách cố vấn AI</h6>
                        <p class="text-muted smaller">Chọn hướng tiếp cận của AI khi đưa ra chiến lược kinh doanh.</p>
                    </div>
                    <div class="col-md-5">
                        <select class="form-select border-0 bg-light rounded-3">
                            <option value="profit">Tối ưu hóa Lợi nhuận (Chốt lời)</option>
                            <option value="cost" selected>Tiết kiệm chi phí (Chặt chẽ)</option>
                            <option value="customer">Trải nghiệm khách hàng (Chăm sóc)</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="config-card">
            <h5 class="fw-bold mb-4"><i class="fa-solid fa-bell me-2 text-primary"></i>Thông báo & Tự động hóa</h5>
            
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="autoPO" checked>
                <label class="form-check-label fw-600" for="autoPO">Tự động soạn đơn nhập hàng (Draft PO) khi vật tư sắp hết</label>
            </div>
            
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="congratulateStaff" checked>
                <label class="form-check-label fw-600" for="congratulateStaff">Tự động gửi thông báo khen thưởng khi nhân viên đạt KPI</label>
            </div>

            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="weeklyReport">
                <label class="form-check-label fw-600" for="weeklyReport">Gửi Email báo cáo tổng hợp BI hàng tuần cho Admin</label>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="config-card h-100" style="background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);">
            <h5 class="fw-bold mb-4"><i class="fa-solid fa-circle-info me-2 text-info"></i>Hướng dẫn</h5>
            <div class="mb-4">
                <p class="small text-muted">Các thiết lập này ảnh hưởng trực tiếp đến cách <b>Azure Smart Advisor</b> tính toán và đưa ra kết luận.</p>
                <p class="small text-muted">Hãy đảm bảo bạn đã cấu hình <b>Gói nguyên liệu (BOM)</b> cho từng dịch vụ trước khi kích hoạt phân tích hao hụt.</p>
            </div>
            <div class="p-3 bg-white rounded-4 shadow-sm">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="fa-solid fa-shield-halved text-success"></i>
                    <span class="small fw-bold">Trạng thái AI: Hoạt động</span>
                </div>
                <div class="progress" style="height: 4px;">
                    <div class="progress-bar bg-success" style="width: 100%"></div>
                </div>
                <div class="mt-2 smaller text-muted text-center italic">Đã đồng bộ với 512 bản ghi mới nhất.</div>
            </div>
        </div>
    </div>
</div>

<script>
    function saveConfig() {
        Swal.fire({
            title: 'Khởi động bộ não AI',
            text: 'Hệ thống đang lưu thiết lập và tái phân tích dữ liệu theo các ngưỡng mới...',
            icon: 'info',
            timer: 2000,
            showConfirmButton: false,
            willClose: () => {
                location.reload();
            }
        });
    }
</script>
