<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Power Admin | Azure Spa Enterprise</title>
    
    <!-- CSS Core -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --admin-bg: #f4f7fe;
            --sidebar-bg: #ffffff;
            --sidebar-width: 280px;
            --sidebar-collapsed-width: 80px;
            --primary-blue: #4318FF;
            --secondary-blue: #707EAE;
            --accent-blue: #E9EDF7;
            --text-main: #1B254B;
            --text-muted: #A3AED0;
            --white: #ffffff;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.3);
            --card-shadow: 0px 18px 40px rgba(112, 144, 176, 0.12);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--admin-bg);
            color: var(--text-main);
            margin: 0;
            overflow-x: hidden;
        }

        #wrapper {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* --- SIDEBAR --- */
        #sidebar-wrapper {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--accent-blue);
            transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        #sidebar-wrapper .sidebar-brand {
            padding: 2.5rem 1.5rem;
            display: flex;
            align-items: center;
            text-decoration: none;
            position: relative;
        }

        .brand-logo {
            width: 40px;
            height: 40px;
            background: var(--primary-blue);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
            margin-right: 12px;
            box-shadow: 0px 10px 20px rgba(67, 24, 255, 0.3);
        }

        .brand-name {
            font-weight: 800;
            font-size: 1.4rem;
            color: var(--text-main);
            letter-spacing: -0.5px;
        }

        .brand-name span { color: var(--primary-blue); font-weight: 400; font-size: 0.8rem; display: block; letter-spacing: 2px; text-transform: uppercase; margin-top: -4px;}

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 0 1rem 2rem 1rem;
            scrollbar-width: thin;
        }

        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: var(--accent-blue); border-radius: 10px; }

        .menu-label {
            color: var(--text-muted);
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 1.5rem 0.5rem 0.75rem 0.5rem;
            opacity: 0.8;
        }

        .nav-item { margin-bottom: 0.4rem; }

        .nav-link {
            display: flex;
            align-items: center;
            padding: 0.8rem 1rem;
            color: var(--secondary-blue);
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        .nav-link i {
            font-size: 1.2rem;
            width: 24px;
            margin-right: 12px;
            text-align: center;
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            color: var(--primary-blue);
            background: var(--accent-blue);
        }

        .nav-link.active {
            background: var(--white);
            color: var(--text-main);
            box-shadow: var(--card-shadow);
            position: relative;
        }

        .nav-link.active::after {
            content: "";
            position: absolute;
            right: 0;
            top: 20%;
            bottom: 20%;
            width: 4px;
            background: var(--primary-blue);
            border-radius: 4px 0 0 4px;
        }

        .nav-link.active i { color: var(--primary-blue); }

        /* --- CONTENT WRAPPER --- */
        #page-content-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        /* --- TOPBAR --- */
        .admin-header {
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: transparent;
            z-index: 999;
        }

        .breadcrumb-section {
            display: flex;
            flex-direction: column;
        }

        .breadcrumb-section .page-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: -0.5px;
            margin: 0;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            background: var(--white);
            padding: 10px 15px;
            border-radius: 30px;
            box-shadow: var(--card-shadow);
            gap: 15px;
        }

        .header-search {
            position: relative;
            width: 200px;
        }

        .header-search input {
            background: var(--admin-bg);
            border: none;
            border-radius: 20px;
            padding: 8px 15px 8px 35px;
            font-size: 0.85rem;
            width: 100%;
        }

        .header-search i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--secondary-blue);
        }

        .icon-btn {
            background: none;
            border: none;
            color: var(--secondary-blue);
            font-size: 1.1rem;
            cursor: pointer;
            position: relative;
            transition: color 0.2s;
        }

        .icon-btn:hover { color: var(--primary-blue); }

        .notification-dot {
            position: absolute;
            top: -4px;
            right: -2px;
            min-width: 18px;
            height: 18px;
            background: #FF5B5B;
            border: 2px solid var(--white);
            border-radius: 10px;
            color: white;
            font-size: 0.65rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            display: none; /* Ẩn mặc định */
        }

        @@keyframes ring-bell {
            0% { transform: rotate(0); }
            10% { transform: rotate(25deg) scale(1.1); }
            20% { transform: rotate(-25deg) scale(1.1); }
            30% { transform: rotate(20deg) scale(1.1); }
            40% { transform: rotate(-20deg) scale(1.1); }
            50% { transform: rotate(15deg) scale(1.1); }
            60% { transform: rotate(-15deg) scale(1.1); }
            70% { transform: rotate(10deg) scale(1.1); }
            80% { transform: rotate(-10deg) scale(1.1); }
            90% { transform: rotate(5deg) scale(1.1); }
            100% { transform: rotate(0) scale(1); }
        }
        .bell-ringing i {
            animation: ring-bell 1s ease-in-out;
            color: #FF5B5B !important;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-left: 10px;
            border-left: 1px solid var(--accent-blue);
        }

        .user-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            object-fit: cover;
            cursor: pointer;
        }

        /* --- MAIN CONTENT --- */
        .main-content {
            padding: 0 2rem 2rem 2rem;
            flex: 1;
        }

        /* Mobile Menu Toggle */
        #menu-toggle {
            display: none;
            background: var(--white);
            border: none;
            color: var(--primary-blue);
            width: 40px;
            height: 40px;
            border-radius: 10px;
            box-shadow: var(--card-shadow);
        }

        @@media (max-width: 992px) {
            #sidebar-wrapper {
                position: fixed;
                margin-left: -100%;
            }
            #wrapper.toggled #sidebar-wrapper {
                margin-left: 0;
            }
            #menu-toggle { display: block; margin-right: 15px; }
            .admin-header { padding: 1rem; }
            .topbar-right { padding: 5px 10px; gap: 8px; }
            .header-search { display: none; }
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <!-- Sidebar -->
        <div id="sidebar-wrapper">
            <a href="/Admin/Home/Index" class="sidebar-brand">
                <div class="brand-logo"><i class="fa-solid fa-gem"></i></div>
                <div class="brand-name">
                    AZURE
                    <span>@(User.IsInRole("Admin") ? "Power Admin" : "Receptionist Portal")</span>
                </div>
            </a>
            
            <div class="sidebar-nav">
                <div class="menu-label">Trung tâm</div>
                <div class="nav-item">
                    <a href="/Admin/Home/Index" class="nav-link @(Context.Request.Path == "/Admin/Home/Index" ? "active" : "")">
                        <i class="fa-solid fa-house"></i> Dashboard
                    </a>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="menu-label">Người dùng</div>
                    <div class="nav-item">
                        <a href="/Admin/Staff" class="nav-link @(Context.Request.Path.ToString().StartsWith("/Admin/Staff") && !Context.Request.Path.ToString().Contains("AttendanceQR") ? "active" : "")">
                            <i class="fa-solid fa-user-shield"></i> Quản lý Nhân sự
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Booking/CustomerList" class="nav-link">
                            <i class="fa-solid fa-users"></i> Khách hàng (Admin)
                        </a>
                    </div>
                }
                else
                {
                    <div class="menu-label">Khách hàng</div>
                    <div class="nav-item">
                        <a href="/Booking/CustomerList" class="nav-link">
                            <i class="fa-solid fa-users"></i> Danh sách khách
                        </a>
                    </div>
                }

                <div class="menu-label">Vận hành</div>
                <div class="nav-item">
                    <a href="/Admin/Staff/AttendanceQR?role=ktv" class="nav-link @(Context.Request.Query["role"] == "ktv" ? "active" : "")">
                        <i class="fa-solid fa-qrcode text-info"></i> Mã QR (KTV)
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Admin/Staff/AttendanceQR?role=letan" class="nav-link @(Context.Request.Query["role"] == "letan" ? "active" : "")">
                        <i class="fa-solid fa-qrcode text-warning"></i> Mã QR (Lễ tân)
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Admin/ManageServices" class="nav-link">
                        <i class="fa-solid fa-spa"></i> Dịch vụ
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Admin/Home/Rooms" class="nav-link @(Context.Request.Path == "/Admin/Home/Rooms" ? "active" : "")">
                        <i class="fa-solid fa-door-open"></i> Sơ đồ Phòng
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Admin/Home/Bookings" class="nav-link @(Context.Request.Path == "/Admin/Home/Bookings" ? "active" : "")">
                        <i class="fa-solid fa-calendar-check"></i> Lịch hẹn (Timeline)
                    </a>
                </div>

                <div class="menu-label">Hậu cần & Tài chính</div>
                <div class="nav-item">
                    <a href="/Admin/Inventory" class="nav-link @(Context.Request.Path.ToString().StartsWith("/Admin/Inventory") ? "active" : "")">
                        <i class="fa-solid fa-boxes-stacked"></i> Kho nguyên liệu
                    </a>
                </div>
                <div class="nav-item">
                    <a href="/Admin/Home/Payments" class="nav-link @(Context.Request.Path == "/Admin/Home/Payments" ? "active" : "")">
                        <i class="fa-solid fa-file-invoice-dollar"></i> Lịch sử Thanh toán
                    </a>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="menu-label">Báo cáo & Hệ thống</div>
                    <div class="nav-item">
                        <a href="/Admin/Branch" class="nav-link @(Context.Request.Path.ToString().StartsWith("/Admin/Branch") ? "active" : "")">
                            <i class="fa-solid fa-code-branch"></i> Hệ thống Chi nhánh
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Admin/Inventory/Reports" class="nav-link @(Context.Request.Path == "/Admin/Inventory/Reports" ? "active" : "")">
                            <i class="fa-solid fa-chart-line"></i> Phân tích
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Admin/Home/Configuration" class="nav-link @(Context.Request.Path == "/Admin/Home/Configuration" ? "active" : "")">
                            <i class="fa-solid fa-gear"></i> Cấu hình
                        </a>
                    </div>
                }
            </div>
        </div>
        <!-- /#sidebar-wrapper -->

        <!-- Page Content -->
        <div id="page-content-wrapper">
            <!-- Topbar -->
            <header class="admin-header">
                <div class="d-flex align-items-center">
                    <button id="menu-toggle"><i class="fa-solid fa-bars"></i></button>
                    <div class="breadcrumb-section">
                        <div class="page-title">@ViewData["Title"]</div>
                    </div>
                </div>

                <div class="topbar-right">
                    <div class="header-search">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" placeholder="Tìm nhanh...">
                    </div>
                    <button class="icon-btn">
                        <i class="fa-regular fa-bell"></i>
                        <span class="notification-dot"></span>
                    </button>
                    <button class="icon-btn">
                        <i class="fa-regular fa-moon"></i>
                    </button>
                    <div class="user-profile dropdown">
                        <img src="https://ui-avatars.com/api/?name=Admin&background=4318FF&color=fff" alt="User" class="user-avatar" data-bs-toggle="dropdown" />
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 rounded-4">
                            <li><a class="dropdown-item py-2 px-3 fw-bold" href="#"><i class="fa-regular fa-user me-2"></i> Hồ sơ</a></li>
                            <li><hr class="dropdown-divider opacity-50"></li>
                            <li><a class="dropdown-item py-2 px-3 text-danger fw-bold" href="/Admin/Auth/Logout"><i class="fa-solid fa-power-off me-2"></i> Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Main Content -->
            <main class="main-content">
                @RenderBody()
            </main>
        </div>
        <!-- /#page-content-wrapper -->
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    
    <script>
        $(document).ready(function() {
            $("#menu-toggle").click(function(e) {
                e.preventDefault();
                $("#wrapper").toggleClass("toggled");
            });

            // Auto-collapse sidebar on mobile
            if($(window).width() < 992) {
                $("#wrapper").removeClass("toggled");
            }

            // --- Validation Số điện thoại 10 số ---
            // Tự động tìm các input có name là Phone
            $(document).on('input', 'input[name$="Phone"]', function() {
                let phone = $(this).val();
                // Loại bỏ các ký tự không phải số
                phone = phone.replace(/\D/g, '');
                $(this).val(phone);

                // Kiểm tra độ dài
                if (phone.length > 0 && phone.length !== 10) {
                    $(this).addClass('is-invalid');
                    if ($(this).next('.phone-warning').length === 0) {
                        $(this).after('<div class="phone-warning text-danger small mt-1">Số điện thoại phải đúng 10 chữ số!</div>');
                    }
                } else {
                    $(this).removeClass('is-invalid');
                    $(this).next('.phone-warning').remove();
                }
            });

            // Giới hạn tối đa 10 ký tự
            $(document).on('keydown', 'input[name$="Phone"]', function(e) {
                if ($(this).val().length >= 10 && e.keyCode !== 8 && e.keyCode !== 46) {
                    // Cho phép xóa (Backbox/Delete) nhưng không cho nhập thêm
                    if (![37, 38, 39, 40].includes(e.keyCode)) { // Cho phép phím mũi tên
                        e.preventDefault();
                    }
                }
            });

            // --- SIGNALR REAL-TIME NOTIFICATIONS ---
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/bookingHub")
                .configureLogging(signalR.LogLevel.Information)
                .build();

            connection.on("ReceiveNewBooking", function (bookingCode, customerName) {
                // Hiển thị thông báo góc phải màn hình
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'info',
                    title: 'Đơn đặt lịch mới!',
                    html: `<b>${customerName}</b> vừa đặt lịch (Mã: <b>${bookingCode}</b>)`,
                    showConfirmButton: false,
                    timer: 5000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                // Chạy âm thanh Ting Ting (Sử dụng Web Audio API tích hợp sẵn)
                try {
                    const ctx = new (window.AudioContext || window.webkitAudioContext)();
                    function playTone(freq, time, duration) {
                        const osc = ctx.createOscillator();
                        const gain = ctx.createGain();
                        osc.connect(gain);
                        gain.connect(ctx.destination);
                        osc.type = 'sine';
                        osc.frequency.value = freq;
                        gain.gain.setValueAtTime(0, time);
                        gain.gain.linearRampToValueAtTime(0.3, time + 0.05);
                        gain.gain.exponentialRampToValueAtTime(0.01, time + duration);
                        osc.start(time);
                        osc.stop(time + duration);
                    }
                    const now = ctx.currentTime;
                    playTone(1046.50, now, 0.5);       // Nốt Đô (C6)
                    playTone(1567.98, now + 0.15, 0.8); // Nốt Sol (G6) - Tạo hiệu ứng Ting Ting êm ái
                } catch(e) { console.log("Audio not supported"); }
                
                // Cập nhật dấu chấm đỏ ở nút chuông và rung
                if (typeof window.unreadNotifications === 'undefined') window.unreadNotifications = 0;
                window.unreadNotifications++;
                $('.notification-dot').text(window.unreadNotifications).css('display', 'flex');
                
                const bellBtn = $('.icon-btn').has('.fa-bell');
                bellBtn.removeClass('bell-ringing');
                void bellBtn[0].offsetWidth; // kích hoạt reflow để reset animation
                bellBtn.addClass('bell-ringing');
            });

            connection.start().then(function () {
                console.log("Đã kết nối SignalR - BookingHub");
            }).catch(function (err) {
                console.error("Lỗi kết nối SignalR: " + err.toString());
            });

            // Xóa thông báo khi click vào chuông
            $('.icon-btn').has('.fa-bell').click(function() {
                window.unreadNotifications = 0;
                $('.notification-dot').css('display', 'none');
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
