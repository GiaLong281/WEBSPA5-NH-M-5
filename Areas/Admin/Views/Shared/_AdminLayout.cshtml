<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ Thống Quản Trị Hệ Thống Spa N5</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --admin-primary: #1e1e2d;
            --admin-secondary: #151521;
            --admin-accent: #009ef7;
            --admin-accent-hover: #008be1;
            --admin-text: #a1a5b7;
            --admin-text-active: #ffffff;
            --admin-bg-light: #f5f8fa;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--admin-bg-light);
            color: #3f4254;
            overflow-x: hidden;
        }

        #wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styling */
        #sidebar-wrapper {
            width: 260px;
            background-color: var(--admin-primary);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        #sidebar-wrapper .sidebar-brand {
            padding: 1.5rem 1rem;
            display: flex;
            align-items: center;
            font-size: 1.25rem;
            font-weight: 700;
            color: #fff;
            background-color: var(--admin-secondary);
            text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        #sidebar-wrapper .sidebar-brand i {
            color: var(--admin-accent);
            font-size: 1.5rem;
            margin-right: 10px;
        }

        .sidebar-menu {
            padding: 1rem 0;
            list-style: none;
            margin: 0;
            flex-grow: 1;
        }

        .sidebar-menu .nav-item {
            margin-bottom: 0.2rem;
            padding: 0 1rem;
        }

        .sidebar-menu .nav-link {
            color: var(--admin-text);
            padding: 0.65rem 1rem;
            border-radius: 0.4rem;
            display: flex;
            align-items: center;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .sidebar-menu .nav-link > i {
            margin-right: 12px;
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
        }

        .sidebar-menu .nav-link:hover, .sidebar-menu .nav-link.active {
            color: var(--admin-text-active);
            background-color: rgba(255,255,255,0.05);
        }

        .sidebar-menu .nav-link.active {
            color: var(--admin-accent);
        }

        .sidebar-menu .menu-title {
            padding: 1.5rem 1rem 0.5rem 1.5rem;
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 600;
            color: #565674;
            letter-spacing: 0.5px;
        }

        /* Header Styling */
        #page-content-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0; /* Important for flex child wrapping */
        }

        .admin-header {
            background-color: #fff;
            padding: 0.5rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 0 20px 0 rgba(76, 87, 125, 0.05);
            height: 70px;
        }

        .btn-toggle-sidebar {
            background: rgba(0, 158, 247, 0.05);
            color: var(--admin-accent);
            border: none;
            padding: 0.5rem;
            border-radius: 0.4rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .btn-toggle-sidebar:hover {
            background: var(--admin-accent);
            color: #fff;
        }

        .user-dropdown .dropdown-toggle {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: #3f4254;
            font-weight: 500;
        }

        .user-dropdown .dropdown-toggle::after {
            display: none;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 0.4rem;
            background-color: #e4e6ef;
            color: #7e8299;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            margin-right: 12px;
        }

        .main-content {
            padding: 1.5rem;
            flex-grow: 1;
        }

        /* Generic Card Styling for Enterprise Look */
        .card {
            border: 0;
            box-shadow: 0 0 20px 0 rgba(76, 87, 125, 0.02);
            border-radius: 0.5rem;
            margin-bottom: 30px;
        }
        
        .card-header {
            background-color: transparent;
            border-bottom: 1px dashed #e4e6ef;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-title {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 600;
            color: #181c32;
        }

        .card-body {
            padding: 1.5rem;
        }

        /* Toggled Sidebar State */
        @@media (min-width: 992px) {
            #wrapper.toggled #sidebar-wrapper {
                margin-left: -260px;
            }
        }

        @@media (max-width: 991.98px) {
            #sidebar-wrapper {
                position: fixed;
                height: 100vh;
                margin-left: -260px;
            }
            #wrapper.toggled #sidebar-wrapper {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <!-- Sidebar -->
        <div id="sidebar-wrapper">
            <a href="/Admin/Home/Index" class="sidebar-brand">
                <i class="bi bi-heptagon-fill"></i>
                <span>SpaN5 ERP</span>
            </a>
            <ul class="sidebar-menu">
                <li class="menu-title">BẢNG ĐIỀU KHIỂN</li>
                <li class="nav-item">
                    <a href="/Admin/Home/Index" class="nav-link active">
                        <i class="bi bi-grid"></i> Tổng quan
                    </a>
                </li>
                <li class="menu-title">NGHIỆP VỤ</li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-calendar-check"></i> Lịch hẹn
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-bag-plus"></i> Đơn hàng & Dịch vụ
                    </a>
                </li>
                <li class="menu-title">QUẢN LÝ TÀI NGUYÊN</li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-people"></i> Nhân viên
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-person-vcard"></i> Khách hàng
                    </a>
                </li>
            </ul>
        </div>
        <!-- /#sidebar-wrapper -->

        <!-- Page Content -->
        <div id="page-content-wrapper">
            <!-- Header -->
            <header class="admin-header">
                <button class="btn-toggle-sidebar" id="menu-toggle">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <div class="user-dropdown dropdown">
                    <a href="#" class="dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="user-avatar">AD</div>
                        <div class="d-none d-md-block">
                            <div style="font-size: 0.85rem; font-weight: 600; line-height: 1;">@User.Identity?.Name</div>
                            <div style="font-size: 0.75rem; color: #a1a5b7; margin-top: 4px;">Người quản trị</div>
                        </div>
                        <i class="bi bi-chevron-down ms-3" style="font-size: 0.8rem; color: #a1a5b7;"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="userDropdown">
                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i>Hồ sơ cá nhân</a></li>
                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i>Cài đặt</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="/Admin/Auth/Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                    </ul>
                </div>
            </header>

            <!-- Main Content -->
            <main class="main-content">
                @RenderBody()
            </main>
        </div>
        <!-- /#page-content-wrapper -->
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById("menu-toggle").addEventListener("click", function (e) {
            e.preventDefault();
            document.getElementById("wrapper").classList.toggle("toggled");
        });

        // Set active state for sidebar items based on current URL
        document.addEventListener("DOMContentLoaded", function () {
            var currentUrl = window.location.pathname;
            var navLinks = document.querySelectorAll('.sidebar-menu .nav-link');
            navLinks.forEach(function (link) {
                if (link.getAttribute("href") === currentUrl) {
                    navLinks.forEach(l => l.classList.remove('active'));
                    link.classList.add('active');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
