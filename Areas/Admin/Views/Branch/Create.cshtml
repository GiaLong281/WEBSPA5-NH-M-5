@model SpaN5.Models.Branch

@{
    ViewData["Title"] = "Thêm Chi nhánh Mới";
    Layout = "_AdminLayout";
}

<style>
    .form-container {
        background: var(--white);
        border-radius: 25px;
        padding: 2.5rem;
        box-shadow: var(--card-shadow);
    }

    .form-label {
        font-weight: 700;
        color: var(--text-main);
        font-size: 0.9rem;
        margin-bottom: 0.6rem;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid var(--accent-blue);
        background: var(--admin-bg);
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .form-control:focus {
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 4px rgba(67, 24, 255, 0.1);
        background: white;
    }

    .image-upload-wrapper {
        border: 2px dashed var(--accent-blue);
        border-radius: 20px;
        padding: 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
        background: var(--admin-bg);
    }

    .image-upload-wrapper:hover {
        border-color: var(--primary-blue);
        background: rgba(67, 24, 255, 0.02);
    }

    #imagePreview {
        max-width: 100%;
        max-height: 250px;
        border-radius: 15px;
        display: none;
        margin-top: 1rem;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .upload-icon {
        font-size: 2.5rem;
        color: var(--secondary-blue);
        margin-bottom: 1rem;
    }

    .btn-submit {
        background: var(--primary-blue);
        color: white;
        border-radius: 15px;
        padding: 12px 40px;
        font-weight: 700;
        border: none;
        box-shadow: 0px 10px 20px rgba(67, 24, 255, 0.2);
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0px 15px 30px rgba(67, 24, 255, 0.3);
    }

    .btn-back {
        color: var(--secondary-blue);
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="container py-4">
    <div class="mb-4">
        <a href="@Url.Action("Index")" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="form-container">
                <div class="d-flex align-items-center gap-3 mb-5">
                    <div style="width: 50px; height: 50px; background: var(--primary-blue); border-radius: 15px; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.2rem;">
                        <i class="fa-solid fa-plus"></i>
                    </div>
                    <div>
                        <h2 class="fw-extrabold mb-0" style="color: var(--text-main);">Thiết lập Chi nhánh</h2>
                        <p class="text-muted mb-0">Điền đầy đủ thông tin để tạo điểm phục vụ mới</p>
                    </div>
                </div>

                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                    <div class="row g-4">
                        <!-- Cột trái: Thông tin cơ bản -->
                        <div class="col-md-7">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label asp-for="BranchName" class="form-label">Tên Chi Nhánh</label>
                                    <input asp-for="BranchName" class="form-control" placeholder="Ví dụ: Azure Spa - Quận 1" />
                                    <span asp-validation-for="BranchName" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="BranchCode" class="form-label">Mã Chi Nhánh</label>
                                    <input asp-for="BranchCode" class="form-control" placeholder="AZ-Q1" />
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Phone" class="form-label">Số Điện Thoại</label>
                                    <input asp-for="Phone" class="form-control" placeholder="09xx xxx xxx" />
                                    <span asp-validation-for="Phone" class="text-danger small"></span>
                                </div>

                                <div class="col-md-12">
                                    <label asp-for="Address" class="form-label">Địa Chỉ</label>
                                    <input asp-for="Address" class="form-control" placeholder="Số nhà, tên đường..." />
                                    <span asp-validation-for="Address" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="District" class="form-label">Quận/Huyện</label>
                                    <input asp-for="District" class="form-control" placeholder="Quận 1" />
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="City" class="form-label">Thành Phố</label>
                                    <input asp-for="City" class="form-control" placeholder="Hồ Chí Minh" />
                                    <span asp-validation-for="City" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="OpeningTime" class="form-label">Giờ Mở Cửa</label>
                                    <input asp-for="OpeningTime" type="time" class="form-control" />
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="ClosingTime" class="form-label">Giờ Đóng Cửa</label>
                                    <input asp-for="ClosingTime" type="time" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <!-- Cột phải: Hình ảnh & Liên kết -->
                        <div class="col-md-5">
                            <div class="mb-4">
                                <label class="form-label">Hình ảnh chi nhánh</label>
                                <div class="image-upload-wrapper" onclick="document.getElementById('imageFile').click()">
                                    <div id="uploadContent">
                                        <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
                                        <p class="mb-1 fw-bold text-main">Tải ảnh lên</p>
                                        <p class="text-muted small">PNG, JPG tối đa 5MB</p>
                                    </div>
                                    <img id="imagePreview" src="#" alt="Preview" />
                                    <input type="file" name="imageFile" id="imageFile" class="d-none" accept="image/*" onchange="previewImage(this)" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="GoogleMapLink" class="form-label">Link Google Maps</label>
                                <input asp-for="GoogleMapLink" class="form-control" placeholder="https://maps.app.goo.gl/..." />
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label">Email Liên Hệ</label>
                                <input asp-for="Email" class="form-control" placeholder="branch@azurespa.vn" />
                            </div>

                            <div class="form-check form-switch mt-4 p-0 ps-5">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" style="width: 40px; height: 20px; cursor: pointer;">
                                <label class="form-check-label fw-bold ms-2" for="IsActive">Kích hoạt ngay</label>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label">Mô tả thêm</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Giới thiệu ngắn về chi nhánh..."></textarea>
                        </div>
                    </div>

                    <div class="mt-5 text-end">
                        <button type="submit" class="btn btn-submit">Lưu Chi Nhánh</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imagePreview').attr('src', e.target.result).fadeIn();
                    $('#uploadContent').hide();
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
