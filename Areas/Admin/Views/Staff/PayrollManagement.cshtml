@using SpaN5.Models
@{
    ViewData["Title"] = "Quản trị Lương & Chấm công";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    
    var month = ViewBag.Month;
    var year = ViewBag.Year;
    var ktvList = ViewBag.KtvList as List<Staff> ?? new List<Staff>();
    var receptionistList = ViewBag.ReceptionistList as List<Staff> ?? new List<Staff>();
    var attendances = ViewBag.Attendances as List<Attendance> ?? new List<Attendance>();
    var allPayments = ViewBag.AllPayments as List<Payment> ?? new List<Payment>();
    var bookingDetails = ViewBag.BookingDetails as List<BookingDetail> ?? new List<BookingDetail>();

    decimal totalPayroll = 0;
}

<style>
    .payroll-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #edf2f7;
        box-shadow: 0 10px 25px rgba(0,0,0,0.02);
        transition: all 0.3s ease;
    }
    .payroll-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.05); }
    
    .status-badge { padding: 5px 12px; border-radius: 100px; font-size: 0.75rem; font-weight: 700; }
    .bg-ktv { background: #E0F2FE; color: #0369A1; }
    .bg-letan { background: #FEF3C7; color: #92400E; }
    
    .table-premium thead th {
        background: #f8fafc;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        border: none;
        padding: 15px;
    }
    .table-premium tbody td { padding: 15px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    
    .nav-pills-premium .nav-link {
        border-radius: 12px;
        font-weight: 600;
        color: #64748b;
        padding: 10px 25px;
        transition: all 0.3s;
    }
    .nav-pills-premium .nav-link.active {
        background: var(--primary-blue);
        color: white;
        box-shadow: 0 8px 15px rgba(67, 24, 255, 0.2);
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-800 text-main mb-1">Quản trị Lương & Chấm công</h2>
            <p class="text-muted">Tổng hợp thu nhập nhân sự tháng @month/@year</p>
        </div>
        
        <form method="get" class="d-flex gap-2 bg-white p-2 rounded-4 shadow-sm">
            <select name="month" class="form-select border-0 bg-light rounded-3" style="width: 120px;">
                @for(int i=1; i<=12; i++) {
                    <option value="@i" selected="@(i == month)">Tháng @i</option>
                }
            </select>
            <select name="year" class="form-select border-0 bg-light rounded-3" style="width: 120px;">
                @for(int i=2024; i<=2026; i++) {
                    <option value="@i" selected="@(i == year)">Năm @i</option>
                }
            </select>
            <button type="submit" class="btn btn-primary rounded-3 px-4">Xem</button>
        </form>
    </div>

    <!-- Tabs Selection -->
    <ul class="nav nav-pills nav-pills-premium mb-4" id="payrollTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="ktv-tab" data-bs-toggle="pill" data-bs-target="#ktv-content" type="button" role="tab">
                <i class="fa-solid fa-user-sparkles me-2"></i>Kỹ thuật viên (@ktvList.Count)
            </button>
        </li>
        <li class="nav-item ms-2" role="presentation">
            <button class="nav-link" id="letan-tab" data-bs-toggle="pill" data-bs-target="#letan-content" type="button" role="tab">
                <i class="fa-solid fa-headset me-2"></i>Lễ tân & Quản lý (@receptionistList.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content" id="payrollTabContent">
        <!-- KTV Tab -->
        <div class="tab-pane fade show active" id="ktv-content" role="tabpanel">
            <div class="payroll-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-premium mb-0">
                        <thead>
                            <tr>
                                <th>Nhân viên</th>
                                <th class="text-center">Ngày công</th>
                                <th class="text-end">Lương cơ bản</th>
                                <th class="text-end">Hoa hồng (10%)</th>
                                <th class="text-end">Tổng nhận</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var staff in ktvList)
                            {
                                var staffAttendances = attendances.Where(a => a.StaffId == staff.StaffId).ToList();
                                var workingDays = staffAttendances.Count;
                                decimal baseSalary = (6000000m / 26m) * workingDays;
                                
                                var staffBookings = bookingDetails.Where(bd => bd.StaffId == staff.StaffId).ToList();
                                decimal commission = staffBookings.Sum(bd => bd.Service.Price * 0.1m);
                                decimal total = baseSalary + commission;

                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-3">
                                                <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(staff.FullName))&background=random" class="rounded-circle" width="40" height="40">
                                            </div>
                                            <div>
                                                <div class="fw-bold text-main">@staff.FullName</div>
                                                <div class="text-muted smaller">@staff.Specialization?.ServiceName</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold text-primary">@workingDays</span> <small class="text-muted">/ 26</small>
                                    </td>
                                    <td class="text-end fw-600">@string.Format("{0:0,0}", baseSalary) đ</td>
                                    <td class="text-end text-success fw-bold">+ @string.Format("{0:0,0}", commission) đ</td>
                                    <td class="text-end fw-800 text-main fs-5">@string.Format("{0:0,0}", total) đ</td>
                                    <td class="text-center">
                                        <a href="/Admin/Staff/Timesheet/@staff.StaffId?month=@month&year=@year" class="btn btn-sm btn-light rounded-pill">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Lễ tân Tab -->
        <div class="tab-pane fade" id="letan-content" role="tabpanel">
            <div class="payroll-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-premium mb-0">
                        <thead>
                            <tr>
                                <th>Nhân viên</th>
                                <th class="text-center">Ngày công</th>
                                <th class="text-end">Lương cơ bản</th>
                                <th class="text-end">Hoa hồng (0.5% DT)</th>
                                <th class="text-end">Tổng nhận</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var staff in receptionistList)
                            {
                                var staffAttendances = attendances.Where(a => a.StaffId == staff.StaffId).ToList();
                                var workingDays = staffAttendances.Count;
                                decimal baseSalary = (6000000m / 26m) * workingDays;
                                
                                // Doanh thu những ngày người này đi làm
                                var workingDates = staffAttendances.Select(a => a.Date.Date).ToList();
                                decimal spaRevenueInDays = allPayments.Where(p => workingDates.Contains(p.CreatedAt.Date)).Sum(p => p.Amount);
                                
                                decimal commission = spaRevenueInDays * 0.005m;
                                decimal total = baseSalary + commission;

                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-3">
                                                <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(staff.FullName))&background=random" class="rounded-circle" width="40" height="40">
                                            </div>
                                            <div>
                                                <div class="fw-bold text-main">@staff.FullName</div>
                                                <div class="text-muted smaller">@staff.Position</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold text-warning">@workingDays</span> <small class="text-muted">/ 26</small>
                                    </td>
                                    <td class="text-end fw-600">@string.Format("{0:0,0}", baseSalary) đ</td>
                                    <td class="text-end text-gold fw-bold">+ @string.Format("{0:0,0}", commission) đ</td>
                                    <td class="text-end fw-800 text-main fs-5">@string.Format("{0:0,0}", total) đ</td>
                                    <td class="text-center">
                                        <a href="/Admin/Staff/Timesheet/@staff.StaffId?month=@month&year=@year" class="btn btn-sm btn-light rounded-pill">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
