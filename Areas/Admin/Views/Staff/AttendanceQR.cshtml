@{
    ViewData["Title"] = "Mã QR Chấm Công Hệ Thống";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .qr-page-container {
        max-width: 1000px;
        margin: 40px auto;
    }
    .qr-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(67, 24, 255, 0.1);
        text-align: center;
        border: 1px solid rgba(67, 24, 255, 0.1);
        height: 100%;
        transition: transform 0.3s;
    }
    .qr-card:hover { transform: translateY(-10px); }
    .qr-image-wrapper {
        background: #f4f7fe;
        padding: 20px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 20px;
        border: 2px solid #4318FF;
    }
    .qr-image-wrapper img { width: 220px; height: 220px; }
    .role-label {
        display: inline-block;
        padding: 5px 20px;
        border-radius: 20px;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        margin-bottom: 15px;
    }
    .label-ktv { background: #E0F2FE; color: #0369A1; }
    .label-letan { background: #FEF3C7; color: #92400E; }
    .progress-container {
        height: 6px;
        background: #e9ecef;
        border-radius: 10px;
        margin-top: 15px;
        overflow: hidden;
    }
    .progress-bar {
        height: 100%;
        background: var(--primary-blue);
        width: 100%;
        transition: width 1s linear;
    }
</style>

<div class="qr-page-container">
    <div class="text-center mb-5">
        <h2 class="fw-800 text-primary">TRUNG TÂM CHẤM CÔNG CÔNG NGHỆ</h2>
        <p class="text-muted">Màn hình hiển thị mã QR động để điểm danh vào/ra ca.</p>
    </div>

    <div class="row justify-content-center">
        @if (ViewBag.Role == "ktv")
        {
            <!-- QR KỸ THUẬT VIÊN -->
            <div class="col-md-6 col-lg-5">
                <div class="qr-card text-center py-5">
                    <span class="role-label label-ktv">Dành cho Kỹ thuật viên</span>
                    <h3 class="fw-700 mb-4">CHẤM CÔNG KTV</h3>
                    <div class="qr-image-wrapper">
                        <img id="ktvQrImg" src="https://via.placeholder.com/300?text=Loading..." alt="KTV QR" />
                    </div>
                    <div class="progress-container mx-4 mb-3">
                        <div class="progress-bar" id="ktvProgress"></div>
                    </div>
                    <p class="small text-muted px-4">Mã bảo mật thay đổi mỗi <span class="fw-bold text-dark">30 giây</span>. Áp dụng cho đội ngũ KTV thực hiện dịch vụ tại phòng.</p>
                </div>
            </div>
        }
        else if (ViewBag.Role == "letan")
        {
            <!-- QR LỄ TÂN -->
            <div class="col-md-6 col-lg-5">
                <div class="qr-card text-center py-5">
                    <span class="role-label label-letan">Dành cho Lễ tân / Admin</span>
                    <h3 class="fw-700 mb-4">CHẤM CÔNG LỄ TÂN</h3>
                    <div class="qr-image-wrapper" style="border-color: #F59E0B;">
                        <img id="letanQrImg" src="https://via.placeholder.com/300?text=Loading..." alt="Letan QR" />
                    </div>
                    <div class="progress-container mx-4 mb-3">
                        <div class="progress-bar" id="letanProgress" style="background: #F59E0B;"></div>
                    </div>
                    <p class="small text-muted px-4">Mã bảo mật thay đổi mỗi <span class="fw-bold text-dark">30 giây</span>. Áp dụng cho nhân viên trực quầy và bộ phận văn phòng.</p>
                </div>
            </div>
        }
    </div>

    <div class="alert alert-info rounded-4 mt-5 d-flex align-items-center gap-3">
        <i class="fa-solid fa-shield-halved fs-3 text-primary"></i>
        <div>
            <strong class="d-block">Lưu ý bảo mật (Dynamic QR):</strong>
            Hệ thống sử dụng công nghệ mã QR động (OTP-style). Mã QR sẽ tự động hết hạn và thay mới sau 30 giây để ngăn chặn hành vi chụp ảnh mã giả mạo điểm danh. Quét lần 1 để Check-in, lần 2 để Check-out.
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const refreshInterval = 30; // 30 giây
            let timeLeft = refreshInterval;

            function loadDynamicQR() {
                $.get('/Admin/Staff/GetDynamicQR', function (res) {
                    if (res.success) {
                        if ($('#ktvQrImg').length > 0) {
                            $('#ktvQrImg').attr('src', res.ktvQrUrl);
                        }
                        if ($('#letanQrImg').length > 0) {
                            $('#letanQrImg').attr('src', res.letanQrUrl);
                        }
                        timeLeft = refreshInterval;
                        updateProgress();
                    }
                });
            }

            function updateProgress() {
                let percentage = (timeLeft / refreshInterval) * 100;
                if ($('#ktvProgress').length > 0) $('#ktvProgress').css('width', percentage + '%');
                if ($('#letanProgress').length > 0) $('#letanProgress').css('width', percentage + '%');
                
                timeLeft--;
                if (timeLeft < 0) {
                    loadDynamicQR();
                }
            }

            // Gọi lần đầu tiên
            loadDynamicQR();

            // Cập nhật thanh tiến trình mỗi giây
            setInterval(updateProgress, 1000);
        });
    </script>
}
