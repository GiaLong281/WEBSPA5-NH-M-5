@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ thống Quản trị - SpaN5 Premium</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #6366f1;
            --accent: #a855f7;
            --text-dark: #1e293b;
            --text-muted: #64748b;
        }

        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Outfit', sans-serif;
            overflow: hidden;
            background: #000;
        }

        .login-container {
            height: 100vh;
            width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        /* Hero Background */
        .bg-image {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://wearegurgaon.com/wp-content/uploads/2023/04/best-spa-in-gurgaon.jpg');
            background-size: cover;
            background-position: center;
            filter: brightness(0.65);
            z-index: 1;
        }

        /* Centered Overlay */
        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.8) 100%);
            z-index: 2;
        }

        /* Premium Centered Login Card */
        .login-panel {
            position: relative;
            z-index: 10;
            width: 90%;
            max-width: 480px;
            padding: 3.5rem;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 2.5rem;
            box-shadow: 0 25px 60px -12px rgba(0, 0, 0, 0.6);
            animation: cardEntrance 1s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@keyframes cardEntrance {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        @@media (max-width: 576px) {
            .login-panel {
                padding: 2rem;
                border-radius: 1.5rem;
            }
        }

        .brand-logo {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .brand-name {
            font-size: 2.5rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: -1.5px;
            margin-bottom: 0;
        }

        .brand-name span {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-left: 8px;
        }

        .welcome-msg {
            color: rgba(255, 255, 255, 0.6);
            font-size: 1rem;
            margin-top: 0.5rem;
            font-weight: 300;
        }

        /* Form Elements */
        .glass-input-group {
            margin-bottom: 1.5rem;
            position: relative;
        }

        .glass-label {
            color: #fff;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 0.6rem;
            display: block;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            opacity: 0.7;
        }

        .glass-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 15px;
            padding: 1rem 1.25rem 1rem 3.5rem;
            color: #fff;
            font-size: 1.05rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .glass-input:focus {
            outline: none;
            background: rgba(255, 255, 255, 0.12);
            border-color: var(--primary);
            box-shadow: 0 0 25px rgba(99, 102, 241, 0.2);
        }

        .input-icon {
            position: absolute;
            left: 1.25rem;
            bottom: 1rem;
            font-size: 1.3rem;
            color: rgba(255, 255, 255, 0.4);
            transition: all 0.3s;
        }

        .glass-input:focus + .input-icon {
            color: var(--primary);
            transform: scale(1.1);
        }

        .btn-premium {
            width: 100%;
            padding: 1.1rem;
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            border: none;
            border-radius: 15px;
            color: #fff !important;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
            margin-top: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-premium:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(99, 102, 241, 0.5);
            filter: brightness(1.1);
        }

        .btn-premium:active {
            transform: scale(0.97);
        }

        .alert-premium {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #fca5a5;
            border-radius: 15px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            font-size: 0.9rem;
        }

        .footer-info {
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.4);
            font-size: 0.8rem;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="bg-image"></div>
        <div class="bg-overlay"></div>
        
        <div class="login-panel">
            <div class="brand-logo">
                <h1 class="brand-name">SpaN5<span>Premium</span></h1>
                <p class="welcome-msg">Hệ thống Quản trị Tập trung</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert-premium shadow-sm">
                    <i class="bi bi-shield-lock-fill me-3 fs-5"></i>
                    <span>@ViewBag.Error</span>
                </div>
            }

            <form asp-action="Login" asp-controller="Auth" method="post" autocomplete="off">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                
                <div class="glass-input-group">
                    <label class="glass-label">Username</label>
                    <input type="text" class="glass-input" id="username" name="username" placeholder="ID nhân viên" required>
                    <i class="bi bi-person-circle input-icon"></i>
                </div>

                <div class="glass-input-group">
                    <label class="glass-label">Password</label>
                    <input type="password" class="glass-input" id="password" name="password" placeholder="••••••••" required>
                    <i class="bi bi-key-fill input-icon"></i>
                </div>

                <button type="submit" class="btn-premium">
                    Bắt đầu làm việc <i class="bi bi-arrow-right-short ms-1"></i>
                </button>
            </form>

            <div class="footer-info">
                <span>&copy; @DateTime.Now.Year Spa N5 Enterprise</span><br>
                <span class="opacity-50 mt-1 d-inline-block">v2.2.0 Platinum &bull; SafeLogin Active</span>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
