## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# VS 2015/2017/2019/2022 cache and settings
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# SQLite databases (User's specific db)
*.db
*.db-shm
*.db-wal

# Local settings
appsettings.Development.json
appsettings.Local.json

# Node.js
node_modules/
npm-debug.log

# Logs
*.log
Log/
[Ll]og/
