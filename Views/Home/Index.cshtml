@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Trang chủ";
}

@section Styles {
    <style>
        .hero-section {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            overflow: hidden;
            background: #12202d;
            margin-top: -140px;
        }
        .hero-video-bg {
            position: absolute; top: 50%; left: 50%;
            width: 100%; height: 100%; min-width: 100%; min-height: 100%;
            transform: translate(-50%, -50%); object-fit: cover;
            z-index: 0; opacity: 0.6;
        }
        .hero-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(90deg, rgba(18,32,45,0.85) 0%, rgba(18,32,45,0.4) 100%);
            z-index: 1;
        }
        .hero-content { position: relative; z-index: 2; color: #fff; }
        .text-gold { color: #b68a63 !important; }
        .btn-gold { 
            background: linear-gradient(135deg, #b68a63 0%, #d9b48f 100%);
            border: none; color: #fff; padding: 0.8rem 2.2rem; border-radius: 999px;
            transition: all 0.3s ease; font-weight: 600;
        }
        .btn-gold:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(182,138,99,0.3); color: #fff; }
        .btn-glass {
            background: rgba(255,255,255,0.1); backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2); color: #fff;
            padding: 0.8rem 2.2rem; border-radius: 999px;
        }
        .section-pad { padding: 7rem 0; }
        .section-label {
            display: inline-block; font-size: 0.8rem; text-transform: uppercase;
            letter-spacing: 2px; color: #b68a63; font-weight: 700; margin-bottom: 1rem;
        }
        .image-stack { position: relative; }
        .image-main { width: 90%; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
        .image-floating { 
            position: absolute; right: 0; bottom: -20px; 
            width: 45%; border: 6px solid #fff; border-radius: 15px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }
        .service-card {
            background: #fff; border-radius: 20px; overflow: hidden;
            transition: all 0.4s ease; border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 5px 15px rgba(0,0,0,0.02); height: 100%;
        }
        .service-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); }
        .card-video-wrapper { position: relative; height: 220px; overflow: hidden; }
        .card-video-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
        .service-card:hover .card-video-wrapper img { transform: scale(1.1); }
        .step-card {
            background: #fdfaf7; padding: 2rem; border-radius: 25px;
            height: 100%; border: 1px solid rgba(182,138,99,0.08);
        }
        .step-number {
            width: 44px; height: 44px; background: #b68a63; color: #fff;
            border-radius: 12px; display: flex; align-items: center;
            justify-content: center; font-weight: 800; margin-bottom: 1.2rem;
        }
        .testimonial-carousel-box {
            background: #fff; padding: 3.5rem; border-radius: 25px;
            box-shadow: 0 15px 45px rgba(0,0,0,0.04);
            border-left: 5px solid #b68a63;
        }
    </style>
}

<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="position-absolute top-0 start-0 w-100 h-100 overflow-hidden" style="z-index: 0;">
        <iframe class="hero-video-bg" 
                src="https://www.youtube.com/embed/VCQrC5IaboA?autoplay=1&mute=1&loop=1&playlist=VCQrC5IaboA&controls=0&modestbranding=1&rel=0" 
                frameborder="0" allow="autoplay; encrypted-media"></iframe>
    </div>
    <div class="container hero-content">
        <div class="row" data-aos="fade-up">
            <div class="col-lg-8">
                <span class="section-label">Premium Spa & Wellness</span>
                <h1 class="display-2 font-playfair fw-bold mb-4">Nuông chiều bản thân,<br><span class="text-gold">Đánh thức vẻ đẹp.</span></h1>
                <p class="fs-5 fw-light mb-5" style="max-width: 600px; opacity: 0.9; line-height: 1.8;">
                    Trải nghiệm không gian thư giãn tuyệt đối và những liệu pháp tái tạo năng lượng hàng đầu. Nơi vẻ đẹp tự nhiên của bạn được tôn vinh một cách tinh tế nhất.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Booking" asp-action="Index" class="btn btn-gold btn-lg shadow">Đặt lịch ngay</a>
                    <a href="#services" class="btn btn-glass btn-lg">Khám phá dịch vụ</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about" class="section-pad">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-right">
                <div class="image-stack">
                    <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=800&q=80" class="image-main" alt="About Spa">
                    <img src="https://images.unsplash.com/photo-1540555700478-4be289fbecef?auto=format&fit=crop&w=600&q=80" class="image-floating" alt="Spa Detail">
                </div>
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <span class="section-label">Câu chuyện thương hiệu</span>
                <h2 class="font-playfair display-4 fw-bold mb-4 text-dark">Nơi Cân Bằng Thân & Tâm</h2>
                <p class="text-muted fs-5 mb-4" style="line-height: 1.7;">
                    Tại SpaN5, chúng tôi tin rằng vẻ đẹp bền vững bắt nguồn từ sự thư thái bên trong. Mỗi liệu trình là sự kết hợp tinh hoa giữa y học cổ truyền và công nghệ hiện đại.
                </p>
                <div class="row g-4 mb-5">
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <i class="fas fa-check-circle text-gold fs-5"></i>
                            <span class="fw-semibold">100% Organic</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <i class="fas fa-check-circle text-gold fs-5"></i>
                            <span class="fw-semibold">Expert Staff</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <i class="fas fa-check-circle text-gold fs-5"></i>
                            <span class="fw-semibold">Private Rooms</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <i class="fas fa-check-circle text-gold fs-5"></i>
                            <span class="fw-semibold">Modern Tech</span>
                        </div>
                    </div>
                </div>
                <a asp-controller="Home" asp-action="About" class="btn btn-outline-dark rounded-pill px-5 py-3 fw-bold">Xem thêm về chúng tôi</a>
            </div>
        </div>
    </div>
</section>

<section id="services" class="section-pad bg-light">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="section-label">Dịch vụ nổi bật</span>
            <h2 class="font-playfair display-4 fw-bold">Liệu Trình Tái Tạo Năng Lượng</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="service-card">
                    <div class="card-video-wrapper">
                        <img src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&w=600&q=80" alt="Massage">
                        <span class="badge bg-gold position-absolute top-0 end-0 m-3 rounded-pill px-3 py-2 shadow-sm">Hot</span>
                    </div>
                    <div class="p-4 text-center">
                        <h4 class="font-playfair fw-bold mb-3">Massage Thư Giãn</h4>
                        <p class="text-muted mb-4 small">Giải tỏa căng thẳng với kỹ thuật massage chuyên nghiệp kết hợp đá nóng.</p>
                        <a href="/Services/Details/1" class="text-gold fw-bold text-decoration-none border-bottom border-gold pb-1 small">CHI TIẾT</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="service-card">
                    <div class="card-video-wrapper">
                        <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?auto=format&fit=crop&w=600&q=80" alt="Facial">
                    </div>
                    <div class="p-4 text-center">
                        <h4 class="font-playfair fw-bold mb-3">Chăm Sóc Da Mặt</h4>
                        <p class="text-muted mb-4 small">Thanh lọc làn da với tinh chất thảo mộc và serum hữu cơ cao cấp.</p>
                        <a href="/Services/Details/2" class="text-gold fw-bold text-decoration-none border-bottom border-gold pb-1 small">CHI TIẾT</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="service-card border-gold" style="border: 1px solid #b68a63;">
                    <div class="card-video-wrapper">
                        <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=600&q=80" alt="VIP">
                        <span class="badge bg-gold position-absolute top-0 end-0 m-3 rounded-pill px-3 py-2 shadow-sm"><i class="fas fa-crown me-1"></i> VIP</span>
                    </div>
                    <div class="p-4 text-center">
                        <h4 class="font-playfair fw-bold mb-3">VIP Trẻ Hóa Hoàng Gia</h4>
                        <p class="text-muted mb-4 small">Liệu trình đỉnh cao với tinh chất vàng 24K giúp trẻ hóa toàn diện.</p>
                        <a href="/Services/Details/6" class="text-gold fw-bold text-decoration-none border-bottom border-gold pb-1 small">CHI TIẾT</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <a asp-controller="Services" asp-action="Index" class="btn btn-outline-dark rounded-pill px-5 py-3 fw-bold">Xem tất cả dịch vụ</a>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="section-label">Quy trình chuyên nghiệp</span>
            <h2 class="font-playfair display-4 fw-bold">3 Bước Đến Với Sự Thư Giãn</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4" data-aos="zoom-in" data-aos-delay="100">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h5 class="fw-bold mb-3">Đặt lịch trực tuyến</h5>
                    <p class="text-muted mb-0 small">Dễ dàng lựa chọn dịch vụ, chi nhánh và khung giờ chỉ trong vài giây.</p>
                </div>
            </div>
            <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h5 class="fw-bold mb-3">Nhận xác nhận ngay</h5>
                    <p class="text-muted mb-0 small">Hệ thống gửi thông báo xác nhận và nhắc lịch tự động qua điện thoại.</p>
                </div>
            </div>
            <div class="col-md-4" data-aos="zoom-in" data-aos-delay="300">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h5 class="fw-bold mb-3">Tận hưởng dịch vụ</h5>
                    <p class="text-muted mb-0 small">Đến chi nhánh, thư giãn và đắm mình trong không gian Luxury.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-pad bg-light overflow-hidden">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-5 mb-5 mb-lg-0" data-aos="fade-right">
                <span class="section-label">Lời khen tặng</span>
                <h2 class="font-playfair display-4 fw-bold mb-4">Khách Hàng Nói Gì Về Chúng Tôi?</h2>
                <p class="text-muted fs-5 mb-5">
                    Hơn 5000+ lượt trải nghiệm hài lòng mỗi năm là minh chứng rõ nhất cho nỗ lực của đội ngũ SpaN5.
                </p>
                <div class="d-flex gap-3">
                    <button class="btn btn-outline-dark rounded-circle" data-bs-target="#testiCarousel" data-bs-slide="prev" style="width: 50px; height: 50px;"><i class="fas fa-arrow-left"></i></button>
                    <button class="btn btn-gold rounded-circle" data-bs-target="#testiCarousel" data-bs-slide="next" style="width: 50px; height: 50px;"><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
            <div class="col-lg-7" data-aos="fade-left">
                <div id="testiCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <div class="testimonial-carousel-box">
                                <div class="mb-3 text-gold"><i class="fas fa-star" v-for="i in 5"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                                <h4 class="font-playfair fw-bold mb-3">"Không gian tuyệt vời"</h4>
                                <p class="fs-5 fst-italic text-muted mb-4 opacity-75">"Mọi thứ vượt quá mong đợi. Từ mùi hương đến kỹ thuật của nhân viên đều rất tinh tế."</p>
                                <div class="d-flex align-items-center gap-3 pt-4 border-top">
                                    <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=100&q=80" class="rounded-circle" width="60" height="60" style="object-fit:cover;">
                                    <div><h6 class="mb-0 fw-bold">Minh Anh</h6><small class="text-gold">Designer</small></div>
                                </div>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <div class="testimonial-carousel-box">
                                <div class="mb-3 text-gold"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                                <h4 class="font-playfair fw-bold mb-3">"Đẳng cấp Premium"</h4>
                                <p class="fs-5 fst-italic text-muted mb-4 opacity-75">"Liệu trình VIP thực sự đáng giá. Tôi cảm thấy cơ thể được hồi sinh hoàn toàn."</p>
                                <div class="d-flex align-items-center gap-3 pt-4 border-top">
                                    <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=100&q=80" class="rounded-circle" width="60" height="60" style="object-fit:cover;">
                                    <div><h6 class="mb-0 fw-bold">Hoàng Nam</h6><small class="text-gold">Entrepreneur</small></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-pad" style="background: linear-gradient(135deg, #12202d 0%, #1e2a38 100%);">
    <div class="container text-center text-white py-4" data-aos="zoom-in">
        <h2 class="font-playfair display-3 fw-bold mb-4">Sẵn Sàng Để Thư Giãn?</h2>
        <p class="fs-5 mb-5 opacity-75 mx-auto" style="max-width: 700px;">
            Đặt lịch ngay hôm nay để nhận ưu đãi khởi đầu hành trình chăm sóc bản thân chuyên nghiệp nhất.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Booking" asp-action="Index" class="btn btn-gold btn-lg px-5">ĐẶT LỊCH NGAY</a>
            <a asp-controller="Home" asp-action="Contact" class="btn btn-glass btn-lg px-5">LIÊN HỆ</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof AOS !== 'undefined') { AOS.init({ duration: 1000, once: true }); }
        });
    </script>
}
