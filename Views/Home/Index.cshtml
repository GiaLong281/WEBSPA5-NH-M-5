@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<!-- Hero Section -->
<section class="hero-section position-relative vh-100 d-flex align-items-center" style="background: url('https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center/cover no-repeat; margin-top: -76px;">
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background-color: rgba(26, 43, 60, 0.4);"></div>
    <div class="container position-relative z-index-1 text-center text-white">
        <h1 class="display-3 font-playfair mb-4 animate-fade-up fw-bold">@Html.Raw(Localizer["MainHeading"].ToString().Replace("\n", "<br>"))</h1>
        <p class="lead mb-5 fw-light mx-auto" style="max-width: 600px; animation-delay: 0.2s;">@Localizer["MainDescription"]</p>
        <a href="#booking" class="btn btn-gold btn-lg rounded-pill px-5 py-3 text-uppercase fw-bold letter-spacing-1" style="animation-delay: 0.4s;">@Localizer["BookNow"]</a>
    </div>
</section>

<!-- About Section -->
<section id="about" class="py-5 my-5 section-fade">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1600334129128-68505d1815b8?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Spa interior" class="img-fluid rounded-3 shadow-lg" style="object-fit: cover; height: 500px; width: 100%;" loading="lazy">
                    <div class="position-absolute bottom-0 end-0 bg-white p-4 shadow-lg rounded-top-start-3 m-0" style="right: -20px !important; bottom: -20px !important;">
                        <h3 class="font-playfair text-gold mb-0">@Localizer["YearsExperience"]</h3>
                        <p class="mb-0 text-muted">@Localizer["ExperienceLabel"]</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <span class="text-gold fw-bold text-uppercase letter-spacing-2">@Localizer["AboutUsTitle"]</span>
                <h2 class="font-playfair display-5 my-3 text-dark">@Html.Raw(Localizer["BalanceSubtitle"].ToString().Replace("\n", "<br>"))</h2>
                <p class="text-muted mb-4" style="line-height: 1.8;">@Localizer["AboutDescription"]</p>
                <ul class="list-unstyled mb-4">
                    <li class="mb-3"><i class="fas fa-check-circle text-gold me-2"></i> @Localizer["ProfessionalTherapists"]</li>
                    <li class="mb-3"><i class="fas fa-check-circle text-gold me-2"></i> @Localizer["OrganicProducts"]</li>
                    <li class="mb-3"><i class="fas fa-check-circle text-gold me-2"></i> @Localizer["PrivateSpace"]</li>
                </ul>
                <a href="#services" class="btn btn-outline-gold rounded-pill px-4 py-2">@Localizer["ExploreServices"]</a>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="py-5 bg-white section-fade">
    <div class="container py-4">
        <div class="text-center mb-5">
            <span class="text-gold fw-bold text-uppercase letter-spacing-2">@Localizer["FeaturedServices"]</span>
            <h2 class="font-playfair display-5 mt-2 mb-3">@Localizer["RejuvenationTherapies"]</h2>
            <div class="mx-auto bg-gold" style="height: 2px; width: 60px;"></div>
        </div>
        
        <div class="row g-4">
            <!-- Service 1 -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm service-card transition-all">
                    <div class="card-img-top overflow-hidden" style="height: 250px;">
                        <img src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-100 h-100 transition-all" alt="Massage" style="object-fit: cover;" loading="lazy">
                    </div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-hands text-gold fs-1 mb-3"></i>
                        <h4 class="font-playfair mb-3">@Localizer["MassageTitle"]</h4>
                        <p class="text-muted mb-4">@Localizer["MassageDesc"]</p>
                        <a href="#" class="text-dark fw-bold text-decoration-none border-bottom border-dark pb-1 text-uppercase text-sm">@Localizer["ViewDetails"]</a>
                    </div>
                </div>
            </div>
            <!-- Service 2 -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm service-card transition-all">
                    <div class="card-img-top overflow-hidden" style="height: 250px;">
                        <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-100 h-100 transition-all" alt="Facial" style="object-fit: cover;" loading="lazy">
                    </div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-spa text-gold fs-1 mb-3"></i>
                        <h4 class="font-playfair mb-3">@Localizer["FacialTitle"]</h4>
                        <p class="text-muted mb-4">@Localizer["FacialDesc"]</p>
                        <a href="#" class="text-dark fw-bold text-decoration-none border-bottom border-dark pb-1 text-uppercase text-sm">@Localizer["ViewDetails"]</a>
                    </div>
                </div>
            </div>
            <!-- Service 3 -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm service-card transition-all">
                    <div class="card-img-top overflow-hidden" style="height: 250px;">
                        <img src="https://images.unsplash.com/photo-1519823551278-64ac92734fb1?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-100 h-100 transition-all" alt="Body Treatment" style="object-fit: cover;" loading="lazy">
                    </div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-leaf text-gold fs-1 mb-3"></i>
                        <h4 class="font-playfair mb-3">@Localizer["HerbalBathTitle"]</h4>
                        <p class="text-muted mb-4">@Localizer["HerbalBathDesc"]</p>
                        <a href="#" class="text-dark fw-bold text-decoration-none border-bottom border-dark pb-1 text-uppercase text-sm">@Localizer["ViewDetails"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials -->
<section id="testimonials" class="py-5 section-fade" style="background-color: var(--beige);">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-md-5 mb-4 mb-md-0">
                <h2 class="font-playfair display-5 mb-4">@Localizer["CustomerTestimonials"]</h2>
                <p class="text-muted mb-4">@Localizer["TestimonialIntro"]</p>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-dark rounded-circle" style="width: 45px; height: 45px;"><i class="fas fa-arrow-left"></i></button>
                    <button class="btn btn-dark rounded-circle bg-navy border-0" style="width: 45px; height: 45px;"><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
            <div class="col-md-7">
                <div class="bg-white p-5 rounded-3 shadow-sm position-relative">
                    <i class="fas fa-quote-left fs-1 text-gold opacity-25 position-absolute top-0 start-0 ms-4 mt-4"></i>
                    <p class="fs-5 fst-italic mb-4 text-dark position-relative z-index-1" style="line-height: 1.8;">"@Localizer["TestimonialContent"]"</p>
                    <div class="d-flex align-items-center">
                        <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80" alt="Customer" class="rounded-circle me-3" style="width: 60px; height: 60px; object-fit: cover;" loading="lazy">
                        <div>
                            <h6 class="mb-0 fw-bold">@Localizer["TestimonialAuthor"]</h6>
                            <small class="text-muted">@Localizer["TestimonialRole"]</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Additional CSS for this page -->
<style>
    .letter-spacing-1 { letter-spacing: 1px; }
    .letter-spacing-2 { letter-spacing: 2px; }
    .bg-navy { background-color: var(--navy) !important; }
    .bg-gold { background-color: var(--gold) !important; }
    .text-sm { font-size: 0.875rem; }
    
    .service-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .service-card:hover img {
        transform: scale(1.05);
    }
</style>