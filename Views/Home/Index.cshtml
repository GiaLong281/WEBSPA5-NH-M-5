@{
    ViewData["Title"] = "Trang Chủ";
}

<!-- Hero Section -->
<section class="hero-section position-relative vh-100 d-flex align-items-center" style="background: url('https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center/cover no-repeat; margin-top: -76px;">
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background-color: rgba(26, 43, 60, 0.4);"></div>
    <div class="container position-relative z-index-1 text-center text-white">
        <h1 class="display-3 font-playfair mb-4 animate-fade-up fw-bold">Nuông Chiều Bản Thân<br>Đánh Thức Vẻ Đẹp</h1>
        <p class="lead mb-5 fw-light mx-auto" style="max-width: 600px; animation-delay: 0.2s;">Trải nghiệm không gian thư giãn tuyệt đối và những liệu pháp tái tạo năng lượng hàng đầu tại SpaN5.</p>
        <a href="/Booking" class="btn btn-gold btn-lg rounded-pill px-5 py-3 text-uppercase fw-bold letter-spacing-1" style="animation-delay: 0.4s;">Đặt Lịch Ngay</a>
    </div>
</section>


<!-- About Section -->
<section id="about" class="py-5 my-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1600334129128-68505d1815b8?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Spa interior" class="img-fluid rounded-3 shadow-lg" style="object-fit: cover; height: 500px; width: 100%;">
                    <div class="position-absolute bottom-0 end-0 bg-white p-4 shadow-lg rounded-top-start-3 m-0" style="right: -20px !important; bottom: -20px !important;">
                        <h3 class="font-playfair text-gold mb-0">10+ Năm</h3>
                        <p class="mb-0 text-muted">Kinh nghiệm chăm sóc</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <span class="text-gold fw-bold text-uppercase letter-spacing-2">Về SpaN5</span>
                <h2 class="font-playfair display-5 my-3 text-dark">Nơi Cân Bằng<br>Thân & Tâm.</h2>
                <p class="text-muted mb-4" style="line-height: 1.8;">Chúng tôi tin rằng sự thư giãn thực sự đến từ sự hòa hợp giữa cơ thể khỏe mạnh và tinh thần an yên. Với không gian thiên nhiên tĩnh lặng và các liệu pháp y học cổ truyền kết hợp hiện đại, SpaN5 mong muốn mang đến cho bạn những trải nghiệm đáng nhớ nhất.</p>
                <ul class="list-unstyled mb-4">
                    <li class="mb-3"><i class="fas fa-check-circle text-gold me-2"></i> Kỹ thuật viên chuyên nghiệp, tận tâm</li>
                    <li class="mb-3"><i class="fas fa-check-circle text-gold me-2"></i> Sản phẩm hữu cơ organic 100%</li>
                    <li class="mb-3"><i class="fas fa-check-circle text-gold me-2"></i> Không gian tĩnh lặng, riêng tư</li>
                </ul>
                <a href="#services" class="btn btn-outline-gold rounded-pill px-4 py-2">Khám phá dịch vụ</a>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="py-5 bg-white">
    <div class="container py-4">
        <div class="text-center mb-5">
            <span class="text-gold fw-bold text-uppercase letter-spacing-2">Dịch Vụ Nổi Bật</span>
            <h2 class="font-playfair display-5 mt-2 mb-3">Những Liệu Trình Tái Tạo</h2>
            <div class="mx-auto bg-gold" style="height: 2px; width: 60px;"></div>
        </div>
        
        <div class="row g-4">
            <!-- Service 1 -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm service-card transition-all">
                    <div class="card-img-top overflow-hidden" style="height: 250px;">
                        <img src="https://images.unsplash.com/photo-1515377905703-c4788e51af15?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-100 h-100 transition-all" alt="Massage" style="object-fit: cover;">
                    </div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-hands text-gold fs-1 mb-3"></i>
                        <h4 class="font-playfair mb-3">Massage Thư Giãn</h4>
                        <p class="text-muted mb-4">Xua tan căng thẳng cơ bắp bằng liệu pháp massage Thụy Điển kết hợp đá nóng thiên nhiên.</p>
                        <a href="/Home/Details/1" class="text-dark fw-bold text-decoration-none border-bottom border-dark pb-1 text-uppercase text-sm">Xem chi tiết</a>
                    </div>
                </div>
            </div>
            <!-- Service 2 -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm service-card transition-all">
                    <div class="card-img-top overflow-hidden" style="height: 250px;">
                        <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-100 h-100 transition-all" alt="Facial" style="object-fit: cover;">
                    </div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-spa text-gold fs-1 mb-3"></i>
                        <h4 class="font-playfair mb-3">Chăm Sóc Da Mặt</h4>
                        <p class="text-muted mb-4">Thanh lọc và trẻ hóa làn da với tinh chất hoa cúc và serum hữu cơ nhập khẩu từ Pháp.</p>
                        <a href="/Home/Details/2" class="text-dark fw-bold text-decoration-none border-bottom border-dark pb-1 text-uppercase text-sm">Xem chi tiết</a>
                    </div>
                </div>
            </div>
            <!-- Service 3 -->
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm service-card transition-all">
                    <div class="card-img-top overflow-hidden" style="height: 250px;">
                        <img src="https://images.unsplash.com/photo-1519823551278-64ac92734fb1?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="w-100 h-100 transition-all" alt="Body Treatment" style="object-fit: cover;">
                    </div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-leaf text-gold fs-1 mb-3"></i>
                        <h4 class="font-playfair mb-3">Tắm Thảo Dược</h4>
                        <p class="text-muted mb-4">Đào thải độc tố, kích thích tuần hoàn máu qua liệu trình ngâm mình với 15 loại thảo mộc quý.</p>
                        <a href="/Home/Details/3" class="text-dark fw-bold text-decoration-none border-bottom border-dark pb-1 text-uppercase text-sm">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials -->
<section id="testimonials" class="py-5" style="background-color: var(--beige);">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-md-5 mb-4 mb-md-0">
                <h2 class="font-playfair display-5 mb-4">Khách Hàng<br>Nói Gì Về Chúng Tôi?</h2>
                <p class="text-muted mb-4">Hơn 5000+ khách hàng đã trải nghiệm và hài lòng với dịch vụ tại SpaN5. Sự tin tưởng của quý khách là động lực to lớn nhất.</p>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-dark rounded-circle" style="width: 45px; height: 45px;"><i class="fas fa-arrow-left"></i></button>
                    <button class="btn btn-dark rounded-circle bg-navy border-0" style="width: 45px; height: 45px;"><i class="fas fa-arrow-right"></i></button>
                </div>
            </div>
            <div class="col-md-7">
                <div class="bg-white p-5 rounded-3 shadow-sm position-relative">
                    <i class="fas fa-quote-left fs-1 text-gold opacity-25 position-absolute top-0 start-0 ms-4 mt-4"></i>
                    <p class="fs-5 fst-italic mb-4 text-dark position-relative z-index-1" style="line-height: 1.8;">"Sau một tuần làm việc căng thẳng, đến SpaN5 giống như bước vào một thế giới khác. Không gian tuyệt vời, mùi hương tinh dầu dịu nhẹ và kỹ thuật massage thì điêu luyện. Chắc chắn tôi sẽ quay lại thường xuyên."</p>
                    <div class="d-flex align-items-center">
                        <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80" alt="Customer" class="rounded-circle me-3" style="width: 60px; height: 60px; object-fit: cover;">
                        <div>
                            <h6 class="mb-0 fw-bold">Nguyễn Phương My</h6>
                            <small class="text-muted">Doanh nhân</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Additional CSS for this page -->
<style>
    .letter-spacing-1 { letter-spacing: 1px; }
    .letter-spacing-2 { letter-spacing: 2px; }
    .bg-navy { background-color: var(--navy) !important; }
    .bg-gold { background-color: var(--gold) !important; }
    .text-sm { font-size: 0.875rem; }
    
    .service-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .service-card:hover img {
        transform: scale(1.05);
    }
</style>
