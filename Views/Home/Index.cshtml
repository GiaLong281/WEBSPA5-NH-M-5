        <iframe src="https://www.youtube.com/embed/VCQrC5IaboA?autoplay=1&mute=1&loop=1&playlist=VCQrC5IaboA&controls=0&showinfo=0&rel=0" 
                frameborder="0" 
                allow="autoplay; encrypted-media" 
                style="width: 100vw; height: 56.25vw; min-height: 100vh; min-width: 177.77vh; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
        </iframe>
    </div>

    <!-- Sophisticated Overlay for Readability -->
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(90deg, rgba(26, 43, 60, 0.8) 0%, rgba(26, 43, 60, 0.5) 50%, rgba(26,43,60,0.2) 100%); z-index: 1;"></div>
    
    <div class="container position-relative" style="z-index: 2;">
        <div class="row">
            <div class="col-lg-7 text-white text-start">
                <span class="text-gold fw-bold text-uppercase letter-spacing-2 mb-3 d-inline-block" data-aos="fade-right" data-aos-delay="200">Chào mừng bạn đến với SpaN5</span>
