@model SpaN5.Models.Service

@{
    ViewData["Title"] = Model.ServiceName;
}

<section class="py-5 overflow-hidden" style="background-color: var(--beige); min-height: 100vh; padding-top: 100px !important;">
    <div class="container py-5">
        <a href="/" class="text-decoration-none text-muted mb-4 d-inline-block" data-aos="fade-right">
            <i class="fas fa-arrow-left me-2"></i> Quay lại trang chủ
        </a>

        <div class="row bg-white rounded-4 shadow-lg overflow-hidden border-0">
            <!-- Hình ảnh dịch vụ -->
            <div class="col-lg-6 p-0" data-aos="fade-right" data-aos-duration="1200">
                @{
                    var imageUrl = string.IsNullOrEmpty(Model.Image) 
                        ? "https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
                        : Model.Image;
                }
                <div class="h-100 position-relative">
                    <img src="@imageUrl" alt="@Model.ServiceName" class="w-100 h-100" style="object-fit: cover; min-height: 500px;">
                    <div class="position-absolute top-0 start-0 w-100 h-100 shadow-inset" style="background: linear-gradient(to bottom, rgba(0,0,0,0.1), transparent);"></div>
                </div>
            </div>

            <!-- Thông tin chi tiết -->
            <div class="col-lg-6 p-5 d-flex flex-column justify-content-center" data-aos="fade-left" data-aos-duration="1200">
                <span class="text-gold fw-bold text-uppercase letter-spacing-2 mb-2">Thông tin dịch vụ</span>
                <h1 class="font-playfair display-4 mb-3 fw-bold">@Model.ServiceName</h1>
                
                <div class="d-flex gap-4 mb-4 text-muted border-bottom pb-4">
                    <span class="fs-5"><i class="far fa-clock text-gold me-2"></i> @Model.Duration phút</span>
                    <span class="fs-5"><i class="fas fa-money-bill-wave text-gold me-2"></i> @Model.Price.ToString("N0") VNĐ</span>
                </div>

                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Mô tả liệu trình</h5>
                    <p class="text-muted lh-lg fs-6">
                        @(string.IsNullOrEmpty(Model.Description) ? "Đang cập nhật mô tả cho dịch vụ này." : Model.Description)
                    </p>
                </div>

                <div class="mb-5">
                    <h5 class="fw-bold mb-3">Nguyên liệu nổi bật</h5>
                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.ServiceMaterials != null && Model.ServiceMaterials.Any())
                        {
                            foreach (var item in Model.ServiceMaterials)
                            {
                                <span class="badge bg-light text-gold border border-gold p-2 px-3 rounded-pill fw-medium" data-aos="zoom-in" data-aos-delay="200">
                                    <i class="fas fa-leaf me-1"></i> @item.Material.MaterialName
                                </span>
                            }
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Sử dụng các tinh chất và nguyên liệu cơ bản cho liệu trình này.</span>
                        }
                    </div>
                </div>

                <!-- Video Dịch Vụ -->
                <div class="mb-5" data-aos="fade-up" data-aos-offset="50">
                    <h5 class="fw-bold mb-3"><i class="fas fa-video text-gold me-2"></i> Quy trình chi tiết</h5>
                    <div class="video-container rounded-4 overflow-hidden shadow-lg bg-dark d-flex align-items-center justify-content-center" style="aspect-ratio: 16/9; position: relative;">
                        @if (!string.IsNullOrEmpty(Model.VideoUrl))
                        {
                            if (Model.VideoUrl.Contains("youtube.com") || Model.VideoUrl.Contains("youtu.be"))
                            {
                                var videoId = "";
                                if (Model.VideoUrl.Contains("v=")) {
                                    videoId = Model.VideoUrl.Split("v=")[1].Split("&")[0];
                                } else if (Model.VideoUrl.Contains("youtu.be/")) {
                                    videoId = Model.VideoUrl.Split("youtu.be/")[1].Split("?")[0];
                                }
                                <iframe width="100%" height="100%" src="https://www.youtube.com/embed/@videoId?autoplay=0" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen style="position: absolute; top: 0; left: 0;"></iframe>
                            }
                            else
                            {
                                <video controls class="w-100 h-100" style="object-fit: cover;">
                                    <source src="@Model.VideoUrl" type="video/mp4">
                                    Trình duyệt của bạn không hỗ trợ tag video.
                                </video>
                            }
                        }
                        else
                        {
                            <div class="text-center p-4">
                                <i class="fas fa-play-circle text-gold opacity-25" style="font-size: 4rem;"></i>
                                <p class="text-white mt-3 mb-0">Video quy trình đang được cập nhật...</p>
                            </div>
                        }
                    </div>
                </div>

                <a href="/Booking?serviceId=@Model.ServiceId" class="btn btn-gold btn-lg rounded-pill px-5 py-3 text-uppercase fw-bold letter-spacing-1 w-100 shadow-lg mt-auto hover-lift" data-aos="zoom-in">
                    Đặt Lịch Cùng Dịch Vụ Này
                </a>
            </div>
        </div>

    </div>
</section>

<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(197, 168, 128, 0.3) !important;
    }
    .shadow-inset {
        box-shadow: inset 0 10px 50px rgba(0,0,0,0.1);
    }
</style>
