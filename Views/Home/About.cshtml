                            </p>
                            <div class="d-flex align-items-center mt-4 pt-4 border-top">
                                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80" alt="Customer" class="rounded-circle border border-2 border-gold p-1 me-3 shadow-sm" style="width: 70px; height: 70px; object-fit: cover;">
                                <div>
                                    <h5 class="mb-1 fw-bold text-dark">Lê Hoàng Nam</h5>
                                    <small class="text-gold fw-bold text-uppercase letter-spacing-1" style="font-size: 0.85rem;">Kiến trúc sư</small>
                                </div>
                            </div>
                        </div>

                    </div>
                    
                    <!-- Carousel Indicators -->
                    <div class="carousel-indicators position-relative mt-5 mb-0 justify-content-start z-index-1">
                        <button type="button" data-bs-target="#premiumTestimonialCarousel" data-bs-slide-to="0" class="active bg-gold" aria-current="true" style="width: 30px; height: 4px; border-radius: 2px; margin-right: 8px; border: none;"></button>
                        <button type="button" data-bs-target="#premiumTestimonialCarousel" data-bs-slide-to="1" class="bg-gold opacity-50 transition-all" style="width: 30px; height: 4px; border-radius: 2px; margin-right: 8px; border: none;"></button>
                        <button type="button" data-bs-target="#premiumTestimonialCarousel" data-bs-slide-to="2" class="bg-gold opacity-50 transition-all" style="width: 30px; height: 4px; border-radius: 2px; border: none;"></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- Call to Action Footer -->
