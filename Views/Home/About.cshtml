@{
    ViewData["Title"] = "Về Chúng Tôi";
}

<!-- Hero About Section -->
<section class="about-hero-section position-relative pb-5" style="margin-top: 80px;">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-12 text-center" data-aos="fade-up">
                <span class="text-gold fw-bold text-uppercase letter-spacing-2 mb-3 d-inline-block">Câu Chuyện Của SpaN5</span>
                <h1 class="display-3 font-playfair mb-4 fw-bold lh-sm text-dark">Khát Vọng Nâng Tầm<br>Vẻ Đẹp Việt</h1>
            </div>
        </div>
    </div>
</section>

<!-- Introduction Section -->
<section class="py-5 bg-light overflow-hidden">
    <div class="container pb-5">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0" data-aos="fade-right">
                <div class="position-relative p-4 rounded-4 shadow-sm bg-white border-start border-gold border-5">
                    <p class="fs-5 text-muted mb-4" style="line-height: 1.8; text-align: justify;">
                        Thị trường ngành làm đẹp ngày càng phát triển mạnh mẽ. Đây là tín hiệu đáng mừng nhưng vẫn còn tồn đọng hàng loạt vấn đề phát sinh. Khách hàng đi làm đẹp gặp phải không ít rắc rối khi thị trường hỗn loạn, không dễ để lựa chọn nơi làm đẹp uy tín và an toàn; chất lượng dịch vụ kém, sản phẩm không rõ nguồn gốc gây ảnh hưởng sức khỏe.
                    </p>
                    <p class="fs-5 text-muted mb-4" style="line-height: 1.8; text-align: justify;">
                        Vì thế, <strong>SpaN5</strong> ra đời với sứ mệnh giúp kết nối người dùng với các dịch vụ làm đẹp uy tín nhất. SpaN5 xây dựng không gian giúp khách hàng khai phá vẻ đẹp tinh thần và thể chất một cách toàn diện. Chúng tôi mang đến trải nghiệm làm đẹp phù hợp, an toàn, và bền vững, hướng tới xây dựng một cộng đồng làm đẹp lành mạnh.
                    </p>
                    <div class="mt-4 p-4 rounded-3" style="background-color: var(--beige);">
                        <p class="fst-italic mb-0 text-dark fw-bold fs-5 text-center">
                            "Khát vọng lớn nhất của chúng tôi là mang SpaN5 giúp hàng triệu người tiếp cận dịch vụ làm đẹp dễ dàng, trải nghiệm hành trình làm đẹp tiện lợi, an tâm."
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 offset-lg-1" data-aos="fade-left">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="SpaN5 Mission" class="img-fluid rounded-4 shadow-lg" style="object-fit: cover; height: 600px; width: 100%;">
                    <div class="position-absolute top-50 start-0 translate-middle p-4 bg-white shadow-lg rounded-circle text-center border border-gold" style="width: 140px; height: 140px; display: flex; align-items: center; justify-content: center; flex-direction: column;">
                        <i class="fas fa-heart text-gold fs-1 mb-2"></i>
                        <span class="fw-bold text-uppercase small">Tận Tâm</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Giá Trị Mang Lại Section -->
<section class="py-5 my-5">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="text-gold fw-bold text-uppercase letter-spacing-2">Lợi ích vượt trội</span>
            <h2 class="font-playfair display-5 mt-2 mb-3 fw-bold text-dark">Giá Trị Mang Lại</h2>
            <div class="mx-auto bg-gold" style="height: 3px; width: 80px; border-radius: 2px;"></div>
        </div>
        
        <div class="row g-5 align-items-center mt-4">
            <div class="col-lg-4" data-aos="fade-right">
                <div class="position-relative text-center">
                    <img src="https://images.unsplash.com/photo-1629904853716-f0bc54eea481?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="App interface mock" class="img-fluid rounded-4 shadow-lg" style="max-height: 500px; border: 10px solid #EFEBE4;">
                </div>
            </div>
            <div class="col-lg-8" data-aos="fade-left">
                <div class="pe-lg-5">
                    <!-- Value 1 -->
                    <div class="d-flex mb-5 align-items-start value-item p-4 rounded-4 transition-all hover-shadow">
                        <div class="flex-shrink-0 bg-gold-light rounded-circle p-3 shadow-sm text-gold me-4">
                            <i class="fas fa-mobile-alt fs-2"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-3 font-playfair" style="color: #6C5CE7;">Kết nối</h4>
                            <p class="text-muted fs-6" style="line-height: 1.7;">
                                SpaN5 tạo cơ hội kết nối hoàn hảo. Giúp khách hàng dễ dàng tìm kiếm dịch vụ làm đẹp gần nhất, đặt lịch hẹn nhanh chóng và thanh toán tiện lợi, bảo mật tuyệt đối.
                            </p>
                        </div>
                    </div>
                    <!-- Value 2 -->
                    <div class="d-flex mb-5 align-items-start value-item p-4 rounded-4 transition-all hover-shadow">
                        <div class="flex-shrink-0 bg-gold-light rounded-circle p-3 shadow-sm text-gold me-4">
                            <i class="fas fa-chart-line fs-2"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-3 font-playfair" style="color: #00B894;">Chuyển đổi số</h4>
                            <p class="text-muted fs-6" style="line-height: 1.7;">
                                Khắc phục các nhược điểm của việc quản lý, đặt lịch thủ công. Mọi quy trình từ tiếp đón, liệu trình đến thanh toán đều được số hóa tinh gọn, nhanh chóng và chính xác.
                            </p>
                        </div>
                    </div>
                    <!-- Value 3 -->
                    <div class="d-flex align-items-start value-item p-4 rounded-4 transition-all hover-shadow">
                        <div class="flex-shrink-0 bg-gold-light rounded-circle p-3 shadow-sm text-gold me-4">
                            <i class="fas fa-bullhorn fs-2"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-3 font-playfair" style="color: #0984E3;">Tiện nghi vượt trội</h4>
                            <p class="text-muted fs-6" style="line-height: 1.7;">
                                Tiếp cận với các công nghệ và dịch vụ làm đẹp hàng đầu mà không phát sinh chi phí ẩn. Tối ưu hóa trải nghiệm khách hàng ở mọi điểm chạm.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Dịch Vụ Của SpaN5 Section -->
<section class="py-5 bg-dark text-white position-relative overflow-hidden">
    <div class="container py-5 z-index-1 position-relative">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="text-gold fw-bold text-uppercase letter-spacing-2">Trải Nghiệm</span>
            <h2 class="font-playfair display-5 mt-2 mb-3 fw-bold text-white">Những Dịch Vụ Tại SpaN5</h2>
            <div class="mx-auto bg-gold" style="height: 3px; width: 80px; border-radius: 2px;"></div>
        </div>
        
        <div class="row g-4 justify-content-center">
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="service-box bg-white bg-opacity-10 rounded-4 p-4 text-center h-100 transition-all border border-secondary border-opacity-25 hover-border-gold">
                    <i class="fas fa-spa fs-1 text-gold mb-3"></i>
                    <h5 class="fw-bold mb-3">Massage Trị Liệu</h5>
                    <p class="text-white-50 small mb-0">Thư giãn cơ bắp, giải tỏa căng thẳng với công nghệ xoa bóp hiện đại kết hợp truyền thống.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="service-box bg-white bg-opacity-10 rounded-4 p-4 text-center h-100 transition-all border border-secondary border-opacity-25 hover-border-gold">
                    <i class="fas fa-magic fs-1 text-gold mb-3"></i>
                    <h5 class="fw-bold mb-3">Chăm Sóc Da Chuyên Sâu</h5>
                    <p class="text-white-50 small mb-0">Tái sinh làn da với các dòng mỹ phẩm cao cấp và quy trình đạt chuẩn y khoa.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="service-box bg-white bg-opacity-10 rounded-4 p-4 text-center h-100 transition-all border border-secondary border-opacity-25 hover-border-gold">
                    <i class="fas fa-leaf fs-1 text-gold mb-3"></i>
                    <h5 class="fw-bold mb-3">Gội Đầu Dưỡng Sinh</h5>
                    <p class="text-white-50 small mb-0">Cân bằng tinh thần, đả thông kinh lạc với thảo dược thiên nhiên 100%.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="service-box bg-white bg-opacity-10 rounded-4 p-4 text-center h-100 transition-all border border-secondary border-opacity-25 hover-border-gold">
                    <i class="fas fa-gem fs-1 text-gold mb-3"></i>
                    <h5 class="fw-bold mb-3">Liệu Pháp Cung Đình</h5>
                    <p class="text-white-50 small mb-0">Trải nghiệm dịch vụ chăm sóc cao cấp dành riêng cho hoàng gia ngày xưa.</p>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-5" data-aos="zoom-in" data-aos-delay="500">
            <a href="/#services" class="btn btn-gold rounded-pill px-5 py-3 fw-bold text-uppercase">Khám Phá Tất Cả</a>
        </div>
    </div>
</section>

<!-- Đối tác / Khách hàng tiêu biểu Section -->
<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="font-playfair display-6 mt-2 mb-3 fw-bold text-dark">Đối Tác & Khách Hàng Tiêu Biểu</h2>
            <p class="text-muted">Được tin tưởng bởi hàng ngàn khách hàng và các thương hiệu uy tín</p>
        </div>
        
        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-4 align-items-center justify-content-center opacity-75 grayscale-hover-container" data-aos="fade-up" data-aos-delay="200">
            <div class="col text-center p-3">
                <i class="fab fa-aws fs-1 text-secondary mb-2 partner-icon transition-all"></i>
                <h6 class="text-muted small">AWS Beauty</h6>
            </div>
            <div class="col text-center p-3">
                <i class="fab fa-shopify fs-1 text-secondary mb-2 partner-icon transition-all"></i>
                <h6 class="text-muted small">Shopify Life</h6>
            </div>
            <div class="col text-center p-3">
                <i class="fab fa-apple fs-1 text-secondary mb-2 partner-icon transition-all"></i>
                <h6 class="text-muted small">Apple Care+</h6>
            </div>
            <div class="col text-center p-3">
                <i class="fab fa-google fs-1 text-secondary mb-2 partner-icon transition-all"></i>
                <h6 class="text-muted small">Google Health</h6>
            </div>
            <div class="col text-center p-3">
                <i class="fab fa-microsoft fs-1 text-secondary mb-2 partner-icon transition-all"></i>
                <h6 class="text-muted small">M-Clinic</h6>
            </div>
        </div>
    </div>
</section>

<style>
    .bg-gold-light {
        background-color: rgba(212, 175, 55, 0.1);
    }
    .hover-shadow:hover {
        background-color: #fff;
        box-shadow: 0 1rem 3rem rgba(0,0,0,.05) !important;
        transform: translateY(-5px);
    }
    .hover-border-gold:hover {
        border-color: var(--gold) !important;
        background-color: rgba(212, 175, 55, 0.05) !important;
    }
    .partner-icon {
        color: #adb5bd !important;
    }
    .col:hover .partner-icon {
        color: var(--gold) !important;
        transform: scale(1.1);
    }
    .col:hover h6 {
        color: var(--gold) !important;
    }
</style>
