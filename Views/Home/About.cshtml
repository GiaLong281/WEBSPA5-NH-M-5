    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background-image: url('https://images.unsplash.com/photo-1540555700478-4be289fbecef?ixlib=rb-4.0.3'); background-size: cover; background-position: center;"></div>
    <div class="container position-relative py-5" style="z-index: 1;">
        <h2 class="font-playfair display-5 mb-4 fw-bold" data-aos="fade-up">Dành Tặng Bản Thân Một Ngày Trọn Vẹn</h2>
        <p class="lead fw-light mb-5 mx-auto" style="max-width: 600px;" data-aos="fade-up" data-aos-delay="100">Cơ thể bạn xứng đáng được lắng nghe và yêu thương. Đừng chờ đợi để được thư giãn.</p>
        <div data-aos="fade-up" data-aos-delay="200">
            <a href="/Booking" class="btn btn-gold btn-lg rounded-pill px-5 py-3 text-uppercase fw-bold letter-spacing-1 shadow">
                <i class="far fa-calendar-alt me-2"></i> Đặt Lịch Hẹn Ngay
            </a>
        </div>
    </div>
</section>

<style>
    .letter-spacing-1 { letter-spacing: 1px; }
    .letter-spacing-2 { letter-spacing: 2px; }
    
    /* Removed old gallery-item CSS */
    
    /* Float Animation for Mission section */
    @@keyframes floatBadge {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
        100% { transform: translateY(0px); }
    }

    /* Premium Gallery Grid Styles */
    .premium-gallery-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: 250px;
        gap: 20px;
    }
    
    .gallery-item {
        overflow: hidden;
        cursor: pointer;
    }
    
    .item-large {
        grid-column: span 2;
        grid-row: span 2;
    }
    
    .item-tall {
        grid-row: span 2;
    }
    
    .item-wide {
        grid-column: span 2;
    }
    
    .gallery-img-wrapper {
        overflow: hidden;
    }
    
    .gallery-img-wrapper img {
        object-fit: cover;
