@{
    ViewData["Title"] = "Về Chúng Tôi";
}

<!-- Hero Section for About Page -->
<section class="hero-section position-relative d-flex align-items-center justify-content-center overflow-hidden" style="height: 60vh; margin-top: -76px;">
    <!-- Background Image -->
    <div class="position-absolute top-0 start-0 w-100 h-100" style="z-index: 0;">
        <img src="https://images.unsplash.com/photo-1540555700478-4be289fbecef?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="Spa Atmosphere" class="w-100 h-100" style="object-fit: cover; filter: brightness(0.6);">
    </div>
    
    <!-- Overlay Gradient -->
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(180deg, rgba(26,43,60,0.8) 0%, rgba(26,43,60,0.3) 100%); z-index: 1;"></div>
    
    <div class="container position-relative text-center text-white" style="z-index: 2; margin-top: 50px;">
        <span class="text-gold fw-bold text-uppercase letter-spacing-2 mb-3 d-inline-block" data-aos="fade-down" data-aos-duration="800">Câu Chuyện Của SpaN5</span>
        <h1 class="display-3 font-playfair mb-4 fw-bold" data-aos="fade-up" data-aos-duration="1000">Nơi Thời Gian Lắng Đọng</h1>
        <p class="lead fw-light mx-auto" style="max-width: 600px; line-height: 1.8;" data-aos="fade-up" data-aos-delay="200">
            Nâng niu vẻ đẹp tự nhiên và mang lại sự bình yên tuyệt đối trong tâm hồn bạn.
        </p>
    </div>
</section>

<!-- Our Story Section -->
<section class="py-5 my-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-5 mb-5 mb-lg-0" data-aos="fade-right">
                <span class="text-gold fw-bold text-uppercase letter-spacing-2">Sứ Mệnh</span>
                <h2 class="font-playfair display-5 my-3 text-dark fw-bold">Khởi Nguồn Của<br>Sự Thư Thái</h2>
                <div class="bg-gold mb-4" style="height: 3px; width: 60px; border-radius: 2px;"></div>
                <p class="text-muted fs-5 mb-4" style="line-height: 1.8;">
                    Giữa nhịp sống thị thành hối hả và đầy áp lực, SpaN5 ra đời với mong muốn trở thành một "trạm sạc năng lượng" yên bình. 
                </p>
                <p class="text-muted" style="line-height: 1.8;">
                    Chúng tôi tin rằng vẻ đẹp tỏa sáng nhất khi cả cơ thể và tinh thần đều được nâng niu. Không chỉ là nơi cung cấp các liệu trình chăm sóc sắc đẹp, SpaN5 mang đến một trải nghiệm chữa lành toàn diện. Tại đây, mọi muộn phiền đều dừng lại sau cánh cửa.
                </p>
            </div>
            <div class="col-lg-6 offset-lg-1 position-relative" data-aos="fade-left">
                <div class="position-relative d-flex justify-content-end align-items-end h-100 w-100 my-4 my-lg-0" style="min-height: 450px;">
                    <!-- Decor frame -->
                    <div class="position-absolute border border-3 border-gold rounded-4" style="top: 5%; right: 5%; width: 75%; height: 85%; z-index: 0;"></div>
                    
                    <!-- Image 1: Main (larger) -->
                    <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Spa Treatment" class="rounded-4 shadow-lg position-absolute overflow-hidden" style="width: 70%; height: 80%; object-fit: cover; top: 0; right: 0; z-index: 1; transition: transform 0.5s ease;" onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
                    
                    <!-- Image 2: Secondary (overlapping bottom left) -->
                    <img src="https://images.unsplash.com/photo-1600334089648-b0d9d3028eb2?ixlib=rb-4.0.3&auto=format&fit=crop&w=500&q=80" alt="Spa Details" class="rounded-4 shadow-lg position-absolute border border-5 border-white" style="width: 55%; height: 60%; object-fit: cover; bottom: 0; left: 0; z-index: 2; transition: transform 0.5s ease;" onmouseover="this.style.transform='scale(1.05) translateY(-10px)'" onmouseout="this.style.transform='scale(1) translateY(0)'">
                    
                    <!-- Decorative element badge -->
                    <div class="position-absolute bg-gold text-white rounded-circle shadow-lg d-flex flex-column align-items-center justify-content-center" style="width: 120px; height: 120px; z-index: 3; top: 40%; left: -5%; animation: floatBadge 3s ease-in-out infinite;">
                        <span class="fs-2 fw-bold font-playfair">10+</span>
                        <span class="small text-uppercase fw-bold letter-spacing-1 text-center" style="font-size: 0.7rem; line-height: 1.2;">Năm<br>Kinh Nghiệm</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Core Values Section -->
<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="text-gold fw-bold text-uppercase letter-spacing-2">Vì Sao Chọn Chúng Tôi</span>
            <h2 class="font-playfair display-5 mt-2 mb-3 fw-bold">Giá Trị Cốt Lõi</h2>
            <div class="mx-auto bg-gold" style="height: 3px; width: 80px; border-radius: 2px;"></div>
        </div>
        
        <div class="row g-5 mt-2">
            <!-- Value 1 -->
            <div class="col-md-4 text-center" data-aos="fade-up" data-aos-delay="100">
                <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center mx-auto mb-4" style="width: 100px; height: 100px;">
                    <i class="fas fa-leaf text-gold fs-1"></i>
                </div>
                <h4 class="font-playfair fw-bold mb-3">Thiên Nhiên Thuần Khiết</h4>
                <p class="text-muted px-3" style="line-height: 1.7;">
                    Cam kết sử dụng 100% thảo mộc và dược liệu thiên nhiên cao cấp, thân thiện và an toàn tuyệt đối với mọi làn da.
                </p>
            </div>
            
            <!-- Value 2 -->
            <div class="col-md-4 text-center" data-aos="fade-up" data-aos-delay="300">
                <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center mx-auto mb-4" style="width: 100px; height: 100px;">
                    <i class="fas fa-spa text-gold fs-1"></i>
                </div>
                <h4 class="font-playfair fw-bold mb-3">Kỹ Thuật Điêu Luyện</h4>
                <p class="text-muted px-3" style="line-height: 1.7;">
                    Đội ngũ chuyên gia và kỹ thuật viên được đào tạo bài bản, sở hữu đôi tay điêu luyện cùng sự thấu cảm sâu sắc.
                </p>
            </div>
            
            <!-- Value 3 -->
            <div class="col-md-4 text-center" data-aos="fade-up" data-aos-delay="500">
                <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center mx-auto mb-4" style="width: 100px; height: 100px;">
                    <i class="fas fa-wind text-gold fs-1"></i>
                </div>
                <h4 class="font-playfair fw-bold mb-3">Không Gian An Tĩnh</h4>
                <p class="text-muted px-3" style="line-height: 1.7;">
                    Sự hòa quyện hoàn hảo giữa kiến trúc thiền định, ánh sáng dịu êm, âm nhạc và hương thơm tinh dầu độc bản.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Gallery Section -->
<section class="py-5 my-5">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <span class="text-gold fw-bold text-uppercase letter-spacing-2">Thư Viện Ảnh</span>
            <h2 class="font-playfair display-5 mt-2 mb-3 fw-bold">Góc Bình Yên Của Chúng Tôi</h2>
            <div class="mx-auto bg-gold" style="height: 3px; width: 80px; border-radius: 2px;"></div>
        </div>
        
        <!-- CSS Grid layout for premium look -->
        <div class="premium-gallery-grid">
            <!-- Large Focus Image -->
            <div class="gallery-item item-large" data-aos="zoom-in" data-aos-delay="100">
                <div class="gallery-img-wrapper rounded-4 shadow-sm h-100 w-100 position-relative">
                    <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" alt="Spa Room" class="img-fluid w-100 h-100">
                    <div class="gallery-overlay d-flex align-items-center justify-content-center">
                        <i class="fas fa-search-plus text-white fs-2"></i>
                    </div>
                </div>
            </div>
            
            <!-- Standard Image 1 -->
            <div class="gallery-item item-standard" data-aos="zoom-in" data-aos-delay="200">
                <div class="gallery-img-wrapper rounded-4 shadow-sm h-100 w-100 position-relative">
                    <img src="https://images.unsplash.com/photo-1519823551278-64ac92734fb1?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Spa Detail" class="img-fluid w-100 h-100">
                    <div class="gallery-overlay d-flex align-items-center justify-content-center">
                        <i class="fas fa-search-plus text-white fs-2"></i>
                    </div>
                </div>
            </div>
            
            <!-- Tall Image -->
            <div class="gallery-item item-tall" data-aos="zoom-in" data-aos-delay="300">
                <div class="gallery-img-wrapper rounded-4 shadow-sm h-100 w-100 position-relative">
                    <img src="https://images.unsplash.com/photo-1552693673-1bf958298935?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Spa Oils" class="img-fluid w-100 h-100">
                    <div class="gallery-overlay d-flex align-items-center justify-content-center">
                        <i class="fas fa-search-plus text-white fs-2"></i>
                    </div>
                </div>
            </div>
            
            <!-- Wide Image -->
            <div class="gallery-item item-wide" data-aos="zoom-in" data-aos-delay="400">
                <div class="gallery-img-wrapper rounded-4 shadow-sm h-100 w-100 position-relative">
                    <img src="https://images.unsplash.com/photo-1600334089648-b0d9d3028eb2?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Massage Therapy" class="img-fluid w-100 h-100">
                    <div class="gallery-overlay d-flex align-items-center justify-content-center">
                        <i class="fas fa-search-plus text-white fs-2"></i>
                    </div>
                </div>
            </div>
            
            <!-- Standard Image 2 -->
            <div class="gallery-item item-standard" data-aos="zoom-in" data-aos-delay="500">
                <div class="gallery-img-wrapper rounded-4 shadow-sm h-100 w-100 position-relative">
                    <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Facial Therapy" class="img-fluid w-100 h-100">
                    <div class="gallery-overlay d-flex align-items-center justify-content-center">
                        <i class="fas fa-search-plus text-white fs-2"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Enhanced Premium Testimonials Section -->
<section id="about-testimonials" class="py-6 position-relative overflow-hidden" style="background-color: #faf9f7; padding-top: 5rem; padding-bottom: 5rem;">
    <!-- Decorative background elements -->
    <div class="position-absolute top-0 end-0 p-5 opacity-10" style="transform: translate(30%, -30%); pointer-events: none;">
        <i class="fas fa-certificate text-gold" style="font-size: 30rem; animation: spin-slow 40s linear infinite;"></i>
    </div>
    <div class="position-absolute bottom-0 start-0 p-5 opacity-10" style="transform: translate(-30%, 30%); pointer-events: none;">
        <i class="fas fa-fan text-gold" style="font-size: 30rem; animation: spin-slow-reverse 45s linear infinite;"></i>
    </div>

    <div class="container py-5 position-relative z-index-1">
        <div class="row align-items-center">
            <!-- Left Info Column -->
            <div class="col-lg-5 mb-5 mb-lg-0" data-aos="fade-right" data-aos-duration="1000">
                <span class="text-gold fw-bold text-uppercase letter-spacing-2 d-inline-block mb-3">Đánh Giá</span>
                <h2 class="font-playfair display-4 mb-4 fw-bold text-dark">Khách Hàng Nói Gì Về SpaN5?</h2>
                <div class="bg-gold mb-4" style="height: 4px; width: 60px; border-radius: 2px;"></div>
                <p class="lead text-muted mb-5" style="line-height: 1.8;">
                    Hơn 5000+ khách hàng đã trải nghiệm và hài lòng với chất lượng dịch vụ của chúng tôi. Mỗi đánh giá là một minh chứng cho sự nỗ lực không ngừng nghỉ và là nguồn động lực to lớn nhất của SpaN5.
                </p>
                
                <!-- Custom Carousel Controls -->
                <div class="d-flex gap-3">
                    <button class="btn btn-outline-dark rounded-circle d-flex align-items-center justify-content-center testimonial-control" type="button" data-bs-target="#premiumTestimonialCarousel" data-bs-slide="prev" style="width: 55px; height: 55px; border-width: 2px; transition: all 0.3s ease;">
                        <i class="fas fa-arrow-left fs-5"></i>
                    </button>
                    <button class="btn btn-gold rounded-circle d-flex align-items-center justify-content-center shadow-lg testimonial-control-next" type="button" data-bs-target="#premiumTestimonialCarousel" data-bs-slide="next" style="width: 55px; height: 55px; transition: all 0.3s ease;">
                        <i class="fas fa-arrow-right fs-5 text-dark"></i>
                    </button>
                </div>
            </div>

            <!-- Right Carousel Column -->
            <div class="col-lg-7 position-relative" data-aos="fade-left" data-aos-duration="1200">
