@model IEnumerable<SpaN5.Models.Branch>
@{
    ViewData["Title"] = "Hệ thống chi nhánh";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5" style="margin-top: 80px;">
    <div class="text-center mb-5">
        <h1 class="font-playfair text-gold">Hệ thống chi nhánh</h1>
        <div class="mx-auto bg-gold" style="height: 2px; width: 60px;"></div>
        <p class="mt-3 text-muted">Chúng tôi có mặt tại các địa điểm thuận tiện nhất cho bạn</p>
    </div>

    <div class="row g-4">
        @foreach (var branch in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm hover-shadow transition-all border-0">
                    @if (!string.IsNullOrEmpty(branch.Image))
                    {
                        <img src="@branch.Image" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@branch.BranchName">
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="fas fa-store fa-4x text-muted"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title font-playfair">@branch.BranchName</h5>
                        <div class="mb-2">
                            <i class="fas fa-map-marker-alt text-gold me-2"></i> @branch.Address
                            @if (!string.IsNullOrEmpty(branch.District))
                            {
                                <span>, @branch.District</span>
                            }
                            <span>, @branch.City</span>
                        </div>
                        <div class="mb-2">
                            <i class="fas fa-phone-alt text-gold me-2"></i> @branch.Phone
                        </div>
                        @if (!string.IsNullOrEmpty(branch.Email))
                        {
                            <div class="mb-2">
                                <i class="fas fa-envelope text-gold me-2"></i> @branch.Email
                            </div>
                        }
                        <div class="mb-3">
                            <i class="far fa-clock text-gold me-2"></i> 
                            @branch.OpeningTime.ToString(@"hh\:mm") - @branch.ClosingTime.ToString(@"hh\:mm")
                            @if (!string.IsNullOrEmpty(branch.Workday))
                            {
                                <span> | @branch.Workday</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(branch.Description))
                        {
                            <p class="text-muted small">@branch.Description</p>
                        }
                    </div>
                    <div class="card-footer bg-white border-0 pb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge @(branch.IsActive ? "bg-success" : "bg-secondary")">
                                @(branch.IsActive ? "Đang hoạt động" : "Tạm đóng cửa")
                            </span>
                            <a asp-action="Details" asp-route-id="@branch.BranchId" class="btn btn-sm btn-outline-gold rounded-pill">
                                Xem chi tiết <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .hover-shadow {
        transition: all 0.3s ease;
    }
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>