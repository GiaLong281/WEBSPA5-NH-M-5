@{
    ViewData["Title"] = "Dịch vụ Spa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5" style="margin-top: 80px;">
    <div class="text-center mb-5">
        <h1 class="font-playfair text-gold">Dịch vụ của chúng tôi</h1>
        <div class="mx-auto bg-gold" style="height: 2px; width: 60px;"></div>
        <p class="mt-3 text-muted">Trải nghiệm các liệu trình chăm sóc chuyên nghiệp</p>
    </div>

    <!-- Form lọc -->
    <div class="card shadow-sm mb-5">
        <div class="card-body">
            <form id="filterForm" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Tìm theo tên</label>
                    <input type="text" id="keyword" class="form-control" placeholder="Nhập tên dịch vụ">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Danh mục</label>
                    <select id="categoryId" class="form-select">
                        <option value="">Tất cả</option>
                        <!-- Danh mục sẽ được load bằng JavaScript -->
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="row g-2">
                        <div class="col">
                            <input type="number" id="minPrice" class="form-control" placeholder="Từ">
                        </div>
                        <div class="col">
                            <input type="number" id="maxPrice" class="form-control" placeholder="Đến">
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Trạng thái</label>
                    <select id="isActive" class="form-select">
                        <option value="true">Đang hoạt động</option>
                        <option value="">Tất cả</option>
                        <option value="false">Không hoạt động</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-gold w-100">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Kết quả hiển thị -->
    <div id="servicesContainer" class="row g-4">
        <div class="col-12 text-center py-5">
            <div class="spinner-border text-gold" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
        </div>
    </div>

    <!-- Phân trang -->
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center" id="pagination"></ul>
    </nav>
</div>

@section Styles {
    <style>
        .badge-luxury {
            background: linear-gradient(135deg, #b68a63 0%, #d9b48f 100%);
            color: #fff;
            padding: 0.35rem 0.8rem;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 700;
            box-shadow: 0 4px 10px rgba(182,138,99,0.3);
            border: 1px solid rgba(255,255,255,0.2);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .badge-luxury i { margin-right: 4px; }
        
        .badge-pro {
            background: linear-gradient(135deg, #6c757d 0%, #a8b2bc 100%);
            color: #fff;
            padding: 0.35rem 0.8rem;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 700;
            box-shadow: 0 4px 10px rgba(108,117,125,0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
            border: 1px solid rgba(255,255,255,0.3);
        }
        .badge-pro i { margin-right: 4px; }
    </style>
}

@section Scripts {
    <script>
        let currentPage = 1;
        const pageSize = 9;

        async function loadCategories() {
            try {
                const res = await fetch('/api/ApiServiceCategory');
                const categories = await res.json();
                const select = document.getElementById('categoryId');
                categories.forEach(cat => {
                    const option = document.createElement('option');
                    option.value = cat.id;
                    option.textContent = cat.name;
                    select.appendChild(option);
                });
            } catch (error) {
                console.error('Lỗi tải danh mục:', error);
            }
        }

        async function fetchServices() {
            const keyword = document.getElementById('keyword').value;
            const categoryId = document.getElementById('categoryId');
            const minPrice = document.getElementById('minPrice').value;
            const maxPrice = document.getElementById('maxPrice').value;
            const isActive = document.getElementById('isActive').value;

            const params = new URLSearchParams({
                page: currentPage,
                pageSize: pageSize,
                ...(keyword && { keyword }),
                ...(categoryId && categoryId.value && { categoryId: categoryId.value }),
                ...(minPrice && { minPrice }),
                ...(maxPrice && { maxPrice }),
                ...(isActive !== '' && { isActive })
            });

            const url = `/api/ApiService?${params.toString()}`;
            try {
                const res = await fetch(url);
                const data = await res.json();

                renderServices(data.items);
                renderPagination(data.totalPages, data.currentPage);
            } catch (error) {
                console.error('Lỗi tải dịch vụ:', error);
                document.getElementById('servicesContainer').innerHTML = `
                    <div class="col-12 text-center py-5">
                        <div class="alert alert-danger">Không thể tải danh sách dịch vụ. Vui lòng thử lại sau.</div>
                    </div>`;
            }
        }

        function renderServices(services) {
            const container = document.getElementById('servicesContainer');
            if (!services || services.length === 0) {
                container.innerHTML = `<div class="col-12 text-center py-5"><p class="text-muted">Không tìm thấy dịch vụ phù hợp.</p></div>`;
                return;
            }

            let html = '';
            services.forEach(service => {
                const imageUrl = (service.image && service.image.startsWith('http')) 
                    ? service.image 
                    : (service.image ? `/images/${service.image}` : '/images/no-image.jpg');
                
                let tierBadge = '';
                if (service.isVip) {
                    tierBadge = '<span class="badge-luxury position-absolute top-0 start-0 m-3 z-3"><i class="fas fa-crown"></i> Luxury</span>';
                } else if (service.price >= 700000) {
                    tierBadge = '<span class="badge-pro position-absolute top-0 start-0 m-3 z-3"><i class="fas fa-star"></i> Pro</span>';
                }

                const statusBadge = service.isActive 
                    ? '<span class="badge bg-success">Hoạt động</span>' 
                    : '<span class="badge bg-secondary">Tạm ngưng</span>';
                html += `
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-0 shadow-sm service-card transition-all position-relative">
                            <div class="card-img-top overflow-hidden position-relative" style="height: 220px;">
                                ${tierBadge}
                                <img src="${imageUrl}" class="w-100 h-100 transition-all" style="object-fit: cover;" alt="${service.serviceName}" loading="lazy">
                            </div>
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5 class="font-playfair mb-2">${service.serviceName}</h5>
                                    ${statusBadge}
                                </div>
                                <div class="mb-2">
                                    <span class="badge bg-gold text-dark">${service.categoryName}</span>
                                </div>
                                <p class="text-muted mb-3 small">${service.description ? (service.description.length > 100 ? service.description.substring(0,100)+'...' : service.description) : 'Không có mô tả'}</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-bold text-gold">${service.price.toLocaleString()}đ</span>
                                        <span class="text-muted ms-2"><i class="far fa-clock"></i> ${service.duration} phút</span>
                                    </div>
                                    <a href="/Booking/Index?serviceId=${service.serviceId}" class="btn btn-sm btn-outline-gold rounded-pill">Đặt lịch</a>
                                </div>
                            </div>
                            <a href="/Services/Details/${service.serviceId}" class="stretched-link"></a>
                        </div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        function renderPagination(totalPages, currentPage) {
            const pagination = document.getElementById('pagination');
            if (totalPages <= 1) {
                pagination.innerHTML = '';
                return;
            }

            let html = '';
            html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${currentPage - 1}">«</a>
                    </li>`;
            for (let i = 1; i <= totalPages; i++) {
                html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                            <a class="page-link" href="#" data-page="${i}">${i}</a>
                         </li>`;
            }
            html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${currentPage + 1}">»</a>
                    </li>`;

            pagination.innerHTML = html;

            document.querySelectorAll('.page-link').forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    const page = parseInt(link.getAttribute('data-page'));
                    if (!isNaN(page) && page >= 1 && page <= totalPages) {
                        currentPage = page;
                        fetchServices();
                    }
                });
            });
        }

        loadCategories();
        fetchServices();

        document.getElementById('filterForm').addEventListener('submit', (e) => {
            e.preventDefault();
            currentPage = 1;
            fetchServices();
        });
    </script>
}