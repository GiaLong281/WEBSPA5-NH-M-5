@model SpaN5.Models.Booking
@using SpaN5.Models

@{
    ViewData["Title"] = "Chi tiết lịch hẹn (Admin)";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var bookingDetail = Model.BookingDetails?.FirstOrDefault();
    var service = bookingDetail?.Service;
    var staff = bookingDetail?.Staff;
    var customer = Model.Customer;

    var statusBadge = Model.Status switch
    {
        BookingStatus.Pending => "bg-warning text-dark",
        BookingStatus.Confirmed => "bg-info",
        BookingStatus.InProgress => "bg-primary",
        BookingStatus.Completed => "bg-success",
        BookingStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };

    var statusText = Model.Status switch
    {
        BookingStatus.Pending => "Chờ xác nhận",
        BookingStatus.Confirmed => "Đã xác nhận",
        BookingStatus.InProgress => "Đang thực hiện",
        BookingStatus.Completed => "Hoàn thành",
        BookingStatus.Cancelled => "Đã hủy",
        _ => Model.Status.ToString()
    };
}

<div class="container py-5" style="margin-top: 80px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="font-playfair text-gold mb-1">Chi tiết lịch hẹn (Admin)</h1>
            <p class="text-muted">Mã đơn: <span class="fw-bold text-dark">@Model.BookingCode</span></p>
        </div>
        <a asp-action="ManageBookings" class="btn btn-outline-gold rounded-pill">
            <i class="fas fa-arrow-left me-2"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Thông tin chính -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold m-0"><i class="fas fa-info-circle text-gold me-2"></i> Thông tin tổng quan</h5>
                        <span class="badge @statusBadge rounded-pill px-3 py-2">@statusText</span>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6 text-break">
                            <label class="text-muted small text-uppercase fw-bold mb-2">Khách hàng</label>
                            <div class="d-flex align-items-center">
                                <div class="bg-soft p-2 rounded-circle me-3">
                                    <i class="fas fa-user text-gold"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@(customer?.FullName ?? "N/A")</h6>
                                    <div class="small text-muted">@(customer?.Phone ?? "N/A")</div>
                                    <div class="small text-muted">@(customer?.Email ?? "")</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 text-break">
                            <label class="text-muted small text-uppercase fw-bold mb-2">Dịch vụ & Nhân viên</label>
                            <div class="d-flex align-items-center">
                                <div class="bg-soft p-2 rounded-circle me-3">
                                    <i class="fas fa-spa text-gold"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold">@(service?.ServiceName ?? "N/A")</h6>
                                    <div class="small text-muted mt-1 d-flex align-items-center gap-2">
                                        Bởi:
                                        @if (staff != null)
                                        {
                                            <span class="text-dark fw-bold">@staff.FullName</span>
                                            @if (Model.Status == BookingStatus.Pending || Model.Status == BookingStatus.Confirmed || Model.Status == BookingStatus.InProgress)
                                            {
                                                <button type="button" class="btn btn-sm btn-link text-gold p-0 ms-2" data-bs-toggle="modal" data-bs-target="#assignStaffModal">
                                                    <i class="fas fa-edit"></i> Đổi
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            @if (Model.Status == BookingStatus.Pending || Model.Status == BookingStatus.Confirmed || Model.Status == BookingStatus.InProgress)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-gold rounded-pill px-2 py-0" data-bs-toggle="modal" data-bs-target="#assignStaffModal">
                                                    Chưa phân công <i class="fas fa-plus ms-1"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Chưa phân công</span>
                                            }
                                        }
                                    </div>
                                    <div class="small text-muted mt-1">Thời lượng: @(service?.Duration ?? 0) phút</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="text-muted small text-uppercase fw-bold mb-0">Thời gian & Địa điểm</label>
                                @if (Model.Status == BookingStatus.Pending || Model.Status == BookingStatus.Confirmed)
                                {
                                    <button type="button" class="btn btn-sm btn-link text-gold p-0" data-bs-toggle="modal" data-bs-target="#rescheduleModal">
                                        <i class="fas fa-edit"></i> Dời lịch
                                    </button>
                                }
                            </div>
                            <div class="mt-1">
                                <h6 class="mb-1 fw-bold"><i class="far fa-calendar-alt me-2 text-gold"></i> @Model.BookingDate.ToString("dddd, dd/MM/yyyy")</h6>
                                <div class="small text-muted mb-1"><i class="far fa-clock me-2 text-gold"></i> @Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</div>
                                <div class="small text-muted"><i class="fas fa-map-marker-alt me-2 text-gold"></i> @(Model.Branch?.BranchName ?? "N/A")</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold mb-2">Chi phí</label>
                            <div class="mt-1">
                                <h4 class="text-gold fw-bold mb-0">@Model.TotalAmount.ToString("N0") ₫</h4>
                                <div class="small text-muted">Phương thức: @(Model.Payments?.FirstOrDefault()?.Method.ToString() ?? "Chưa thanh toán")</div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <hr class="my-4 opacity-10">
                        <label class="text-muted small text-uppercase fw-bold mb-2">Ghi chú từ khách</label>
                        <p class="mt-1 mb-0 border-start border-gold border-4 ps-3 py-1 bg-light rounded-e-3 italic">"@Model.Notes"</p>
                    }
                </div>
            </div>

            <!-- Thanh toán Details -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold m-0"><i class="fas fa-credit-card text-gold me-2"></i> Lịch sử thanh toán</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.Payments != null && Model.Payments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-borderless align-middle mb-0">
                                <thead class="text-muted small text-uppercase">
                                    <tr>
                                        <th>ID</th>
                                        <th>Phương thức</th>
                                        <th>Số tiền</th>
                                        <th>Thời gian</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in Model.Payments)
                                    {
                                        <tr>
                                            <td class="fw-bold">@p.PaymentId</td>
                                            <td><span class="badge bg-soft text-gold rounded-pill px-2">@p.Method</span></td>
                                            <td class="fw-bold text-dark">@p.Amount.ToString("N0") ₫</td>
                                            <td class="small">@p.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td><span class="badge bg-success rounded-pill">Thành công</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted italic">
                            <i class="fas fa-receipt fa-2x mb-2 opacity-25"></i>
                            <p class="mb-0">Chưa có giao dịch thanh toán nào được ghi nhận.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Timeline Trạng thái -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold"><i class="fas fa-history text-gold me-2"></i> Lịch sử trạng thái</h5>
                </div>
                <div class="card-body p-4">
                    <div class="timeline">
                        <div class="timeline-item pb-4">
                            <div class="timeline-marker bg-success"></div>
                            <div class="timeline-content">
                                <h6 class="mb-0 fw-bold">Lịch hẹn đã tạo</h6>
                                <small class="text-muted">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </div>

                        <div class="timeline-item pb-4">
                            <div class="timeline-marker @(Model.Status != BookingStatus.Pending ? "bg-success" : "bg-warning")"></div>
                            <div class="timeline-content">
                                <h6 class="mb-0 fw-bold">@(Model.Status != BookingStatus.Pending ? "Đã xác nhận" : "Chờ xác nhận")</h6>
                            </div>
                        </div>

                        @if (Model.Status == BookingStatus.InProgress || Model.Status == BookingStatus.Completed)
                        {
                            <div class="timeline-item pb-4">
                                <div class="timeline-marker @(Model.Status != BookingStatus.InProgress ? "bg-success" : "bg-primary")"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-0 fw-bold">Đang thực hiện</h6>
                                </div>
                            </div>
                        }

                        @if (Model.Status == BookingStatus.Completed)
                        {
                            <div class="timeline-item pb-4">
                                <div class="timeline-marker bg-success"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-0 fw-bold">Đã hoàn thành</h6>
                                </div>
                            </div>
                        }

                        @if (Model.Status == BookingStatus.Cancelled)
                        {
                            <div class="timeline-item pb-4">
                                <div class="timeline-marker bg-danger"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-0 fw-bold">Đã hủy</h6>
                                    @if (!string.IsNullOrEmpty(Model.CancelReason))
                                    {
                                        <div class="small text-danger italic">Lý do: @Model.CancelReason</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Nút hành động nhanh -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 text-center">
                    <h6 class="fw-bold mb-3">Thao tác Admin</h6>
                    <div class="d-grid gap-2">
                        @if (Model.Status == BookingStatus.Pending)
                        {
                            <form asp-action="ApproveBooking" method="post">
                                <input type="hidden" name="id" value="@Model.BookingId" />
                                <button type="submit" class="btn btn-gold rounded-pill w-100">Xác nhận lịch ngay</button>
                            </form>
                        }
                        <button class="btn btn-outline-secondary rounded-pill" onclick="window.print()">
                            <i class="fas fa-print me-2"></i> In hóa đơn/Phiếu hẹn
                        </button>
                        <button class="btn btn-soft-danger rounded-pill mt-2">
                             Liên hệ khách hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modals -->
<div class="modal fade" id="assignStaffModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Phân công nhân viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AssignStaff" method="post">
                <div class="modal-body">
                    <input type="hidden" name="bookingId" value="@Model.BookingId" />
                    <input type="hidden" name="detailId" value="@bookingDetail?.DetailId" />
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Chọn nhân viên (Chi nhánh @Model.Branch?.BranchName)</label>
                        <select class="form-select" name="staffId" required>
                            <option value="">-- Chọn nhân viên --</option>
                            @if (ViewBag.BranchStaffs != null)
                            {
                                foreach (var s in ViewBag.BranchStaffs)
                                {
                                    <!option value="@s.StaffId" @(s.StaffId == staff?.StaffId ? "selected" : "")>@s.FullName</!option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-gold rounded-pill px-4">Lưu phân công</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="rescheduleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Dời lịch hẹn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RescheduleBooking" method="post">
                <div class="modal-body">
                    <input type="hidden" name="bookingId" value="@Model.BookingId" />
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Ngày mới</label>
                        <input type="date" class="form-control" name="newDate" value="@Model.BookingDate.ToString("yyyy-MM-dd")" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Giờ bắt đầu mới</label>
                        <input type="time" class="form-control" name="newStartTime" value="@Model.StartTime.ToString("HH:mm")" required />
                    </div>
                    <div class="alert alert-warning small bg-warning bg-opacity-10 mb-0 rounded-3 border-warning">
                        <i class="fas fa-info-circle me-1"></i> Quá trình dời lịch sẽ kiểm tra và đảm bảo không trùng với lịch nhân viên (nếu đã được phân công).
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-gold rounded-pill px-4">Xác nhận dời</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-soft { background: rgba(182, 138, 99, 0.08); }
    .btn-soft-danger { background: rgba(220, 53, 69, 0.1); color: #dc3545; border: none; }
    .btn-soft-danger:hover { background: #dc3545; color: white; }
    
    .timeline { position: relative; }
    .timeline-item { position: relative; padding-left: 30px; }
    .timeline-item:not(:last-child)::after {
        content: ""; position: absolute; left: 10px; top: 24px; bottom: 0;
        width: 2px; background: #eee;
    }
    .timeline-marker {
        position: absolute; left: 0; top: 4px; width: 20px; height: 20px;
        border-radius: 50%; border: 4px solid #fff; box-shadow: 0 0 0 2px #eee;
        z-index: 1;
    }
    .timeline-marker.bg-success { box-shadow: 0 0 0 2px #dcfce7; }
    .timeline-marker.bg-warning { box-shadow: 0 0 0 2px #fef9c3; }
    .timeline-marker.bg-danger { box-shadow: 0 0 0 2px #fee2e2; }
    .timeline-marker.bg-primary { box-shadow: 0 0 0 2px #dbeafe; }
</style>