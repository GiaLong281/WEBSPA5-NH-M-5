@model SpaN5.Models.Service
@{
    ViewData["Title"] = "Sửa dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h1>Sửa dịch vụ</h1>
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    
    <form asp-action="EditService" method="post" class="mt-4" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ServiceId" />
        
        <div class="row">
            <div class="col-md-8">
                <div class="form-group mb-3">
                    <label asp-for="ServiceName" class="form-label">Tên dịch vụ <span class="text-danger">*</span></label>
                    <input asp-for="ServiceName" class="form-control" required />
                    <span asp-validation-for="ServiceName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="form-label">Danh mục <span class="text-danger">*</span></label>
                    <select asp-for="CategoryId" class="form-control" required>
                        <option value="">-- Chọn danh mục --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var category in ViewBag.Categories)
                            {
                                <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">@category.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Price" class="form-label">Giá <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Duration" class="form-label">Thời gian (phút) <span class="text-danger">*</span></label>
                            <input asp-for="Duration" type="number" class="form-control" required />
                            <span asp-validation-for="Duration" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- Radio buttons cho IsActive -->
                <div class="form-group mb-3">
                    <label class="form-label">Trạng thái <span class="text-danger">*</span></label>
                    <div class="mt-2">
                        <div class="form-check form-check-inline">
                            <input type="radio" asp-for="IsActive" value="true" id="IsActive_True" class="form-check-input" checked="@Model.IsActive" />
                            <label for="IsActive_True" class="form-check-label">
                                <span class="badge bg-success">Hoạt động</span>
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input type="radio" asp-for="IsActive" value="false" id="IsActive_False" class="form-check-input" checked="@(!Model.IsActive)" />
                            <label for="IsActive_False" class="form-check-label">
                                <span class="badge bg-secondary">Không hoạt động</span>
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="IsActive" class="text-danger"></span>
                </div>

                <!-- Radio buttons cho IsPopular -->
                <div class="form-group mb-3">
                    <label class="form-label">Đánh dấu phổ biến</label>
                    <div class="mt-2">
                        <div class="form-check form-check-inline">
                            <input type="radio" asp-for="IsPopular" value="true" id="IsPopular_True" class="form-check-input" checked="@Model.IsPopular" />
                            <label for="IsPopular_True" class="form-check-label">
                                <span class="badge bg-warning text-dark">Phổ biến</span>
                            </label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input type="radio" asp-for="IsPopular" value="false" id="IsPopular_False" class="form-check-input" checked="@(!Model.IsPopular)" />
                            <label for="IsPopular_False" class="form-check-label">
                                <span class="badge bg-light text-dark">Không phổ biến</span>
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="IsPopular" class="text-danger"></span>
                    <small class="text-muted d-block">Dịch vụ phổ biến sẽ được hiển thị nổi bật trên trang chủ</small>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="form-group mb-3">
                    <label class="form-label">Hình ảnh hiện tại</label>
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <div class="card mb-3">
                            <div class="card-body text-center">
                                <img src="/images/@Model.Image" alt="Current image" style="max-width: 100%; max-height: 200px; object-fit: cover;" class="rounded border" />
                                <p class="text-muted mt-2 small">Tên file: @Model.Image</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">Chưa có hình ảnh</div>
                    }
                    
                    <label class="form-label mt-2">Cập nhật hình ảnh mới</label>
                    <input type="file" name="ImageFile" id="ImageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />
                    <small class="text-muted">Để trống nếu không muốn thay đổi hình ảnh</small>
                    
                    <div id="imagePreview" class="mt-3" style="display: none;">
                        <div class="card">
                            <div class="card-body text-center">
                                <img id="preview" src="#" alt="Preview" style="max-width: 100%; max-height: 200px; object-fit: cover;" class="rounded" />
                                <button type="button" class="btn btn-sm btn-danger mt-2" onclick="clearImage()">Xóa ảnh xem trước</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-success">Cập nhật dịch vụ</button>
            <a asp-action="ManageServices" class="btn btn-secondary">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        function previewImage(input) {
            var previewDiv = document.getElementById('imagePreview');
            var preview = document.getElementById('preview');
            
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    previewDiv.style.display = 'block';
                }
                
                reader.readAsDataURL(input.files[0]);
            }
        }
        
        function clearImage() {
            var previewDiv = document.getElementById('imagePreview');
            var imageInput = document.getElementById('ImageFile');
            var preview = document.getElementById('preview');
            
            imageInput.value = '';
            preview.src = '#';
            previewDiv.style.display = 'none';
        }
    </script>
}