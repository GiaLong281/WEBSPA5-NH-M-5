@model IEnumerable<SpaN5.Models.Branch>
@{
    ViewData["Title"] = "Quản lý chi nhánh";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-5">
    <h1>Quản lý chi nhánh</h1>
    <a asp-action="CreateBranch" class="btn btn-success mb-3">Thêm chi nhánh</a>
    <table class="table">
        <thead>
            <tr><th>ID</th><th>Tên</th><th>Địa chỉ</th><th>Điện thoại</th><th>Email</th><th>Hành động</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.BranchId</td>
                    <td>@item.BranchName</td>
                    <td>@item.Address</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>
                        <a asp-action="EditBranch" asp-route-id="@item.BranchId" class="btn btn-sm btn-warning">Sửa</a>
                        <form asp-action="DeleteBranch" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@item.BranchId" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa?')">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>