@model IEnumerable<SpaN5.Models.Material>
@{
    ViewData["Title"] = "Quản lý vật tư";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-5">
    <h1>Quản lý vật tư</h1>
    <a asp-action="CreateMaterial" class="btn btn-success mb-3">Thêm vật tư</a>
    <a asp-action="CreateStockTransaction" class="btn btn-info mb-3">Nhập/xuất kho</a>
    <table class="table">
        <thead>
            <tr><th>ID</th><th>Tên</th><th>Đơn vị</th><th>Tồn kho</th><th>Giá nhập</th><th>Hành động</th></tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td>@m.MaterialId</td>
                    <td>@m.MaterialName</td>
                    <td>@m.Unit</td>
                    <td>@m.CurrentStock</td>
                    <td>@m.PurchasePrice</td>
                    <td>
                        <a asp-action="EditMaterial" asp-route-id="@m.MaterialId" class="btn btn-warning">Sửa</a>
                        <form asp-action="DeleteMaterial" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@m.MaterialId" />
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Xóa?')">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>