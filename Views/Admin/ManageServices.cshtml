@model IEnumerable<SpaN5.Models.Service>
@{
    ViewData["Title"] = "Quản lý dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-5">
    <h1>Quản lý dịch vụ</h1>
    <a asp-action="CreateService" class="btn btn-success mb-3">Thêm dịch vụ</a>
    <table class="table table-bordered">
        <thead><tr><th>ID</th><th>Tên dịch vụ</th><th>Giá</th><th>Thời gian</th><th>Danh mục</th><th>Hành động</th></tr></thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.ServiceId</td>
                    <td>@s.ServiceName</td>
                    <td>@s.Price</td>
                    <td>@s.Duration phút</td>
                    <td>@s.Category?.Name</td>
                    <td>
                        <a asp-action="EditService" asp-route-id="@s.ServiceId" class="btn btn-warning">Sửa</a>
                        <form asp-action="DeleteService" method="post" style="display:inline;">
                            <input type="hidden" name="id" value="@s.ServiceId" />
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Xóa?')">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>