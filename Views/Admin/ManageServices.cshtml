@model IEnumerable<SpaN5.Models.Service>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Quản lý dịch vụ";
    // Tự động chọn Layout dựa trên vai trò
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var isAdmin = User.IsInRole("Admin");
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">@ViewData["Title"]</h2>
            <p class="text-muted small mb-0">Khám phá và quản lý danh mục dịch vụ Spa cao cấp</p>
        </div>
        @if (isAdmin)
        {
            <a asp-action="CreateService" class="btn btn-primary d-flex align-items-center gap-2 px-4 rounded-pill shadow-sm">
                <i class="fas fa-plus"></i>
                <span>Thêm dịch vụ mới</span>
            </a>
        }
    </div>

    <!-- Search & Filter Bar -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" id="serviceSearch" class="form-control bg-light border-0 shadow-none" placeholder="Tìm kiếm tên dịch vụ hoặc danh mục...">
                    </div>
                </div>
                <div class="col-md-4">
                    <select id="categoryFilter" class="form-select bg-light border-0 shadow-none">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var cat in Model.Select(s => s.Category?.Name).Distinct().Where(n => n != null))
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4 d-flex align-items-center gap-2">
            <i class="fas fa-check-circle fs-5"></i>
            <div>@TempData["Success"]</div>
        </div>
    }

    <!-- Service Cards Grid -->
    <div class="row g-4" id="serviceGrid">
        @if (Model != null && Model.Any())
        {
            foreach (var service in Model)
            {
                <div class="col-sm-6 col-md-4 col-xl-3 service-item" data-category="@(service.Category?.Name ?? "")" data-name="@service.ServiceName.ToLower()">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden transition-hover">
                        <!-- Image Container -->
                        <div class="position-relative">
                            @{
                                var imageUrl = (service.Image != null && service.Image.StartsWith("http")) 
                                    ? service.Image 
                                    : (!string.IsNullOrEmpty(service.Image) ? "/images/" + service.Image : null);
                            }
                            @if (imageUrl != null)
                            {
                                <img src="@imageUrl" class="card-img-top" alt="@service.ServiceName" style="height: 180px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                                    <i class="fas fa-spa text-muted fa-3x"></i>
                                </div>
                            }
                            
                            @if (service.IsPopular)
                            {
                                <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-3 shadow-sm rounded-pill px-3">
                                    <i class="fas fa-star me-1"></i> Hot
                                </span>
                            }
                        </div>

                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-soft-info text-info rounded-pill px-3 mb-2">@(service.Category?.Name ?? "Chưa phân loại")</span>
                                <span class="fw-bold text-primary">@service.Price.ToString("N0") đ</span>
                            </div>
                            
                            <h5 class="fw-bold text-dark mb-2 text-truncate" title="@service.ServiceName">@service.ServiceName</h5>
                            <p class="text-muted small mb-3 truncate-2">@(string.IsNullOrEmpty(service.Description) ? "Chưa có mô tả cho dịch vụ này." : service.Description)</p>
                            
                            <div class="d-flex align-items-center gap-3 text-muted small mb-4">
                                <span><i class="far fa-clock me-1"></i> @service.Duration phút</span>
                                <span>
                                    <i class="fas fa-circle @(service.IsActive ? "text-success" : "text-secondary") me-1" style="font-size: 8px;"></i>
                                    @(service.IsActive ? "Sẵn sàng" : "Tạm ngưng")
                                </span>
                            </div>

                            <div class="d-flex gap-2 mt-auto">
                                @if (isAdmin)
                                {
                                    <a asp-action="EditService" asp-route-id="@service.ServiceId" class="btn btn-soft-warning flex-fill rounded-3 py-2">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="DeleteService" method="post" style="display:inline;" class="flex-fill" onsubmit="return confirm('Xóa dịch vụ này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@service.ServiceId" />
                                        <button type="submit" class="btn btn-soft-danger w-100 rounded-3 py-2">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <a href="/Booking?serviceId=@service.ServiceId" class="btn btn-primary w-100 rounded-pill py-2 shadow-sm d-flex align-items-center justify-content-center gap-2">
                                        <i class="fas fa-calendar-check"></i>
                                        <span>Đặt lịch ngay</span>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
    .btn-soft-warning { background-color: rgba(255, 193, 7, 0.1); color: #856404; border: none; }
    .btn-soft-warning:hover { background-color: #ffc107; color: #fff; }
    .btn-soft-danger { background-color: rgba(220, 53, 69, 0.1); color: #842029; border: none; }
    .btn-soft-danger:hover { background-color: #dc3545; color: #fff; }
    
    .transition-hover { transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .transition-hover:hover { transform: translateY(-5px); box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important; }
    
    .truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Search function
            $("#serviceSearch").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                filterGrid();
            });

            // Filter function
            $("#categoryFilter").on("change", function() {
                filterGrid();
            });

            function filterGrid() {
                var searchTerm = $("#serviceSearch").val().toLowerCase();
                var category = $("#categoryFilter").val();

                $(".service-item").each(function() {
                    var itemCategory = $(this).data("category");
                    var itemName = $(this).data("name");
                    
                    var matchesSearch = itemName.indexOf(searchTerm) > -1;
                    var matchesCategory = category === "" || itemCategory === category;

                    if (matchesSearch && matchesCategory) {
                        $(this).fadeIn(300);
                    } else {
                        $(this).hide();
                    }
                });
            }

            // Auto dismiss alerts
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}