@model SpaN5.Models.ViewModels.LoginViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Login"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5" style="margin-top: 80px;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-gold text-white text-center py-4 border-0">
                    <h2 class="mb-0 font-playfair">@Localizer["Login"]</h2>
                    <p class="mb-0 mt-2 text-white-50">@Localizer["WelcomeBack"]</p>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        <div class="mb-3">
                            <label asp-for="Username" class="form-label">@Localizer["Username"]</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-user"></i></span>
                                <input asp-for="Username" class="form-control border-start-0 ps-0" placeholder="@Localizer["EnterUsername"]" />
                            </div>
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock"></i></span>
                                <input asp-for="Password" class="form-control border-start-0 ps-0" placeholder="@Localizer["EnterPassword"]" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">@Localizer["RememberMe"]</label>
                        </div>
                        <button type="submit" class="btn btn-gold w-100 py-2 rounded-pill fw-bold">@Localizer["Login"]</button>
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    </form>
                    <div class="text-center mt-4">
                        <p class="mb-0">@Localizer["NoAccount"] <a asp-action="Register" class="text-gold fw-bold">@Localizer["SignUpNow"]</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}