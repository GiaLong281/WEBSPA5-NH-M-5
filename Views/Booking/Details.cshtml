@model SpaN5.Models.Booking
@using SpaN5.Models
@{
    ViewData["Title"] = "Chi Tiết Lịch Hẹn";
    var firstDetail = Model.BookingDetails?.FirstOrDefault();
    var service = firstDetail?.Service;
    var staff = firstDetail?.Staff;
    var serviceName = service?.ServiceName ?? "Dịch vụ đã chọn";
    var isVip = service?.IsVip ?? false;
}

<style>
    :root {
        --p-navy: #12202d;
        --p-gold: #b68a63;
        --p-gold-light: #d9b48f;
        --p-beige: #fdfaf7;
    }

    body {
        background-color: var(--p-beige);
        font-family: 'Inter', sans-serif;
        color: var(--p-navy);
    }

    .main-wrapper {
        padding: 60px 20px;
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .title-area {
        text-align: center;
        margin-bottom: 30px;
    }

    .title-area h2 {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 12px;
        color: var(--p-navy);
    }

    .booking-code-pill {
        display: inline-block;
        background: #fff;
        padding: 6px 18px;
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid rgba(182,138,99,0.2);
        color: var(--p-gold);
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }

    .compact-ticket {
        background: white;
        width: 100%;
        max-width: 750px;
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.06);
        overflow: hidden;
        border-top: 6px solid var(--p-gold);
    }

    .ticket-section {
        padding: 40px;
    }

    .section-title {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--p-gold);
        margin-bottom: 25px;
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .info-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
        margin-bottom: 25px;
    }

    .info-item label {
        display: block;
        font-size: 0.7rem;
        color: #999;
        text-transform: uppercase;
        margin-bottom: 5px;
        font-weight: 700;
    }

    .info-item p {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0;
    }

    .status-badge {
        display: inline-block;
        padding: 5px 15px;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
    }
    .status-pending { background: #fffcf0; color: #b8860b; border: 1px solid #ffeeba; }
    .status-confirmed { background: #f0fff4; color: #2f855a; border: 1px solid #c6f6d5; }
    .status-inprogress { background: #ebf8ff; color: #2b6cb0; border: 1px solid #bee3f8; }
    .status-completed { background: #12202d; color: white; }
    .status-cancelled { background: #fff5f5; color: #c53030; border: 1px solid #fed7d7; }

    .vip-tag {
        background: linear-gradient(45deg, var(--p-gold), #e8d5b5);
        color: #fff;
        padding: 4px 10px;
        font-size: 0.65rem;
        border-radius: 4px;
        font-weight: 800;
        margin-left: 10px;
    }

    .action-group {
        display: flex;
        gap: 15px;
        margin-top: 20px;
    }

    .btn-ticket {
        flex: 1;
        padding: 14px;
        font-size: 0.85rem;
        font-weight: 700;
        border-radius: 12px;
        text-transform: uppercase;
        transition: all 0.3s;
        text-align: center;
        text-decoration: none;
    }

    .btn-cancel {
        background: #fff;
        color: #dc3545;
        border: 1px solid #f8d7da;
    }
    .btn-cancel:hover { background: #fff5f5; border-color: #dc3545; }

    .btn-main {
        background: var(--p-navy);
        color: white;
        border: none;
    }
    .btn-main:hover { background: #1e2a38; transform: translateY(-2px); color: #fff; }

    .btn-outline-gold {
        background: transparent;
        color: var(--p-gold);
        border: 1px solid var(--p-gold);
    }
    .btn-outline-gold:hover { background: var(--p-gold); color: #fff; }

    .timeline-area {
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px dashed #eee;
    }

    .footer-note {
        text-align: center;
        margin-top: 40px;
        font-size: 0.8rem;
        color: #bbb;
    }
</style>

<div class="main-wrapper">
    <div class="title-area" data-aos="fade-down">
        <h2>Chi Tiết Lịch Hẹn @if(isVip) { <span class="vip-tag">ROYAL VIP</span> }</h2>
        <div class="booking-code-pill">Mã đơn: @Model.BookingCode</div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mb-4 w-100" style="max-width: 750px;">@TempData["ErrorMessage"]</div>
    }

    <div class="compact-ticket" data-aos="zoom-in">
        <div class="ticket-section pb-2">
            <div class="section-title">
                <span>Thông tin dịch vụ</span>
                <span class="status-badge status-@Model.Status.ToString().ToLower()">
                    @Model.Status switch {
                        BookingStatus.Pending => "CHỜ XÁC NHẬN",
                        BookingStatus.Confirmed => "ĐÃ XÁC NHẬN",
                        BookingStatus.InProgress => "ĐANG THỰC HIỆN",
                        BookingStatus.Completed => "HOÀN THÀNH",
                        BookingStatus.Cancelled => "ĐÃ HỦY",
                        _ => Model.Status.ToString().ToUpper()
                    }
                </span>
            </div>
            
            <div class="info-row">
                <div class="info-item">
                    <label>Dịch vụ</label>
                    <p>@serviceName</p>
                </div>
                <div class="info-item">
                    <label>Thời lượng</label>
                    <p>@(service?.Duration ?? 0) phút</p>
                </div>
                <div class="info-item">
                    <label>Ngày hẹn</label>
                    <p>@Model.BookingDate.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="info-item">
                    <label>Thời gian</label>
                    <p>@Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</p>
                </div>
                <div class="info-item">
                    <label>Nhân viên</label>
                    <p>@(staff?.FullName ?? "Đang chỉ định...")</p>
                </div>
                <div class="info-item">
                    <label>Chi nhánh</label>
                    <p>@(Model.Branch?.BranchName ?? "SpaN5 Premium")</p>
                </div>
            </div>
        </div>

        <div class="ticket-section" style="background: #fafafb; border-top: 1px dashed #eee;">
            <div class="section-title">Thông tin thanh toán</div>
            <div class="info-row">
                <div class="info-item">
                    <label>Khách hàng</label>
                    <p>@Model.Customer?.FullName</p>
                </div>
                <div class="info-item text-end">
                    <label>Số điện thoại</label>
                    <p>@Model.Customer?.Phone</p>
                </div>
                <div class="info-item col-12" style="grid-column: span 2;">
                    <label>Tổng chi phí</label>
                    <p class="text-gold fs-4 fw-bold">@Model.TotalAmount.ToString("N0") ₫</p>
                </div>
                
                @if (Model.Payments != null && Model.Payments.Any())
                {
                    var payment = Model.Payments.OrderByDescending(p => p.CreatedAt).FirstOrDefault();
                    <div class="info-item">
                        <label>Trạng thái thanh toán</label>
                        <p class="text-success fw-bold"><i class="fas fa-check-circle me-1"></i>ĐÃ THANH TOÁN</p>
                    </div>
                    <div class="info-item text-end">
                        <label>Phương thức</label>
                        <p>@(payment?.Method == SpaN5.Models.PaymentMethod.Cash ? "Tiền mặt" : "Chuyển khoản")</p>
                    </div>
                }
                else
                {
                    <div class="info-item">
                        <label>Trạng thái thanh toán</label>
                        <p class="text-danger fw-bold"><i class="fas fa-exclamation-circle me-1"></i>CHƯA THANH TOÁN</p>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="info-item mb-4">
                    <label>Ghi chú</label>
                    <p class="small text-muted fst-italic">@Model.Notes</p>
                </div>
            }

            <div class="action-group">
                @if (Model.Status != BookingStatus.Cancelled && Model.Status != BookingStatus.Completed)
                {
                    <button onclick="confirmCancel()" class="btn-ticket btn-cancel">Hủy lịch</button>
                    @if (Model.Status == BookingStatus.Confirmed && Model.TotalAmount > 0)
                    {
                        <a href="@Url.Action("Create", "Payment", new { bookingId = Model.BookingId })" class="btn-ticket btn-main">Thanh toán ngay</a>
                    }
                }
                <a href="/Booking" class="btn-ticket btn-outline-gold">Đặt lịch mới</a>
                <a href="/" class="btn-ticket btn-main">TRANG CHỦ</a>
            </div>
        </div>
    </div>

    <div class="footer-note">
        <p>SpaN5 Luxury - Kiến tạo vẻ đẹp tự nhiên<br> Hotline: 1900 123 456 | Email: contact@span5.com</p>
    </div>
</div>

<form id="cancelForm" method="post" action="@Url.Action("Cancel", "Booking")" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.BookingId" />
    <input type="hidden" name="bookingCode" value="@Model.BookingCode" />
</form>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmCancel() {
        Swal.fire({
            title: 'Hủy lịch hẹn?',
            text: "Lưu ý: Hành động này không thể hoàn tác.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#12202d',
            confirmButtonText: 'Đồng ý hủy',
            cancelButtonText: 'Quay lại',
            background: '#fff',
            borderRadius: '15px'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('cancelForm').submit();
            }
        })
    }
</script>
