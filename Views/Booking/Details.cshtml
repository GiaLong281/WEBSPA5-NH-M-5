@model SpaN5.Models.Booking
@{
    ViewData["Title"] = "Chi Tiết Lịch Hẹn";
    var firstDetail = Model.BookingDetails.FirstOrDefault();
    var serviceName = firstDetail?.Service?.ServiceName ?? "Dịch vụ đã chọn";
}

<style>
    .details-container {
        max-width: 900px;
        margin: 0 auto;
    }
    .status-badge {
        padding: 8px 16px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
    }
    .status-pending { background: #fff3cd; color: #856404; }
    .status-confirmed { background: #d4edda; color: #155724; }
    .status-cancelled { background: #f8d7da; color: #721c24; }
    
    .info-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid #eee;
    }
    .label-custom {
        color: #999;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .value-custom {
        font-weight: 600;
        color: #333;
        font-size: 1.1rem;
    }
</style>

<div class="container py-5">
    <div class="details-container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="font-playfair mb-0">Chi Tiết Lịch Hẹn</h2>
            <div>
                @switch (Model.Status)
                {
                    case SpaN5.Models.BookingStatus.Pending:
                        <span class="status-badge status-pending">Đang chờ</span>
                        break;
                    case SpaN5.Models.BookingStatus.Confirmed:
                        <span class="status-badge status-confirmed">Đã xác nhận</span>
                        break;
                    case SpaN5.Models.BookingStatus.Cancelled:
                        <span class="status-badge status-cancelled">Đã hủy</span>
                        break;
                    default:
                        <span class="status-badge bg-light text-dark">@Model.Status</span>
                        break;
                }
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-8">
                <div class="info-card p-4 mb-4">
                    <h5 class="border-bottom pb-3 mb-4"><i class="fas fa-info-circle me-2 text-gold"></i>Thông Tin Dịch Vụ</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="label-custom d-block">Mã Booking</label>
                            <span class="value-custom">@Model.BookingCode</span>
                        </div>
                        <div class="col-md-6">
                            <label class="label-custom d-block">Gói dịch vụ</label>
                            <span class="value-custom">@serviceName</span>
                        </div>
                        <div class="col-md-6">
                            <label class="label-custom d-block">Ngày hẹn</label>
                            <span class="value-custom">@Model.StartTime.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="col-md-6">
                            <label class="label-custom d-block">Thời gian</label>
                            <span class="value-custom">@Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</span>
                        </div>
                        <div class="col-md-6">
                            <label class="label-custom d-block">Tổng tiền</label>
                            <span class="value-custom text-success">@Model.TotalAmount.ToString("N0") VNĐ</span>
                        </div>
                    </div>
                </div>

                <div class="info-card p-4 mt-4">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <i class="fas fa-info-circle fa-2x text-gold"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Thanh toán tại quầy</h6>
                            <p class="small text-muted mb-0">Vui lòng thanh toán trực tiếp tại spa sau khi hoàn thành dịch vụ.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card p-4 sticky-top" style="top: 100px;">
                    <h5 class="border-bottom pb-3 mb-4">Thao Tác</h5>
                    
                    @if (Model.Status != SpaN5.Models.BookingStatus.Cancelled && Model.Status != SpaN5.Models.BookingStatus.Completed)
                    {
                        <button onclick="confirmCancel()" class="btn btn-outline-danger w-100 mb-3 rounded-pill py-2">
                            <i class="fas fa-times me-2"></i>Hủy Lịch Hẹn
                        </button>
                    }
                    
                    <a href="/" class="btn btn-dark w-100 rounded-pill py-2">
                        <i class="fas fa-home me-2"></i>Về Trang Chủ
                    </a>
                    
                    <hr>
                    <div class="text-center">
                        <p class="small text-muted mb-0">Hỗ trợ hotline:</p>
                        <p class="fw-bold text-gold">1900 123 456</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmCancel() {
        Swal.fire({
            title: 'Bạn có chắc chắn?',
            text: "Lịch hẹn sẽ bị hủy và không thể hoàn tác!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Đúng, hủy nó!',
            cancelButtonText: 'Giữ lại'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/Booking/Cancel', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'bookingCode=@Model.BookingCode'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire(
                            'Đã hủy!',
                            data.message,
                            'success'
                        ).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('Lỗi!', data.message, 'error');
                    }
                });
            }
        })
    }
</script>
