@model SpaN5.Models.ViewModels.BookingViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "Đặt lịch";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
}

<div class="container py-5" style="margin-top: 80px;">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-gold text-white text-center py-4 border-0">
                    <h2 class="mb-0 font-playfair">Đặt lịch hẹn</h2>
                    <p class="mb-0 mt-2 text-white-50">Vui lòng điền thông tin bên dưới</p>
                </div>

                <div class="card-body p-5">
                    <form id="bookingForm" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <h4 class="font-playfair text-gold mb-3">Thông tin khách hàng</h4>
                                <div class="mb-3">
                                    <label asp-for="FullName" class="form-label">Họ tên</label>
                                    @if (isLoggedIn)
                                    {
                                        <input asp-for="FullName" class="form-control" readonly />
                                    }
                                    else
                                    {
                                        <input asp-for="FullName" class="form-control" />
                                    }
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">Email</label>
                                    @if (isLoggedIn)
                                    {
                                        <input asp-for="Email" class="form-control" type="email" readonly />
                                    }
                                    else
                                    {
                                        <input asp-for="Email" class="form-control" type="email" />
                                    }
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Phone" class="form-label">Số điện thoại</label>
                                    @if (isLoggedIn)
                                    {
                                        <input asp-for="Phone" class="form-control" readonly />
                                    }
                                    else
                                    {
                                        <input asp-for="Phone" class="form-control" />
                                    }
                                    <span asp-validation-for="Phone" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h4 class="font-playfair text-gold mb-3">Thông tin đặt lịch</h4>
                                <div class="mb-3">
                                    <label asp-for="SelectedServiceId" class="form-label">Dịch vụ</label>
                                    <select asp-for="SelectedServiceId" class="form-control" asp-items="ViewBag.Services" required>
                                        <option value="">-- Chọn dịch vụ --</option>
                                    </select>
                                    <span asp-validation-for="SelectedServiceId" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="BranchId" class="form-label">Chi nhánh</label>
                                    <select asp-for="BranchId" class="form-control" asp-items="ViewBag.Branches" required>
                                        <option value="">-- Chọn chi nhánh --</option>
                                    </select>
                                    <span asp-validation-for="BranchId" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="BookingDate" class="form-label">Ngày</label>
                                    <input asp-for="BookingDate" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="BookingDate" class="text-danger"></span>
                                    <div id="dateWarning" class="text-warning small mt-1" style="display:none;"></div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Thời gian</label>
                                    <select id="timeSlot" name="StartTime" class="form-control" required disabled>
                                        <option value="">-- Chọn giờ --</option>
                                    </select>
                                    <span class="text-danger" id="timeError"></span>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" asp-for="AutoAssignStaff" id="autoAssignToggle">
                                        <label class="form-check-label fw-bold text-gold" for="autoAssignToggle">Tự động chọn nhân viên cho tôi</label>
                                    </div>
                                    <div class="small text-muted mt-1">Hệ thống sẽ gán nhân viên rảnh nhất cho bạn.</div>
                                </div>

                                <div class="mb-3" id="staffSelectionContainer" style="display:none;">
                                    <label asp-for="StaffId" class="form-label">Chọn nhân viên ưa thích</label>
                                    <select asp-for="StaffId" class="form-control" id="staffId">
                                        <option value="">-- Trước hết hãy chọn giờ --</option>
                                    </select>
                                    <span asp-validation-for="StaffId" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Notes" class="form-label">Ghi chú</label>
                                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Yêu cầu thêm..."></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info" id="serviceInfo" style="display:none;">
                            <p><strong>Thông tin dịch vụ:</strong></p>
                            <p><span id="serviceName"></span> - <span id="serviceDuration"></span> phút - <span id="servicePrice"></span> VNĐ</p>
                        </div>

                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-gold rounded-pill px-5 py-2 fw-bold">ĐẶT LỊCH</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            var branchId = $('#BranchId');
            var bookingDate = $('#BookingDate');
            var serviceId = $('#SelectedServiceId');
            var timeSlot = $('#timeSlot');
            var dateWarning = $('#dateWarning');

            // Khi chọn dịch vụ, hiển thị thông tin
            serviceId.change(async function () {
                var id = $(this).val();
                if (id) {
                    try {
                        const res = await fetch(`/api/ApiService/${id}`);
                        const data = await res.json();
                        $('#serviceInfo').show();
                        $('#serviceName').text(data.serviceName);
                        $('#serviceDuration').text(data.duration);
                        $('#servicePrice').text(data.price.toLocaleString());
                    } catch (error) {
                        console.error('Lỗi tải dịch vụ:', error);
                    }
                } else {
                        $('#serviceInfo').hide();
                }
                loadTimeSlots();
            });

            // Khi chọn chi nhánh hoặc ngày, load lại danh sách giờ
            branchId.add(bookingDate).change(function () {
                loadTimeSlots();
            });

            // Toggle hiển thị chọn nhân viên
            var autoAssignToggle = $('#autoAssignToggle');
            var staffSelectionContainer = $('#staffSelectionContainer');
            var staffSelect = $('#staffId');

            autoAssignToggle.change(function() {
                if ($(this).is(':checked')) {
                    staffSelectionContainer.slideUp();
                    staffSelect.prop('required', false);
                } else {
                    staffSelectionContainer.slideDown();
                    staffSelect.prop('required', true);
                    loadAvailableStaff();
                }
            });

            // Khi chọn giờ, load lại danh sách nhân viên nếu đang chọn thủ công
            timeSlot.change(function() {
                if (!autoAssignToggle.is(':checked')) {
                    loadAvailableStaff();
                }
            });

            async function loadAvailableStaff() {
                var branch = branchId.val();
                var date = bookingDate.val();
                var time = timeSlot.val();
                var service = serviceId.val();

                if (!branch || !date || !time || !service) {
                    staffSelect.html('<option value="">-- Hãy chọn giờ trước --</option>');
                    return;
                }

                staffSelect.html('<option value="">-- Đang tải nhân viên... --</option>');

                try {
                    const res = await fetch(`/api/ApiBooking/GetAvailableStaff?branchId=${branch}&date=${date}&time=${time}&serviceId=${service}`);
                    const staffs = await res.json();
                    
                    staffSelect.empty();
                    if (staffs.length === 0) {
                        staffSelect.append('<option disabled selected>Không có nhân viên rảnh</option>');
                        alert('Không có nhân viên rảnh trong khung giờ này. Vui lòng chọn giờ khác.');
                    } else {
                        staffSelect.append('<option value="">-- Chọn nhân viên --</option>');
                        staffs.forEach(s => {
                            staffSelect.append(`<option value="${s.staffId}">${s.fullName} (${s.position})</option>`);
                        });
                    }
                } catch (error) {
                    console.error('Lỗi tải nhân viên:', error);
                    staffSelect.html('<option value="">-- Lỗi tải dữ liệu --</option>');
                }
            }

            async function loadTimeSlots() {
                var branch = branchId.val();
                var date = bookingDate.val();
                var service = serviceId.val();

                if (!branch || !date || !service) {
                    timeSlot.prop('disabled', true).html('<option value="">-- Vui lòng chọn đủ thông tin --</option>');
                    return;
                }

                // Kiểm tra ngày mở cửa (gọi API riêng nếu cần)
                try {
                    const res = await fetch(`/api/ApiBooking/GetTimeSlots?branchId=${branch}&date=${date}&serviceId=${service}`);
                    const slots = await res.json();
                    timeSlot.empty();
                    if (slots.length === 0) {
                        timeSlot.append('<option value="">-- Không có khung giờ trống --</option>');
                        timeSlot.prop('disabled', true);
                        dateWarning.text('Chi nhánh có thể không mở cửa hoặc đã kín lịch.').show();
                    } else {
                        timeSlot.append('<option value="">-- Chọn giờ --</option>');
                        slots.forEach(slot => {
                            timeSlot.append(`<option value="${slot.value}">${slot.time}</option>`);
                        });
                        timeSlot.prop('disabled', false);
                        dateWarning.hide();
                    }
                } catch (error) {
                    console.error('Lỗi tải giờ:', error);
                    timeSlot.html('<option value="">-- Lỗi tải dữ liệu --</option>').prop('disabled', true);
                }
            }
        });
    </script>
}