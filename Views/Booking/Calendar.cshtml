@{
    ViewData["Title"] = "Lịch hẹn";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var bookings = ViewBag.Bookings as List<dynamic>;
}

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>

<div class="container py-5" style="margin-top: 80px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="font-playfair text-gold">Lịch hẹn của tôi</h1>
        <a asp-action="Create" class="btn btn-gold rounded-pill px-4"><i class="fas fa-plus"></i> Đặt lịch mới</a>
    </div>

    <div id="calendar"></div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'vi',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay'
            },
            events: @Html.Raw(Json.Serialize(bookings.Select(b => new {
                title = b.ServiceNames,
                start = b.BookingDate.ToString("yyyy-MM-dd") + "T" + b.StartTime.ToString(),
                end = b.BookingDate.ToString("yyyy-MM-dd") + "T" + b.EndTime.ToString(),
                color = b.Status == 2 ? "#28a745" : (b.Status == 4 ? "#dc3545" : "#ffc107"),
                extendedProps = new {
                    status = b.Status,
                    code = b.BookingCode,
                    branch = b.BranchName,
                    total = b.TotalAmount
                }
            }))),
            eventClick: function(info) {
                var props = info.event.extendedProps;
                alert(`Mã đơn: ${props.code}\nTrạng thái: ${props.status}\nChi nhánh: ${props.branch}\nTổng tiền: ${props.total.toLocaleString()}đ`);
            }
        });
        calendar.render();
    });
</script>