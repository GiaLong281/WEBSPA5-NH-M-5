@model IEnumerable<SpaN5.Models.Customer>

@{
    ViewData["Title"] = "Quản lý khách đăng ký";
    Layout = "_Layout";
}

<style>
    .customer-list-container {
        padding-top: 120px;
        padding-bottom: 80px;
        background-color: #fcfaf7;
        min-height: 100vh;
    }
    
    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
    }
    
    .font-playfair {
        font-family: 'Playfair Display', serif;
    }
    
    .text-gold {
        color: #C5A059;
    }
    
    .btn-gold-outline {
        border: 1px solid #C5A059;
        color: #C5A059;
        transition: all 0.3s ease;
        border-radius: 50px;
        padding: 5px 20px;
    }
    
    .btn-gold-outline:hover {
        background-color: #C5A059;
        color: white;
        transform: translateY(-2px);
    }
    
    .badge-gold {
        background-color: #C5A059;
        color: white;
    }
    
    .table thead th {
        border-top: none;
        color: #888;
        font-weight: 500;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }
    
    .customer-row {
        transition: all 0.2s ease;
    }
    
    .customer-row:hover {
        background-color: rgba(197, 160, 89, 0.03) !important;
    }
</style>

<div class="customer-list-container">
    <div class="container">
        <div class="text-center mb-5">
            <h6 class="text-gold text-uppercase fw-bold ls-2 mb-2">Hệ thống quản lý</h6>
            <h1 class="font-playfair display-5 mb-3">Danh sách khách hàng đăng ký</h1>
            <div class="divider-gold mx-auto"></div>
        </div>

        <div class="glass-card p-4 p-md-5">
            <div class="table-responsive">
                <table class="table align-middle custom-table">
                    <thead>
                        <tr>
                            <th>Khách hàng</th>
                            <th>Liên hệ</th>
                            <th class="text-center">Số dịch vụ</th>
                            <th class="text-center">Ngày tạo</th>
                            <th class="text-end">Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            var totalServices = customer.Bookings.SelectMany(b => b.BookingDetails).Count();
                            <tr class="customer-row">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3">
                                            @customer.FullName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@customer.FullName</div>
                                            <small class="text-muted">ID: #CST-@customer.CustomerId.ToString("D4")</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div><i class="fas fa-phone-alt text-gold me-2 small"></i> @customer.Phone</div>
                                    @if (!string.IsNullOrEmpty(customer.Email))
                                    {
                                        <div class="small text-muted"><i class="fas fa-envelope text-gold me-2 small"></i> @customer.Email</div>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-gold rounded-pill px-3">@totalServices dịch vụ</span>
                                </td>
                                <td class="text-center text-muted small">
                                    @customer.CreatedAt.ToString("dd/MM/yyyy")
                                </td>
                                <td class="text-end">
                                    <a asp-action="CustomerDetail" asp-route-id="@customer.CustomerId" class="btn btn-gold-outline btn-sm">
                                        <i class="fas fa-chevron-right me-1"></i> Xem lịch sử
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .avatar-circle {
        width: 45px;
        height: 45px;
        background-color: #f0e6d2;
        color: #C5A059;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1.2rem;
    }
    
    .divider-gold {
        width: 80px;
        height: 3px;
        background: linear-gradient(90deg, transparent, #C5A059, transparent);
    }
    
    .ls-2 {
        letter-spacing: 2px;
    }
</style>
