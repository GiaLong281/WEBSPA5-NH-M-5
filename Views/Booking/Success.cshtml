@model SpaN5.Models.Booking
@{
    ViewData["Title"] = "Đặt Lịch Thành Công";
    var firstDetail = Model.BookingDetails.FirstOrDefault();
    var serviceName = firstDetail?.Service?.ServiceName ?? "Dịch vụ đã chọn";
}

<style>
    .success-container {
        max-width: 800px;
        margin: 0 auto;
    }
    .success-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
        border-top: 6px solid #d4af37;
    }
    .success-header {
        background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
        padding: 40px 20px;
        text-align: center;
    }
    .success-icon {
        width: 80px;
        height: 80px;
        background: #d4af37;
        color: white;
        font-size: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
        margin: 0 auto 20px;
        box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
    }
    .booking-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        padding: 30px;
        background: #fafafa;
        border-radius: 15px;
        margin: 20px;
    }
    .info-item {
        border-bottom: 1px dashed #eee;
        padding-bottom: 15px;
    }
    .info-label {
        color: #888;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 5px;
    }
    .info-value {
        color: #333;
        font-weight: 600;
        font-size: 1.1rem;
    }
    .booking-code-box {
        background: rgba(212, 175, 55, 0.1);
        border: 2px dashed #d4af37;
        padding: 20px;
        border-radius: 10px;
        margin-top: 20px;
        text-align: center;
    }
    .code-text {
        font-size: 2rem;
        font-weight: 800;
        color: #d4af37;
        letter-spacing: 3px;
        display: block;
    }
</style>

<div class="container py-5">
    <div class="success-container">
        <div class="success-card">
            <div class="success-header">
                <div class="success-icon">
                    <i class="fas fa-check"></i>
                </div>
                <h2 class="font-playfair display-6 text-dark mb-2">Đặt Lịch Thành Công!</h2>
                <p class="text-muted">Cảm ơn @Model.Customer.FullName đã tin tưởng SpaN5</p>
            </div>

            <div class="p-4">
                <h5 class="mb-4 text-center text-uppercase fw-bold" style="color: #d4af37; letter-spacing: 2px;">Thông Tin Lịch Hẹn</h5>
                
                <div class="booking-info-grid">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-user me-2"></i> Khách hàng</div>
                        <div class="info-value">@Model.Customer.FullName</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-phone me-2"></i> Số điện thoại</div>
                        <div class="info-value">@Model.Customer.Phone</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-spa me-2"></i> Gói dịch vụ</div>
                        <div class="info-value">@serviceName</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-calendar-alt me-2"></i> Ngày hẹn</div>
                        <div class="info-value">@Model.StartTime.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-clock me-2"></i> Giờ hẹn</div>
                        <div class="info-value">@Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-money-bill-wave me-2"></i> Tổng cộng</div>
                        <div class="info-value text-success">@Model.TotalAmount.ToString("N0") VNĐ</div>
                    </div>
                </div>

                <div class="px-4">
                    <div class="booking-code-box">
                        <span class="info-label">Mã số Booking</span>
                        <span class="code-text">@Model.BookingCode</span>
                        <p class="small text-muted mt-2 mb-0">Vui lòng cung cấp mã này cho nhân viên lễ tân khi đến spa.</p>
                    </div>
                </div>

                <!-- PHƯƠNG THỨC THANH TOÁN -->
                @if (!Model.Payments.Any(p => p.Status == SpaN5.Models.PaymentStatus.Paid))
                {
                    <div class="mt-5 px-4 text-center">
                        <h5 class="mb-4 text-uppercase fw-bold" style="color: #d4af37; letter-spacing: 1px;">Chọn Phương Thức Thanh Toán</h5>
                        <div class="d-flex justify-content-center gap-4">
                            <form asp-action="ProcessPayment" method="post">
                                <input type="hidden" name="bookingCode" value="@Model.BookingCode" />
                                <input type="hidden" name="method" value="Cash" />
                                <button type="submit" class="payment-btn border-0 bg-white shadow-sm p-4 rounded-3 d-flex flex-column align-items-center" style="width: 180px; transition: 0.3s; border: 2px solid transparent !important;">
                                    <i class="fas fa-money-bill-wave fa-3x mb-3 text-success"></i>
                                    <span class="fw-bold">Tiền mặt</span>
                                </button>
                            </form>
                            <form asp-action="ProcessPayment" method="post">
                                <input type="hidden" name="bookingCode" value="@Model.BookingCode" />
                                <input type="hidden" name="method" value="BankTransfer" />
                                <button type="submit" class="payment-btn border-0 bg-white shadow-sm p-4 rounded-3 d-flex flex-column align-items-center" style="width: 180px; transition: 0.3s; border: 2px solid transparent !important;">
                                    <i class="fas fa-university fa-3x mb-3 text-primary"></i>
                                    <span class="fw-bold">Chuyển khoản</span>
                                </button>
                            </form>
                        </div>
                    </div>
                }

                <!-- LỊCH SỬ THANH TOÁN -->
                @if (Model.Payments != null && Model.Payments.Any())
                {
                    <div class="mt-5 px-4">
                        <h5 class="mb-4 text-center text-uppercase fw-bold" style="color: #d4af37; letter-spacing: 1px;">Lịch Sử Thanh Toán</h5>
                        <div class="table-responsive">
                            <table class="table table-hover border">
                                <thead class="table-light">
                                    <tr>
                                        <th>Phương thức</th>
                                        <th>Số tiền</th>
                                        <th>Thời gian</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payment in Model.Payments.OrderByDescending(p => p.CreatedAt))
                                    {
                                        <tr>
                                            <td>
                                                @if (payment.Method == SpaN5.Models.PaymentMethod.BankTransfer)
                                                {
                                                    <span class="badge bg-primary">Chuyển khoản</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Tiền mặt</span>
                                                }
                                            </td>
                                            <td class="fw-bold">@payment.Amount.ToString("N0") VNĐ</td>
                                            <td>@payment.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                            <td>
                                                @if (payment.Status == SpaN5.Models.PaymentStatus.Paid)
                                                {
                                                    <span class="text-success"><i class="fas fa-check-circle me-1"></i> Thành công</span>
                                                }
                                                else
                                                {
                                                    <span class="text-warning"><i class="fas fa-clock me-1"></i> Chờ xác nhận</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <style>
                    .payment-btn:hover {
                        transform: translateY(-10px);
                        border-color: #d4af37 !important;
                        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
                    }
                </style>

                <div class="text-center mt-5 mb-4">
                    <p class="text-muted small px-5">Chúng tôi đã gửi thông tin chi tiết qua email/SMS của bạn. Nhân viên sẽ liên hệ lại để xác nhận lịch hẹn trong ít phút.</p>
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a href="/" class="btn btn-outline-dark rounded-pill px-4">Về Trang Chủ</a>
                        <a href="@Url.Action("Details", "Booking", new { bookingCode = Model.BookingCode })" class="btn btn-primary rounded-pill px-4"><i class="fas fa-tasks me-2"></i>Quản Lý Lịch Hẹn</a>
                        <a href="/Booking" class="btn btn-gold text-white rounded-pill px-4" style="background-color: #d4af37;">Đặt Thêm Lịch</a>
                        <button onclick="window.print()" class="btn btn-light rounded-pill px-4"><i class="fas fa-print me-2"></i>In phiếu</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
