@model SpaN5.Models.Booking
@{
    ViewData["Title"] = "Đặt Lịch Thành Công";
    var firstDetail = Model.BookingDetails.FirstOrDefault();
    var serviceName = firstDetail?.Service?.ServiceName ?? "Dịch vụ đã chọn";
}

<style>
    .success-container {
        max-width: 800px;
        margin: 0 auto;
    }
    .success-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
        border-top: 6px solid #d4af37;
    }
    .success-header {
        background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);
        padding: 40px 20px;
        text-align: center;
    }
    .success-icon {
        width: 80px;
        height: 80px;
        background: #d4af37;
        color: white;
        font-size: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
        margin: 0 auto 20px;
        box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
    }
    .booking-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        padding: 30px;
        background: #fafafa;
        border-radius: 15px;
        margin: 20px;
    }
    .info-item {
        border-bottom: 1px dashed #eee;
        padding-bottom: 15px;
    }
    .info-label {
        color: #888;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 5px;
    }
    .info-value {
        color: #333;
        font-weight: 600;
        font-size: 1.1rem;
    }
    .booking-code-box {
        background: rgba(212, 175, 55, 0.1);
        border: 2px dashed #d4af37;
        padding: 20px;
        border-radius: 10px;
        margin-top: 20px;
        text-align: center;
    }
    .code-text {
        font-size: 2rem;
        font-weight: 800;
        color: #d4af37;
        letter-spacing: 3px;
        display: block;
    }
</style>

<div class="container py-5">
    <div class="success-container">
        <div class="success-card">
            <div class="success-header">
                <div class="success-icon">
                    <i class="fas fa-check"></i>
                </div>
                <h2 class="font-playfair display-6 text-dark mb-2">Đặt Lịch Thành Công!</h2>
                <p class="text-muted">Cảm ơn @Model.Customer.FullName đã tin tưởng SpaN5</p>
            </div>

            <div class="p-4">
                <h5 class="mb-4 text-center text-uppercase fw-bold" style="color: #d4af37; letter-spacing: 2px;">Thông Tin Lịch Hẹn</h5>
                
                <div class="booking-info-grid">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-user me-2"></i> Khách hàng</div>
                        <div class="info-value">@Model.Customer.FullName</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-phone me-2"></i> Số điện thoại</div>
                        <div class="info-value">@Model.Customer.Phone</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-spa me-2"></i> Gói dịch vụ</div>
                        <div class="info-value">@serviceName</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-calendar-alt me-2"></i> Ngày hẹn</div>
                        <div class="info-value">@Model.StartTime.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-clock me-2"></i> Giờ hẹn</div>
                        <div class="info-value">@Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-money-bill-wave me-2"></i> Tổng cộng</div>
                        <div class="info-value text-success">@Model.TotalAmount.ToString("N0") VNĐ</div>
                    </div>
                </div>

                <div class="px-4">
                    <div class="booking-code-box">
                        <span class="info-label">Mã số Booking</span>
                        <span class="code-text">@Model.BookingCode</span>
                        <p class="small text-muted mt-2 mb-0">Vui lòng cung cấp mã này cho nhân viên lễ tân khi đến spa.</p>
                    </div>
                </div>

                <!-- THÔNG BÁO THANH TOÁN TẠI QUẦY -->
                <div class="mt-5 px-4 text-center">
                    <div class="p-4 rounded-4" style="background: rgba(212, 175, 55, 0.05); border: 1px solid rgba(212, 175, 55, 0.2);">
                        <i class="fas fa-info-circle fa-2x mb-3" style="color: #d4af37;"></i>
                        <h5 class="fw-bold mb-2">Thanh toán tại quầy</h5>
                        <p class="text-muted mb-0">Quý khách vui lòng thanh toán trực tiếp tại quầy lễ tân sau khi sử dụng dịch vụ. Chúng tôi chấp nhận cả Tiền mặt và Chuyển khoản.</p>
                    </div>
                </div>

                <div class="text-center mt-5 mb-4">
                    <p class="text-muted small px-5">Chúng tôi đã gửi thông tin chi tiết qua email/SMS của bạn. Nhân viên sẽ liên hệ lại để xác nhận lịch hẹn trong ít phút.</p>
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a href="/" class="btn btn-outline-dark rounded-pill px-4">Về Trang Chủ</a>
                        <a href="@Url.Action("Details", "Booking", new { bookingCode = Model.BookingCode })" class="btn btn-primary rounded-pill px-4"><i class="fas fa-tasks me-2"></i>Quản Lý Lịch Hẹn</a>
                        <a href="/Booking" class="btn btn-gold text-white rounded-pill px-4" style="background-color: #d4af37;">Đặt Thêm Lịch</a>
                        <button onclick="window.print()" class="btn btn-light rounded-pill px-4"><i class="fas fa-print me-2"></i>In phiếu</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
