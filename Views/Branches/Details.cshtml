@model SpaN5.Models.Branch
@{
    ViewData["Title"] = Model.BranchName;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5" style="margin-top: 80px;">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Chi nhánh</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.BranchName</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <img src="/images/@Model.Image" class="img-fluid rounded-3 shadow-sm" alt="@Model.BranchName">
            }
            else
            {
                <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="height: 300px;">
                    <i class="fas fa-store fa-5x text-muted"></i>
                </div>
            }
        </div>
        <div class="col-md-6">
            <h1 class="font-playfair text-gold">@Model.BranchName</h1>
            <div class="mb-3">
                <i class="fas fa-map-marker-alt text-gold me-2"></i> <strong>Địa chỉ:</strong> @Model.Address, @Model.District, @Model.City
            </div>
            <div class="mb-3">
                <i class="fas fa-phone text-gold me-2"></i> <strong>Điện thoại:</strong> @Model.Phone
            </div>
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <div class="mb-3">
                    <i class="fas fa-envelope text-gold me-2"></i> <strong>Email:</strong> @Model.Email
                </div>
            }
            <div class="mb-3">
                <i class="far fa-clock text-gold me-2"></i> <strong>Giờ mở cửa:</strong> @Model.OpeningTime.ToString(@"hh\:mm") - @Model.ClosingTime.ToString(@"hh\:mm")
                @if (!string.IsNullOrEmpty(Model.Workday))
                {
                    <span>(@Model.Workday)</span>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="mb-3">
                    <strong>Mô tả:</strong>
                    <p>@Model.Description</p>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.FacebookLink))
            {
                <a href="@Model.FacebookLink" target="_blank" class="btn btn-outline-primary me-2">
                    <i class="fab fa-facebook"></i> Facebook
                </a>
            }
            @if (!string.IsNullOrEmpty(Model.GoogleMapLink))
            {
                <a href="@Model.GoogleMapLink" target="_blank" class="btn btn-outline-danger">
                    <i class="fas fa-map"></i> Xem bản đồ
                </a>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.GoogleMapLink))
    {
        <div class="row mt-5">
            <div class="col-12">
                <h3>Bản đồ</h3>
                <div class="ratio ratio-16x9">
                    <iframe src="@Model.GoogleMapLink" allowfullscreen="" loading="lazy"></iframe>
                </div>
            </div>
        </div>
    }
</div>